CMD:sd(playerid, params[])
{
	if( sscanf(params, "ds[128]", params[0], params[1]) ) return SCM(playerid, COLOR_WHITE, "�����������: /sd [����� ������������] [�����]");
	if( params[0] > LoadAllNed || params[0] < 0 ) return SCM( playerid, -1, "��������� ����� ������������ - �� ������!");
	if( strlen( params[1] ) > 128 || !strlen( params[1] ) ) return SCM( playerid, -1, "������������ ����� ������ - 128 ��������!");
	if(IsPlayerInRangeOfPoint( playerid, 10.0, nInfo[ params[0] ][ nPick ][ 0 ], nInfo[ params[0] ][ nPick ][ 1 ], nInfo[ params[0] ][ nPick ][ 2 ])) 
	{
	    format:str_small("[(���)����� � �����]: %s",params[1]);
	    SCM( playerid, -1, str_small );
	    
	    format:str_small("[����� � �����]: %s",params[1]);
		foreach( Player, i )
		{
		    if(IsPlayerInRangeOfPoint( i, 10.0, nInfo[ params[0] ][ nExite ][ 0 ], nInfo[ params[0] ][ nExite ][ 1 ], nInfo[ params[0] ][ nExite ][ 2 ]))
		    {
		        SCM( i, -1, str_small );
		    }
		}
		return 1;
	}
	else if(IsPlayerInRangeOfPoint( playerid, 10.0, nInfo[ params[0] ][ nExite ][ 0 ], nInfo[ params[0] ][ nExite ][ 1 ], nInfo[ params[0] ][ nExite ][ 2 ]))
	{
		format:str_small("[(���)����� �� ���������]: %s",params[1]);
		SCM( playerid, -1, str_small );
		
		format:str_small("[����� �� ���������]: %s",params[1]);
		foreach( Player, i )
		{
		    if(IsPlayerInRangeOfPoint( i, 10.0, nInfo[ params[0] ][ nPick ][ 0 ], nInfo[ params[0] ][ nPick ][ 1 ], nInfo[ params[0] ][ nPick ][ 2 ]))
		    {
		        SCM( i, -1, str_small );
		    }
		}
		return 1;
	}
	
	return SCM(playerid,-1,"�� ������ ���������� ����� ������ ��� ����� ��������� ������������!");
}

CMD:findned(playerid, params[])
{
	if(pInfo[playerid][pFrak] == 1 || pInfo[playerid][pFrak]==2 || pInfo[playerid][pFrak]==3)
	{
		if( sscanf(params, "d", params[0]) ) return SCM(playerid, COLOR_WHITE, "�����������: /findned [����� ������������]");
		if( params[0] > LoadAllNed || params[0] < 0 ) return SCM( playerid, -1, "��������� ����� ������������ - �� ������!");
		
		if(!IsPlayerInAnyVehicle(playerid)) return SCM(playerid,-1,"�� ������ ���������� � ���������� ���!");
		new car = GetPlayerVehicleID(playerid);
	    if(car < ymvd[0] && car > ymvd[20]) return SCM(playerid,-1,"�� ������ ���������� � ���������� ���!");
	    if(car < omon[0] && car > omon[18]) return SCM(playerid,-1,"�� ������ ���������� � ���������� ���!");
	    if(car < gibdd[0] && car > gibdd[25]) return SCM(playerid,-1,"�� ������ ���������� � ���������� ���!");

		new
			i = params[0];

	    if( nInfo[ i ][ nPick ][ 0 ] == 0.0 ) return SCM( playerid, -1, "������������ �� �������!");

        SendMes(playerid,-1,"{658c6a}� ��� �� ����� ���� ��������: %s �%d", GetPropertyType( i ), i);
		SetPlayerCheckpoint(playerid, nInfo[ i ][ nPick ][ 0 ], nInfo[ i ][ nPick ][ 1 ], nInfo[ i ][ nPick ][ 2 ], 5.0);
	 	SCM(playerid,-1,"����� ��������� GPS-���������, ������� /gps ��� ���"),
	 	SetPVarInt(playerid,"gps",1);
	 	return 1;
	}
	else return SCM( playerid, -1, "� ��� ��� ������� � ������ �������!");
}

CMD:kd(playerid, params[])
{
	if(pInfo[playerid][pFrak] == 1 || pInfo[playerid][pFrak]==2)
	{
		if( sscanf(params, "d", params[0]) ) return SCM(playerid, COLOR_WHITE, "�����������: /kd [����� ������������]");
		if( params[0] > LoadAllNed || params[0] < 0 ) return SCM( playerid, -1, "��������� ����� ������������ - �� ������!");
		if(IsPlayerInRangeOfPoint( playerid, 5.0, nInfo[ params[0] ][ nPick ][ 0 ], nInfo[ params[0] ][ nPick ][ 1 ], nInfo[ params[0] ][ nPick ][ 2 ]) || IsPlayerInRangeOfPoint( playerid, 10.0, nInfo[ params[0] ][ nExite ][ 0 ], nInfo[ params[0] ][ nExite ][ 1 ], nInfo[ params[0] ][ nExite ][ 2 ]))
		{
		    if( nInfo[ params[0] ][ nLock ] == 0 ) return SCM( playerid, -1, "������������ ��� �������!");
		    nInfo[ params[0] ][ nLock ] = 0;
		    foreach( Player, i )
			{
				if(IsPlayerInRangeOfPoint( i, 10.0, nInfo[ params[0] ][ nPick ][ 0 ], nInfo[ params[0] ][ nPick ][ 1 ], nInfo[ params[0] ][ nPick ][ 2 ]) || IsPlayerInRangeOfPoint( i, 10.0, nInfo[ params[0] ][ nExite ][ 0 ], nInfo[ params[0] ][ nExite ][ 1 ], nInfo[ params[0] ][ nExite ][ 2 ]))
				{
				    format:str_small("* %s ���������� ����� ��� � ������� ����������� ������� ����� ������� �����", pInfo[ playerid ][ pName ] );
				    SCM( i, 0xAF5DD2FF, str_small );
				}
			}
			cmd::akick(playerid);
			return 1;
		}

		return SCM(playerid,-1,"�� ������ ���������� ����� ������ ��� ����� ��������� ������������!");
	}
	else return SCM( playerid, -1, "� ��� ��� ������� � ������ �������!");
}

CMD:rd(playerid)
{
	if(pInfo[playerid][pFrak]==0) return SCM(playerid,-1,"�� �� �������� �� � ����� �� �������");
	if(pInfo[playerid][pFrak]==1 || pInfo[playerid][pFrak]==2 || pInfo[playerid][pFrak]==3)
	{
	    if( GetPVarInt(playerid,"dps_radio") == 1 || GetPVarInt(playerid,"dps_radio") == 0 )
