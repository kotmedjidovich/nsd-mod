IsWeapon(playerid, slot)
{
    for(new h = 0; h < 13; h++)
	{
  		new id, ammo;
		GetPlayerWeaponData(playerid,slot,id,ammo);
		if(id!=0 && ammo != 0) return 1;
		id=EOS; ammo=EOS;
 }
	return false;
}

IsWeaponID(playerid, id)
{
    for(new h = 0; h < 13; h++)
	{
		new num, ammo;
		GetPlayerWeaponData(playerid,h,num,ammo);
		if(num == id && ammo != 0) return 1;
	}
	return false;
}

RemovePlayerWeapon(playerid, weaponid)
{
	new plyWeapons[12] = 0;
	new plyAmmo[12] = 0;
	for(new slot = 0; slot != 12; slot++)
	{
		new wep, ammo;
		GetPlayerWeaponData(playerid, slot, wep, ammo);

		if(wep != weaponid && ammo != 0)
		{
			GetPlayerWeaponData(playerid, slot, plyWeapons[slot], plyAmmo[slot]);
		}
	}
	SafeResetPlayerWeapons(playerid);
	for(new slot = 0; slot != 12; slot++)
	{
		if(plyAmmo[slot] != 0)
		{
			GivePlayerWeapon(playerid, plyWeapons[slot], plyAmmo[slot]);
		}
	}
	return 1;
}

SafeResetPlayerWeapons(plyid)
{
	ResetPlayerWeapons(plyid);
	return 1;
}
SaveFrak(playerid)
{
    mysql_format:str_big("UPDATE `" #DB_ACCOUNTS "` SET `Frak` = '%d'  WHERE `Name` = '%s'",pInfo[playerid][pFrak],pInfo[playerid][pName]);
    mysql_function_query(mysql_connect_ID, str_big, false, "", "");


    return 1;
}
SaveWeapon(playerid)
{
	new id[13],
    	ammo[13];

	for(new h = 0; h < 13; h++)
	{
		GetPlayerWeaponData(playerid,h,id[h],ammo[h]);
	}

	mysql_format:str_cmd("UPDATE `" #DB_ACCOUNTS "` SET `pWeapon` = '%d|%d|%d|%d|%d|%d|%d|%d|%d|%d' WHERE `ID` = '%d'",id[0],id[1],id[2],id[3],id[4],id[5],id[6],id[7],id[8],id[9],pInfo[playerid][pID]);
	mysql_function_query(mysql_connect_ID,str_cmd, false, "", "");

	mysql_format:str_cmd("UPDATE `" #DB_ACCOUNTS "` SET `pAmmo` = '%d|%d|%d|%d|%d|%d|%d|%d|%d|%d' WHERE `ID` = '%d'",ammo[0],ammo[1],ammo[2],ammo[3],ammo[4],ammo[5],ammo[6],ammo[7],ammo[8],ammo[9],pInfo[playerid][pID]);
	mysql_function_query(mysql_connect_ID,str_cmd, false, "", "");

	return ResetPlayerWeapons(playerid);
}

ac_GivePlayerWeapon(playerid, weaponid, ammo)
{
	pInfo[playerid][pWeapon][weaponid] += ammo;
 	GivePlayerWeapon(playerid,weaponid,ammo);
 	return 1;
}

ac_ResetPlayerWeaponsf(playerid)
{
	ResetPlayerWeapons(playerid);
 	for(new i=0;i<47;i++)
 	{
  		pInfo[playerid][pWeapon][i] = 0;
  		if( i <= 15 ) pInfo[playerid][pAmmo][i] = 0;
   	}
   	return 1;
}

ac_Kick(playerid, typecheat)
{
	new bool:admins = false;

	foreach(Player, i) if(pInfo[i][pAdmin] != 0)
	{
		admins = true;
		break;
	}

	if(admins == false) return SCM(playerid,-1,"" #C_ORANGE "�� ���� ����������� �� ������� � ���������� �� ���������"), Kick(playerid);

	else
	{
		switch(typecheat)
		{
			case 0: format:str_small("{E2F43D}[AC]{ffffff}: ����� %s[%d] ������ �� ������������� ���� �� ������� ��� ������!",pInfo[playerid][pName], playerid), SCM(playerid,-1,"" #C_ORANGE "�� ���� ����������� �� ������� � ���������� �� ���������"), Kick(playerid);
			case 1: format:str_small("{E2F43D}[AC]{ffffff}: ����� %s[%d] ������ �� ��� �� �������, ���������� ����!",pInfo[playerid][pName], playerid), Kick(playerid);
			case 2: format:str_small("{E2F43D}[AC]{ffffff}: ����� %s[%d] ���������� � ������������� Speed-Hack!",pInfo[playerid][pName], playerid);
			case 3: format:str_small("{E2F43D}[AC]{ffffff}: ����� %s[%d] ���������� � ������������� Speed-Hack!",pInfo[playerid][pName], playerid);
			default: format:str_small("{E2F43D}[AC]{ffffff}: ����� %s ���������� DEFAULT(������) !",pInfo[playerid][pName]);
		}
		SAM(COLOR_WHITE, str_small);
	}
   	return 1;
}

