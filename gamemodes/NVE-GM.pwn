CMD:amusic(playerid,params[])
{
    new radio[1000], distance;
	if(MUSICACTIVE == true)
	{
	    foreach(new i: Player)
		{
		    activemusic[i] = false;
			StopAudioStreamForPlayer(i);
		}
		SendAdminMessage(COLOR_WHITE, radio);
		MUSICACTIVE = false;
	    return 1;
	}
	if(sscanf(params, "s[1000]d", radio, distance)) return SendClientMessage(playerid, COLOR_WHITE, "{9ACD32}�������: {FFFFFF} /amusic [url] [���������]");
	if(strlen(radio) < 10 || strlen(radio) > 1000) return SendClientMessage(playerid, COLOR_WHITE, "�������� ���������� �������� � URL!");
	if(distance < 2 || distance > 1000) return SendClientMessage(playerid, COLOR_WHITE, "������� ������� ���������!");
	new Float:X, Float:Y, Float:Z;
	GetPlayerPos(playerid, X, Y, Z);
	MUSICACTIVE = true;
	MUSICX = X;
	MUSICY = Y;
	MUSICZ = Z;
	MUSICDIST = distance;
	strmid(MUSICURL, radio, 0, strlen(radio), 1000);
	activemusic[playerid] = true;
	foreach(new i: Player) { PlayAudioStreamForPlayer(i, radio, X, Y, Z, distance, 1); }
    SendAdminMessage(COLOR_WHITE, radio);
	return true;
}

