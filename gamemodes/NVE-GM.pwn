public OnCefInitialize(playerid, success)
{
    if (success == 1)
    {
        cef_emit_event(playerid, 1, "classic:hud:active", CEFINT(true));
        cef_emit_event(playerid, 1, "game:hud:setComponentVisible", CEFSTR("radar"), CEFINT(true));
    }
    return 1;
}

public OnPlayerDisconnect(playerid, reason)
{
	SetPVarInt(playerid, "alogin", 0);
	GetPlayerName(playerid, pInfo[playerid][pName], MAX_PLAYER_NAME);
	if(strcmp(pInfo[playerid][pName], "Kanaev", true) == 0)
	{
		mysql_format:str_cmd("UPDATE `" #DB_ACCOUNTS "` SET `Name` = 'Blake_Sweizy' WHERE `ID` = '%d'",pInfo[playerid][pID]);
  		mysql_function_query(mysql_connect_ID, str_cmd, false, "", "");
		SetPlayerName(playerid, "Aleksandr_Kanaev"), GetPlayerName(playerid, pInfo[playerid][pName], MAX_PLAYER_NAME);
	}
  	if(strcmp(pInfo[playerid][pName], "Alishka", true) == 0)
  	{
 		mysql_format:str_cmd("UPDATE `" #DB_ACCOUNTS "` SET `Name` = 'Said_Aliguseev' WHERE `ID` = '%d'",pInfo[playerid][pID]);
  		mysql_function_query(mysql_connect_ID, str_cmd, false, "", "");
		SetPlayerName(playerid, "Said_Aliguseev"), GetPlayerName(playerid, pInfo[playerid][pName], MAX_PLAYER_NAME);
	}
	if(strcmp(pInfo[playerid][pName], "4elik", true) == 0)
	{
		mysql_format:str_cmd("UPDATE `" #DB_ACCOUNTS "` SET `Name` = 'Boeslav_Majorov' WHERE `ID` = '%d'",pInfo[playerid][pID]);
  		mysql_function_query(mysql_connect_ID, str_cmd, false, "", "");
		SetPlayerName(playerid, "Boeslav_Majorov"), GetPlayerName(playerid, pInfo[playerid][pName], MAX_PLAYER_NAME);
	}
    TextDrawDestroy(zapravkai[0][playerid]),TextDrawDestroy(zapravkai[1][playerid]);
    TextDrawDestroy(ftextdrawp[0][playerid]),TextDrawDestroy(ftextdrawp[1][playerid]);
	PlayerTextDrawDestroy(playerid,pgruz1[playerid]), PlayerTextDrawDestroy(playerid,pgruz2[playerid]),PlayerTextDrawDestroy(playerid,pstr1[playerid]),PlayerTextDrawDestroy(playerid,pstr2[playerid]), PlayerTextDrawDestroy(playerid,Speedmetr2[playerid]), PlayerTextDrawDestroy(playerid,namenter[playerid]);
	TextDrawDestroy(Speedmetr1[playerid]), TextDrawDestroy(Speedmetr3[playerid]), TextDrawDestroy(Speedmetr4[playerid]), TextDrawDestroy(Speedmetr5[playerid]), TextDrawDestroy(Speedmetr6[playerid]);
	TextDrawDestroy(Speedmetr7[playerid]), TextDrawDestroy(Speedmetr9[playerid]), TextDrawDestroy(Speedmetr10[playerid]), TextDrawDestroy(Speedmetr11[playerid]), TextDrawDestroy(Speedmetr12[playerid]), TextDrawDestroy(Speedmetr0[playerid]);
    TextDrawDestroy(texttruck[0][playerid]),TextDrawDestroy(texttruck[1][playerid]),TextDrawDestroy(texttruck[2][playerid]),TextDrawDestroy(texttruck[3][playerid]),TextDrawDestroy(texttruck[4][playerid]);
    PlayerTextDrawDestroy(playerid, udostvng1[playerid]), PlayerTextDrawDestroy(playerid, udostmvd1[playerid]), PlayerTextDrawDestroy(playerid, udostmvd2[playerid]), PlayerTextDrawDestroy(playerid, udostmvd3[playerid]), PlayerTextDrawDestroy(playerid, udostmvd4[playerid]);
    for(new i; i != 11; i++) TextDrawDestroy(skintext[i][playerid]);
    
    if(GetPVarInt(playerid,"ccfon")==1) DeletePVar(playerid,"ccfon"), TextDrawHideForPlayer( playerid, ccfon );
    
    
    if(reason == 0) format:str_least("�����/����");
	if(reason == 1) format:str_least("�����");
	if(reason == 2) format:str_least("���/���");
	
    format:str_small("" #C_LIGHTBLUE "[DISCONNECT] %s[%d] - %s (%s)",pInfo[playerid][pName],playerid,pInfo[playerid][pIP], str_least);
	SAMT(COLOR_WHITE, str_small, 3);
	str_small[0] = EOS;
	str_least[0] = EOS;

	if(GetPVarInt(playerid,"gLogged")!=1) return 1;
    if(GetPVarInt(playerid,"truck")==1) konec(playerid);
    if(GetPVarInt(playerid,"buycar") >= 1) DestroyVehicle(playersellcar[playerid]), playersellcar[playerid]=EOS;
    if(adcar[playerid]!=0) DestroyVehicle(adcar[playerid]), adcar[playerid]=0;
    if(GetPVarInt(playerid,"pme")==1)
    {
		DestroyDynamic3DPlayer( pInfo[playerid][pDesc], playerid );
	}
	
    if(GetPVarInt(playerid,"cdocar") != 0)
	{
		DestroyDynamic3DVehicle( cdotext[GetPVarInt(playerid,"cdocar")], GetPVarInt(playerid,"cdocar") );
		cdo[GetPVarInt(playerid,"cdocar")] = false;
	}
    if(strlen(mInfo[playerid][mdo1])>1) DeleteDynamic3DText(mInfo[playerid][mdotext][0]);
    if(strlen(mInfo[playerid][mdo2])>1) DeleteDynamic3DText(mInfo[playerid][mdotext][1]);
    if(strlen(mInfo[playerid][mdo3])>1) DeleteDynamic3DText(mInfo[playerid][mdotext][2]);
    if(GetPVarInt(playerid,"jobcar")!=0) SetVehicleToRespawn(GetPVarInt(playerid,"jobcar"));
    if(GetPVarInt(playerid,"motorent")!=0)
	{
		DestroyVehicle(playersellcar[playerid]);
		milleage[playersellcar[playerid]] = 0.0;
		Gas[playersellcar[playerid]] = 0.0;
		playersellcar[playerid]=EOS;
		TextDrawHideForPlayer(playerid,salon[0]); TextDrawHideForPlayer(playerid,salon[1]); TextDrawHideForPlayer(playerid,salon[2]); TextDrawHideForPlayer(playerid,salon[3]);
		TextDrawHideForPlayer(playerid,salon[6]); TextDrawHideForPlayer(playerid,salon[7]); TextDrawHideForPlayer(playerid,salon[9]); TextDrawHideForPlayer(playerid,salon[10]); TextDrawHideForPlayer(playerid,motorent);
		DeletePVar(playerid,"motorent");
	}
	
	if( GetPVarInt(playerid,"editfrakobject") == 1 )
	{
	    DestroyDynamicObjected( eobj[playerid] );
	    eobj[playerid] = EOS;
	}
    if( GetPVarInt(playerid,"editobject") == 1 )
    {
	    DestroyDynamicObjected(eobj[playerid]);
	    eobj[playerid] = EOS;
	}
	if( GetPVarInt(playerid,"fursel") == 1 )
    {
	    DestroyPlayerObject( playerid, fInfo[ GetPVarInt(playerid,"nmenuid") ][ fObjectid ][ GetPVarInt( playerid, "furslot" ) ] );
	    fInfo[ GetPVarInt(playerid,"nmenuid") ][ fObjectid ][ GetPVarInt( playerid, "furslot" ) ] = EOS;
	    fInfo[ GetPVarInt(playerid,"nmenuid") ][ fObject ][ GetPVarInt( playerid, "furslot" ) ] = EOS;
	}
	if( furnitureid[ playerid ] != 0 && GetPVarInt(playerid,"fshop") == 1)
	{
		DestroyPlayerObject( playerid, furnitureid[ playerid ] );
		furnitureid[ playerid ] = EOS;
	}
	
	if(GetPVarInt(playerid,"editcarattach") != 0)
	{
        if(GetPVarInt(playerid,"editcarattach") == 1)
		{
		    new
				i = GetPVarInt( playerid, "editattachcar"),
				car = GetPVarInt( playerid, "attachcar"),
   				Float:px, Float:py, Float:pz;

			GetVehiclePos(cInfo[ car ][ cCar ], px, py, pz);
            AttachDynamicObjectToVehicle(cInfo[ car ][ cAttachID ][ i ], cInfo[ car ][ cCar ], px, py, pz + 1.3, 0.0, 0.0, 0.0);

            cInfo[ car ][ cObjectX ][ i ] = px,
			cInfo[ car ][ cObjectY ][ i ] = py,
			cInfo[ car ][ cObjectZ ][ i ] = pz + 1.3,
			cInfo[ car ][ cObjectfX ][ i ] = 0.0,
			cInfo[ car ][ cObjectfY ][ i ] = 0.0,
			cInfo[ car ][ cObjectfZ ][ i ] = 0.0;

			SaveCarAttach( car );

		}
		else if(GetPVarInt(playerid,"editcarattach") == 2)
		{
			new
				i = GetPVarInt( playerid, "editattachcar"),
				car = GetPVarInt( playerid, "attachcar");
				
			DestroyDynamicObjected( cInfo[ car ][ cAttachID ][ i ] );
			
			cInfo[ car ][ cAttachID ][ i ] = 0;
			cInfo[ car ][ cObjectInv ][ i ] = 0;
			cInfo[ car ][ cAttachObject ][ i ] = 0;
			
			SaveCarAttach( car );
		}
	}

    for(new id; id < MAX_VIZ; id ++)
	{
		if(viInfo[id][viPlayerid]!=playerid && viInfo[id][viEnter]!=1) continue;
	    viInfo[id][viID]=id;
		viInfo[id][viPlayerid]=0;
		viInfo[id][viEnter]=0;
		viInfo[id][viPos][0]=0;
		viInfo[id][viPos][1]=0;
		viInfo[id][viPos][2]=0;
		strmid(viInfo[id][viText], "0", 0, strlen("0"), 70), vizov--;
		if(vizov<0) vizov=0;
		break;
    }
    
    for(new za; za != LoadAllCar; za++)
   	{
   	    if(!strcmp(cInfo[za][cOwner],pInfo[playerid][pName],true))
		{
		    if( cInfo[ za ][ cArrest ] != 1 )
		    {
				if( cInfo[ za ][ cTime ] == 0 ) cInfo[ za ][ cTime ] = gettime()+43200;
			}

			// ���������� ������, ���� �������� �����
			if(cInfo[za][cMusic][1] != 0)
			{
			    foreach(Player, i)
				{
					if(IsPlayerInDynamicArea(playerid,cInfo[za][cMusic][2])) StopAudioStreamForPlayer(i);
				}
                        
				if(IsValidDynamicArea(cInfo[za][cMusic][2])) DestroyDynamicArea(cInfo[za][cMusic][2]), cInfo[GetPVarInt(playerid,"cmenuid")][cMusic][2] = 0;
			 	cInfo[za][cMusic][1] = 0;
			}
		}
	}
    	
    if(GetPVarInt(playerid,"motoid")!=0) konecmoto(playerid);

    if(GetPVarInt(playerid,"taxi")==1 && GetPVarInt(playerid,"taxitype")!=0)
	{
		if(GetPVarInt(playerid,"perevoz")==1)
		{
			DeletePVar( GetPVarInt(playerid,"taxip") , "taxipp"   );
			DeletePVar( GetPVarInt(playerid,"taxip") , "pperevoz" );
			RemovePlayerFromVehicle( GetPVarInt(playerid,"taxip") );
			SetVehicleToRespawn( GetPVarInt(playerid,"taxip") );
		}
		textdrawtaxi(playerid,0,0,0,1,0,0);
		tdriver--;
		textupdate();
	}
	
	if(GetPVarInt(playerid,"hand") != 0) RemovePlayerAttachedObject(playerid, 9);
	
	if(GetPVarInt(playerid,"pperevoz")==1)
	{
		new dr = GetPVarInt(playerid,"taxipp");
		GiveMoney(playerid,-GetPVarInt(dr,"plata"));
		SetPVarInt(dr,"zarplata",GetPVarInt(dr,"zarplata")+GetPVarInt(dr,"plata"));

		pformat:( "�� �������� "C_GRAY"%d ���",GetPVarInt(dr,"plata"));
		psend:( playerid, COLOR_WHITE );
		
		textdrawtaxi(dr,0,0,0,0,0,1);
		DeletePVar(dr,"perevoz");
		DeletePVar(dr,"s");
		DeletePVar(dr,"plata");
		DeletePVar(dr,"taxip");
		DeletePVar(dr,"zarplata");
	}
	
	for(new i; i != 3; i ++)
	{
		if(aObj[playerid][aSlot][i] != 0)
		{
			aObj[playerid][aSlot][i] = 0;
			aObj[playerid][aObject][i] = 0;
			aObj[playerid][aBone][i] = 0;
			aObj[playerid][aX][i] = 0.0;
			aObj[playerid][aY][i] = 0.0;
			aObj[playerid][aZ][i] = 0.0;
			aObj[playerid][aFX][i] = 0.0;
			aObj[playerid][aFY][i] = 0.0;
			aObj[playerid][aFZ][i] = 0.0;
		}
	}

	// ����� � ����, �������, ����� �����
    new c,m,s,d,y,me,Float:pos1,Float:pos2,Float:pos3,Float:pos4; getdate(y,me,d); gettime(c,m,s);  // if(m>50 && c!=23) c++;
    
	if(reason == 0) format:str_least("�����/����");
	if(reason == 1) format:str_least("�����");
	if(reason == 2) format:str_least("���/���");

	if(GetPVarInt(playerid,"spec") != 1)
	{
	    format:str_small("(( %s[%d] ������� ����. �������: %s ))",pInfo[playerid][pName],playerid,str_least);
		ProxDetector(20.0,playerid,str_small,0x858585FF,0x858585FF,0x858585FF,0x858585FF,0x858585FF);
	}
	SaveFrak(playerid);
	SaveWeapon(playerid);
	viptime[playerid] = 0;
    
	GetPlayerPos(playerid,pos1,pos2,pos3); GetPlayerFacingAngle(playerid,pos4);
	
	if(GetPVarInt(playerid,"mask") != 0)
	{
	    GivePlayerItem(playerid,378,1);
	    DestroyDynamic3DPlayer( mask[playerid], playerid );
	}
	
	if(GetPVarInt(playerid,"mute") !=0 )
	{
		mysql_format:str_small("UPDATE `" #DB_ACCOUNTS "` SET `Mute` = '%d' WHERE `Name` = '%s'",GetPVarInt(playerid,"mute"), pInfo[playerid][pName]);
		mysql_function_query(mysql_connect_ID, str_small, false, "", "");
	}
	if(pInfo[playerid][pArrest]!=0)
	{
		mysql_format:str_small("UPDATE `" #DB_ACCOUNTS "` SET `Arrest` = '%d' WHERE `Name` = '%s'",pInfo[playerid][pArrest], pInfo[playerid][pName]);
		mysql_function_query(mysql_connect_ID, str_small, false, "", "");
	}

    if( GetPVarInt(playerid,"skinshop") == 0 && GetPVarInt(playerid,"buycar") == 0 && GetPVarInt(playerid,"skinchange") == 0 && GetPVarInt(playerid,"fshop") == 0)
    {
		mysql_format:str_cmd("UPDATE `" #DB_ACCOUNTS "` SET `Time` = '%d|%d', `Pos` = '%f|%f|%f|%f', `Virt` = '%d' WHERE `Name` = '%s'",c,d,pos1,pos2,pos3,pos4,GetPlayerVirtualWorld(playerid),pInfo[playerid][pName]);
		mysql_function_query(mysql_connect_ID, str_cmd, false, "", "");
	}
	
	if(GetPVarInt(playerid,"duty") == 1)
	{
        mysql_format:str_small("UPDATE `" #DB_ACCOUNTS "` SET `Fskin` = '%d' WHERE `ID` = '%d'",GetPlayerSkin(playerid),pInfo[playerid][pID]);
		mysql_function_query(mysql_connect_ID, str_small, false, "", "");
		str_small[0] = EOS;
    }
	
	new year, month, day;
	getdate(year, month, day);
	mysql_format:str_small("UPDATE `" #DB_ACCOUNTS "` SET `Lastip` = '%s', `Lastdate` = '%d|%d|%d' WHERE `ID` = '%d'", pInfo[playerid][pLastip], day, month, year, pInfo[playerid][pID]);
	mysql_function_query(mysql_connect_ID, str_small, false, "", "");
	str_small[0] = EOS;
	
	foreach(Player, i)
	{
		if( pInfo[i][pAdmin] != 0 )
		{
			if( GetPVarInt( i, "spectable" ) == playerid && GetPVarInt( i, "spec" ) == 1 )
			{
			    SendMes( i, -1, "����� %s[%d] �����/������� �� ����. " #C_GRAY "����� �������� - ��������!", pInfo[playerid][pName], playerid );
			    Specoff( i );
			}
		}
	}
	
	cmd::c(playerid);

	
	return 1;
}

public OnPlayerSpawn(playerid)
{
    SetPlayerColor(playerid,0xFFFFFF00);
    if(GetPVarInt(playerid,"skinchange")==1)
	{
		TogglePlayerSpectating(playerid,0);
		TogglePlayerControllable(playerid,0);
