    str_big[0] = EOS;

    return 1;
}

IsVelo(carid)
{
	switch(GetVehicleModel(carid)) { case 481,509,510:return true; }
	return 0;
}

IsBike(carid)
{
	switch(GetVehicleModel(carid)) { case 448,461,462,463,468,471,521,522,523,581,586:return true; }
	return 0;
}

IsCopCar(carid)
{
	switch(GetVehicleModel(carid))
	{
		case 402,598,596,599,597,528,427,580,518:return true;
	}
	return 0;
}


SpeedVehicle(vehicleid)
{
	new Float:x, Float:y, Float:z;
	GetVehicleVelocity(vehicleid, x, y, z);
	return floatround(floatsqroot(x*x+y*y)*101.666667);
}

GiveMoney(i,num) { pInfo[i][pMoney]+=num, SaveMoney(i); return 0; }
SaveMoney(i) { mysql_format:str_small("UPDATE `" #DB_ACCOUNTS "` SET `Money` = '%d' WHERE `Name` = '%s'",pInfo[i][pMoney],pInfo[i][pName]), mysql_function_query(mysql_connect_ID, str_small, false, "", ""); }

