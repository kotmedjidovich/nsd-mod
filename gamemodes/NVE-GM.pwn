		SCM(playerid,COLOR_DARK_GRAY,"������� ��� ������ ��������������� ����� ����. � ��������� ������ ��� ����� ��������");
		for(new z; z != 6; z++) TextDrawShowForPlayer(playerid,tskinc[z]);
	    SelectTextDraw(playerid,0xFF0000FF);
		return 1;
	}

    Logotype[playerid] = TextDrawCreate(580.000000, -16.177778, "apack:abilityproject");
	TextDrawLetterSize(Logotype[playerid], 0.000000, 0.000000);
	TextDrawTextSize(Logotype[playerid], 58.500000, 66.577774);
	TextDrawAlignment(Logotype[playerid], 1);
