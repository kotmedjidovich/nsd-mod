CMD:p(playerid)
{
	if( c_info[playerid][cStatus] != 2) return SCM(playerid,-1,"��� ����� �� ������!");
	
	new id = c_info[playerid][cCaller];
	
	if( c_info[id][cStatus] != 1) return SCM(playerid,-1,"��� ����� �� ������!");
	
	pformat:( "������� %d ������� �� ��� ������",pInfo[playerid][pNumber]);
	psend:( id, COLOR_WHITE );
	
	if( GetPVarInt( id, "payphone") == 0 )
	{
		pformat:( "�� �������� �� ����� �� �������� %d",pInfo[id][pNumber]);
		psend:( playerid, COLOR_WHITE );
	}
	else
	{
		pformat:( "�� �������� �� ����� �� ��������� �%d",GetPVarInt( id, "payphone"));
		psend:( playerid, COLOR_WHITE );
	}
	
	PlayAudioStreamForPlayer(id,"http://exrptest.myarena.ru/vzal.mp3");
	
	c_info[id][cStatus] = 3;
	c_info[playerid][cStatus] = 4;
	
	DeletePVar(id,"goodok");

    return 1;
}

CMD:c(playerid)
{
	if( c_info[playerid][cStatus] == 2) // �������� �������� �����
	{
	    new id = c_info[playerid][cCaller];
	    
		SCM(playerid,-1,"�� �������� �������� �����");
		SCM(id,-1,"������� ������� ��� �����");
		
		c_info[playerid][cStatus] = 0;
		c_info[playerid][cCaller] = 0;
		c_info[playerid][cStatus] = 0;
		
		c_info[id][cStatus] = 0;
		c_info[id][cCaller] = 0;
		c_info[id][cStatus] = 0;
		
		return 1;
	}
	
	if( c_info[playerid][cStatus] == 1) // �������� ��������� �����
	{
	    new id = c_info[playerid][cAnswerer];

		SCM(playerid,-1,"�� �������� ��������� �����");
		SCM(id,-1,"������� ������� �������� �����");

		c_info[playerid][cStatus] = 0;
		c_info[playerid][cCaller] = 0;
		c_info[playerid][cStatus] = 0;

		c_info[id][cStatus] = 0;
		c_info[id][cCaller] = 0;
		c_info[id][cStatus] = 0;

		return 1;
	}
	
	if( c_info[playerid][cStatus] == 3) // �������� �������� �� ���������
	{
	    new id = c_info[playerid][cAnswerer];

		SCM(playerid,-1,"�� ��������� �����");
		SCM(id,-1,"������� ������� �����");

		c_info[playerid][cStatus] = 0;
		c_info[playerid][cCaller] = 0;
		c_info[playerid][cStatus] = 0;
		
		if( GetPVarInt( playerid, "payphone") == 0 )
		{
			pInfo[playerid][pPhonemoney] -= GetPVarInt( playerid, "calltime" ) * 2;
	 		mysql_format:str_small("UPDATE `" #DB_ACCOUNTS "` SET `Phonemoney` = '%d'  WHERE `ID` = '%d'", pInfo[playerid][pPhonemoney], pInfo[playerid][pID]);
			mysql_function_query(mysql_connect_ID, str_small, false, "", "");
		
			pformat:( "������������ ������: " #C_GRAY "%s - {ffffff}�� ����� ���������� ������: " #C_GRAY "%d",Convert(GetPVarInt(playerid,"calltime")), GetPVarInt( playerid, "calltime" ) * 2 );
			psend:( playerid, COLOR_WHITE );
		}
		
		DeletePVar(playerid,"calltime");
		if( GetPVarInt( playerid, "payphone" ) != 0 )
		{
			DeletePVar( playerid, "payphone" );
			TogglePlayerControllable( playerid, true );
		}

		c_info[id][cStatus] = 0;
		c_info[id][cCaller] = 0;
		c_info[id][cStatus] = 0;

		return 1;
	}
	
	if( c_info[playerid][cStatus] == 4) // �������� �������� �� �����������
	{
	    new id = c_info[playerid][cCaller];

		SCM(id,-1,"�� ��������� �����");
		SCM(playerid,-1,"������� ������� �����");

		c_info[id][cStatus] = 0;
		c_info[id][cCaller] = 0;
		c_info[id][cStatus] = 0;

        if( GetPVarInt( id, "payphone") == 0 )
		{
			pInfo[id][pPhonemoney] -= GetPVarInt( id, "calltime" ) * 2;
	 		mysql_format:str_small("UPDATE `" #DB_ACCOUNTS "` SET `Phonemoney` = '%d'  WHERE `ID` = '%d'", pInfo[id][pPhonemoney], pInfo[id][pID]);
			mysql_function_query(mysql_connect_ID, str_small, false, "", "");

			pformat:( "������������ ������: " #C_GRAY "%s - {ffffff}�� ����� ���������� ������: " #C_GRAY "%d",Convert(GetPVarInt(id,"calltime")), GetPVarInt( id, "calltime" ) * 2 );
			psend:( id, COLOR_WHITE );
		}
		
		DeletePVar(id,"calltime");
		if( GetPVarInt( id, "payphone" ) != 0 )
		{
			DeletePVar( id, "payphone" );
			TogglePlayerControllable( id, true );
		}

		c_info[playerid][cStatus] = 0;
		c_info[playerid][cCaller] = 0;
		c_info[playerid][cStatus] = 0;

		return 1;
	}
	
	SCM(playerid,-1,"� ��� ��� ��������/��������� �������!");
	
	return 1;
}

CMD:moto(playerid)
{
	if(GetPVarInt(playerid,"motoid")==0) return SCM(playerid,-1,"�� �� ���������� �����!");
	new Float:p1,Float:p2,Float:p3; GetVehiclePos(GetPVarInt(playerid,"motoid"),p1,p2,p3);
	if(!IsPlayerInRangeOfPoint(playerid,10.0,p1,p2,p3)) return SCM(playerid,-1,"�� ������ ���������� ����� ������ ������");
	SPD(playerid,dMoto+1,list,"" #C_GRAY "���������� �������","" #C_GRAY "1. {ffffff}�������� ����� �� GPS\n" #C_GRAY "2. {ffffff}������� ����� � ����������","��","�������");
	return 1;
}

CMD:fobj(playerid)
{
    if( GetPVarInt(playerid,"editfrakobject") == 1 ) return SCM(playerid, -1,"��������� �������������� �������!");
    if( GetPVarInt(playerid,"editobject") == 1 ) return SCM(playerid, -1,"��������� �������������� �������!");
    if( GetPVarInt(playerid,"editcarattach") != 0 ) return SCM(playerid, -1,"��������� �������������� �������!");
    
    if( pInfo[playerid][pArrest] != 0 ) return SCM(playerid, -1,"� ��� ������� ��� ����, � ������ ������  ����� ��������� ������ ����������");
    
	if(pInfo[playerid][pFrak]!=0) return SPD(playerid,dFrakobj,list,"" #C_ABILITY "��������� ��������","" #C_ABILITY "1. {ffffff}��������\n" #C_ABILITY "2. {ffffff}������\n" #C_ABILITY "3. {ffffff}������������� �������","��","�������");
	SCM(playerid,-1,"������ ������� ��� �� ��������!");
	return 1;
}

CMD:delobj(playerid)
{
	if(pInfo[playerid][pFrak]==0) return SCM(playerid,-1,"������ ������� ��� �� ��������!");

	for(new i; i != MAX_FRAK_OBJ; i ++)
	{
		if(fObj[i][objFrak] == pInfo[playerid][pFrak])
		{
			if(IsPlayerInRangeOfPoint(playerid,3.0,fObj[i][objPos][0],fObj[i][objPos][1],fObj[i][objPos][2]))
			{
				DestroyDynamicObjected(fObj[i][objID]); SCM(playerid,-1,"�� ������� ������");
				fObj[i][objID]=0;
				fObj[i][objPlayer]=0;
				fObj[i][objFrak]=0;
				fObj[i][objPos][0]=0.0;
				fObj[i][objPos][1]=0.0;
				fObj[i][objPos][2]=0.0;
				break;
			}
		}
	}

	return 1;
}

CMD:del(playerid)
{
	if(GetPVarInt(playerid,"hand") != 0)
	{
		return RemovePlayerAttachedObject(playerid, 9), DeletePVar(playerid,"hand"), DeletePVar(playerid,"handuse"), ApplyAnimation(playerid,"PED","IDLE_tired",4.1,1,1,1,0,1), SCM(playerid,-1,"��, ���-�� �������� �� ����� ���!");
	}
	else return SCM(playerid,-1,"� ��� ��� ������ � �����!");
}

public: OnPlayerBuyingCar( playerid, car )
{
	cInfo[car][cID] = cache_insert_id();
	PutPlayerInVehicle( playerid, cInfo[car][cCar], 0 );
	ncarsel[playerid] = 0;
	SetPVarInt( playerid,"buycolor", -1 );

	return 1;
}

public: OnCreateProperty( playerid, id )
{
	nInfo[id][nID] = cache_insert_id();
	CreateProperty(id);
	
	LoadAllNed++;
	
	pformat:( "�� ������� ������������ "C_GRAY"�%d",id);
	psend:( playerid, COLOR_WHITE );

	return 1;
}

CMD:eject(playerid, params[])
{
    if(sscanf(params, "d", params[0])) return SCM(playerid, COLOR_WHITE, "�����������: /eject [�� ������]");
    if(!IsPlayerConnected(params[0])) return SCM(playerid,-1,"������ � ����� ID ��� �� �������");
	if(GetPlayerVehicleSeat(playerid)!=0) return SCM(playerid,-1,"�� ������ ���������� �� ����� ����������");
	if(GetPlayerVehicleID(params[0])!=GetPlayerVehicleID(playerid)) return SCM(playerid,-1,"����� �� ���������� � ����� ��");
	return RemovePlayerFromVehicle(params[0]), SendMes(params[0],-1,"{D8D8D8}%s ������ ��� �� ����������",pInfo[playerid][pName]), SendMes(params[0],-1,"{D8D8D8}�� ������� %s �� ����������",pInfo[params[0]][pName]);
}

