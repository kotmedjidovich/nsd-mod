{
	if(pInfo[playerid][pFrak]>0)
	{
		if(pInfo[playerid][pRang] != 5) return SCM(playerid,-1,"�� �� ��������� �������");
		new text[35];
		if(sscanf(params, "ds[35]", params[0], text)) return SCM(playerid, COLOR_WHITE, "�����������: /setdolg [�� ������] [���������]");
		if(pInfo[params[0]][pFrak] != pInfo[playerid][pFrak]) return SCM(playerid, COLOR_WHITE, "����� ������� � ������ �������");
		if(GetPVarInt(params[0],"gLogged")!=1) return SCM(playerid, COLOR_WHITE, "����� � ����� �� ���");
		if(strlen(text)>35||strlen(text)<1) return SCM(playerid, COLOR_WHITE, "�������� ��������� ������ �������� �� 35 ��������");

		for(new z = strlen(text)-1; z != -1; z--)
  		{
	    	switch(text[z])
	     	{
		     	case '0'..'9', 'a'..'z', 'A'..'Z', '�'..'�', '�'..'�', ' ', '-': continue;
		     	default: return SCM(playerid,-1,"����������� ������ ����� � �����!");
	  		}
  		}

		mysql_format:str_small("UPDATE `" #DB_ACCOUNTS "` SET `Dols` = '%s' WHERE `ID` = '%d'",text,pInfo[params[0]][pID]); mysql_function_query(mysql_connect_ID, str_small, false, "", "");
		SendMes(params[0],-1,"{FFEF00}����� ������� %s ������� ���� ��������� �� %s",pInfo[playerid][pName],text);
		SendMes(playerid,-1,"{FFEF00}�� �������� ��������� %s �� %s",pInfo[params[0]][pName],text);
		strmid(pInfo[params[0]][pDols], text, 0, strlen(text), 35);
	}

	if(pInfo[playerid][pOrg][1] == 10)
	{
		new text[35];
		if(sscanf(params, "ds[35]", params[0], text)) return SCM(playerid, COLOR_WHITE, "�����������: /setdolg [�� ������] [���������]");
		if(pInfo[params[0]][pOrg][0] != pInfo[playerid][pOrg][0]) return SCM(playerid, COLOR_WHITE, "����� ������� � ������ �����������");
		if(pInfo[params[0]][pFrak] != pInfo[playerid][pFrak]) return SCM(playerid, COLOR_WHITE, "����� ������� � ������ �������");
		if(GetPVarInt(params[0],"gLogged")!=1) return SCM(playerid, COLOR_WHITE, "����� � ����� �� ���");
		if(strlen(text)>35||strlen(text)<1) return SCM(playerid, COLOR_WHITE, "�������� ��������� ������ �������� �� 35 ��������");

		for(new z = strlen(text)-1; z != -1; z--)
  		{
	    	switch(text[z])
	     	{
		     	case '0'..'9', 'a'..'z', 'A'..'Z', '�'..'�', '�'..'�', ' ', '-': continue;
		     	default: return SCM(playerid,-1,"����������� ������ ����� � �����!");
	  		}
  		}

		mysql_format:str_small("UPDATE `" #DB_ACCOUNTS "` SET `Dols` = '%s' WHERE `ID` = '%d'",text,pInfo[params[0]][pID]); mysql_function_query(mysql_connect_ID, str_small, false, "", "");
		SendMes(params[0],-1,"{FFEF00}����� ������� %s ������� ���� ��������� �� %s",pInfo[playerid][pName],text);
		SendMes(playerid,-1,"{FFEF00}�� �������� ��������� %s �� %s",pInfo[params[0]][pName],text);
		strmid(pInfo[params[0]][pDols], text, 0, strlen(text), 35);
	}
	return 1;
}
