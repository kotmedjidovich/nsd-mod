CMD:online(playerid)
{
	new
		frak[7],
		othert[2];
	
    foreach(Player, i)
    {
        if( GetPVarInt( i, "taxi" ) == 1 )
        {
			othert[0]++;
		}
	    
	    if( pInfo[i][pOrg][0] > 0 && oInfo[ pInfo[i][pOrg][0] ][ oType ] == 1 )
	    {
			othert[1]++;
	    }
	    
	    if( pInfo[i][pFrak] > 0 && pInfo[i][pFrak] <= 7 )
	    {
	        if( pInfo[i][pFrak] == 2 ) continue;
	        
			frak[pInfo[i][pFrak]-1]++;
	    }
	}
	
	str_big[0]=EOS;
	
	format:str_big("\
	"C_GRAY"����:\t\t\t"C_WHITE"%d\n\
	"C_GRAY"������:\t\t"C_WHITE"%d\n\
	"C_GRAY"�������������:\t"C_WHITE"%d\n\
	"C_GRAY"��� �15:\t\t"C_WHITE"%d\n\
	"C_GRAY"����:\t\t\t"C_WHITE"%d\n\
	"C_GRAY"��� 24:\t\t\t"C_WHITE"%d\n\n\
	"C_GRAY"�������� �����:\t"C_WHITE"%d\n\
	"C_GRAY"���������� ���:\t"C_WHITE"%d",
	frak[0],frak[2],frak[3],frak[4],frak[5],frak[6],othert[0],othert[1]);
	
	SPD(playerid,d_null,info,""C_GRAY"������ ������ �� �������",str_big,"�������","");
	
	str_big[0]=EOS;

	return 1;
}

