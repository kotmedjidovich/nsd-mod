      					case 355: { if(IsWeaponID(playerid, 35)==1) return SPD(playerid,dInv+1,list,str_cmd,"{FF3300}1. {ffffff}������ ������ � ���������\n" #C_GRAY "2. {ffffff}���������\n" #C_GRAY "3. {ffffff}��������\n" #C_GRAY "4. {ffffff}����������\n" #C_GRAY "5. {ffffff}��������\n" #C_GRAY "6. {ffffff}���������� �� ����","��","�������");  }
      					case 356: { if(IsWeaponID(playerid, 36)==1) return SPD(playerid,dInv+1,list,str_cmd,"{FF3300}1. {ffffff}������ ������ � ���������\n" #C_GRAY "2. {ffffff}���������\n" #C_GRAY "3. {ffffff}��������\n" #C_GRAY "4. {ffffff}����������\n" #C_GRAY "5. {ffffff}��������\n" #C_GRAY "6. {ffffff}���������� �� ����","��","�������");  }
					}
				}

				if(sh==false) return SCM(playerid,-1,"��������� ������. " #C_GRAY "�������� �� ���� �� ��� ����� !");
				if(sh==true)
				{
					i = GetPVarInt( playerid, "editattachcar");
				
