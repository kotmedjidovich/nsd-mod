CMD:sellcar(playerid, params[])
{
    if(sscanf(params, "dd", params[0], params[1])) return SCM(playerid, COLOR_WHITE, "�����������: /sellcar [�� ������, �������� �������] [����]");
	if(!IsPlayerConnected(params[0])) return SCM(playerid,-1,"������ � ����� ID ��� �� �������");
	if(params[1]>9999999 || params[1]<1) return SCM(playerid,-1,"������");
	new Float:p1,Float:p2,Float:p3; GetPlayerPos(params[0],p1,p2,p3);
	if(!IsPlayerInRangeOfPoint(playerid, 10.0,p1,p2,p3)) return SCM(playerid,-1,"�� ������ ���������� ����� ������, �������� ������ ������� ����������");
	
	new cars, bool:st=false, i;
	
    for(new z; z != LoadAllCar; z++)
	{
		if(!strcmp(cInfo[z][cOwner],pInfo[params[0]][pName],true)) cars++;
