public OnPlayerEnterRaceCheckpoint(playerid)
{
    // ���������
    if(GetPlayerVehicleID(playerid) >= acar_b[0] && GetPlayerVehicleID(playerid) <= acar_b[3] || GetPlayerVehicleID(playerid) >= acar_a[0] && GetPlayerVehicleID(playerid) <= acar_a[1] || GetPlayerVehicleID(playerid) >= acar_c[0] && GetPlayerVehicleID(playerid) <= acar_c[2] || GetPlayerVehicleID(playerid) >= acar_d[0] && GetPlayerVehicleID(playerid) <= acar_d[2])
    {
		new Float:x,Float:y,Float:z; GetVehicleVelocity(GetPlayerVehicleID(playerid),x,y,z);
	    if(floatround(floatsqroot(((x*x)+(y*y))+(z*z))*101.666667)>65) SendClientMessage(playerid,-1,"[����������]: " #C_GRAY "�� ��������� ���������� �������� (60 ��/�). ������ ������������!"), SetPVarInt(playerid,"oshibka",GetPVarInt(playerid,"oshibka")+1);

		if(GetPVarInt(playerid,"LESSON") == 1) return SetPlayerRaceCheckpoint(playerid,0,B_CHECK2,B_CHECK3,3.5),SetPVarInt(playerid, "LESSON", 2);
	    if(GetPVarInt(playerid,"LESSON") == 2) return SetPlayerRaceCheckpoint(playerid,0,B_CHECK3,B_CHECK4,3.5),SetPVarInt(playerid, "LESSON", 3);
	    if(GetPVarInt(playerid,"LESSON") == 3) return SetPlayerRaceCheckpoint(playerid,0,B_CHECK4,B_CHECK5,3.5),SetPVarInt(playerid, "LESSON", 4);
	    if(GetPVarInt(playerid,"LESSON") == 4) return SetPlayerRaceCheckpoint(playerid,0,B_CHECK5,B_CHECK6,3.5),SetPVarInt(playerid, "LESSON", 5);
	    if(GetPVarInt(playerid,"LESSON") == 5) return SetPlayerRaceCheckpoint(playerid,0,B_CHECK6,B_CHECK7,3.5),SetPVarInt(playerid, "LESSON", 6);
	    if(GetPVarInt(playerid,"LESSON") == 6) return SetPlayerRaceCheckpoint(playerid,0,B_CHECK7,B_CHECK8,3.5),SetPVarInt(playerid, "LESSON", 7);
	    if(GetPVarInt(playerid,"LESSON") == 7) return SetPlayerRaceCheckpoint(playerid,0,B_CHECK8,B_CHECK9,3.5),SetPVarInt(playerid, "LESSON", 8);
	    if(GetPVarInt(playerid,"LESSON") == 8) return SetPlayerRaceCheckpoint(playerid,0,B_CHECK9,B_CHECK10,3.5),SetPVarInt(playerid, "LESSON", 9);
	    if(GetPVarInt(playerid,"LESSON") == 9) return SetPlayerRaceCheckpoint(playerid,0,B_CHECK10,B_CHECK11,3.5),SetPVarInt(playerid, "LESSON", 10);
	    if(GetPVarInt(playerid,"LESSON") == 10) return SetPlayerRaceCheckpoint(playerid,0,B_CHECK11,B_CHECK12,3.5),SetPVarInt(playerid, "LESSON", 11);
	    if(GetPVarInt(playerid,"LESSON") == 11) return SetPlayerRaceCheckpoint(playerid,0,B_CHECK12,B_CHECK13,3.5),SetPVarInt(playerid, "LESSON", 12);
	    if(GetPVarInt(playerid,"LESSON") == 12) return SetPlayerRaceCheckpoint(playerid,0,B_CHECK13,B_CHECK14,3.5),SetPVarInt(playerid, "LESSON", 13);
	    if(GetPVarInt(playerid,"LESSON") == 13) return SetPlayerRaceCheckpoint(playerid,0,B_CHECK14,B_CHECK15,3.5),SetPVarInt(playerid, "LESSON", 14);
	    if(GetPVarInt(playerid,"LESSON") == 14) return SetPlayerRaceCheckpoint(playerid,0,B_CHECK15,B_CHECK16,3.5),SetPVarInt(playerid, "LESSON", 15);
	    if(GetPVarInt(playerid,"LESSON") == 15) return SetPlayerRaceCheckpoint(playerid,0,B_CHECK16,B_CHECK17,3.5),SetPVarInt(playerid, "LESSON", 16);
	    if(GetPVarInt(playerid,"LESSON") == 16) return SetPlayerRaceCheckpoint(playerid,0,B_CHECK17,B_CHECK18,3.5),SetPVarInt(playerid, "LESSON", 17);
	    if(GetPVarInt(playerid,"LESSON") == 17) return SetPlayerRaceCheckpoint(playerid,0,B_CHECK18,B_CHECK19,3.5),SetPVarInt(playerid, "LESSON", 18);
	    if(GetPVarInt(playerid,"LESSON") == 18) return SetPlayerRaceCheckpoint(playerid,0,B_CHECK19,B_CHECK20,3.5),SetPVarInt(playerid, "LESSON", 19);
	    if(GetPVarInt(playerid,"LESSON") == 19) return SetPlayerRaceCheckpoint(playerid,0,B_CHECK20,B_CHECK21,3.5),SetPVarInt(playerid, "LESSON", 20);
	    if(GetPVarInt(playerid,"LESSON") == 20)
	    {
		    new Float:heal;
		    GetVehicleHealth(GetPlayerVehicleID(playerid),heal);
		    if(heal < 900.0 || GetPVarInt(playerid,"remen") == 0 && PlayerInCAR(playerid))
			{
				SendClientMessage(playerid,-1,"{FFFFFF}[����������]" #C_GRAY "�� �� ����� ������������ �������!");
				DeletePVar(playerid,"LESSON"); DeletePVar(playerid,"ekzamen"); DeletePVar(playerid,"practicexam");
			}
			else
			{
			    SendClientMessage(playerid,-1,"" #C_GRAY "�� ������� ����� ������������ �������!");
			    SendClientMessage(playerid,-1,"{FFFF00}�������� � ������ ��������� ��� ��������� ������� �� ��������� �����");
				SetPVarInt(playerid,"practicexam",2); DeletePVar(playerid,"LESSON"); SetPVarInt(playerid,"ekzamen",2);
				cmd::ame(playerid,"��������� ������ ������������"), SetPVarInt(playerid,"remen",0);
			}
		    if(IsTrailerAttachedToVehicle(GetPlayerVehicleID(playerid))) { SetVehicleToRespawn(GetVehicleTrailer(GetPlayerVehicleID(playerid))); DetachTrailerFromVehicle(GetPlayerVehicleID(playerid)); }
		    RemovePlayerFromVehicle(playerid);
			SetVehicleToRespawn(GetPlayerVehicleID(playerid));
			DisablePlayerRaceCheckpoint(playerid);
			return 1;
		}
	}
	else SCM(playerid,-1,"�� ������ ���������� �� ����� �������� ����������");
