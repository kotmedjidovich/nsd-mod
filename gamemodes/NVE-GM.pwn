	return 1;
}

CMD:anima(playerid, params[])
{
	if(IsAdmin(playerid, 5)) return 1;
	ClearAnimations(playerid);
	if(sscanf(params, "d", params[0])) return SCM(playerid, COLOR_WHITE, "�����������: /anima [index ��������]");
	if(params[0] < 0 || params[0] > 10000) return SCM(playerid, -1,"������");
 	new animlib[64];
  	new animname[64];
	GetAnimationName(params[0],animlib,64,animname,64);
	SendMes(playerid,-1,"������: %d | %s - %s",params[0], animlib, animname);
	ApplyAnimation(playerid, animlib, animname, 4.1, 1, 1, 1, 1, 1, 1);
	return 1;
}

