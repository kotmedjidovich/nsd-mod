		SPD(p[0],d_null,info,string,str_small,"�������","");
		
		mysql_format:str_small("INSERT INTO `tickets` (`Name`,`Sum`,`Reason`,`Date`,`Writer`) VALUES ('%s','%d','%s','%d.%d.%d','%s')",pInfo[p[0]][pName],p[1],p[2],day,m,g,pInfo[playerid][pName]);
		mysql_function_query(mysql_connect_ID, str_small, false, "", "");
		
		SCM(p[0],-1,"" #C_GRAY "��� �������� �����. ����� ���������� ��� ���� ������, ������� /mytickets");
		SendMes(playerid,-1,"" #C_GRAY "�� �������� ����� %s �� ����� %d �. �������: %s | ����: %d.%d.%d",pInfo[p[0]][pName],p[1],p[2],day,m,g);
	}
	return 1;
}

