CMD:delnomer(playerid, params[])
{
    if(sscanf(params, "d", params[0])) return SCM(playerid, COLOR_WHITE, "�����������: /delnomer [id ����]");
    new vehicleid = GetPlayerVehicleID(params[0]);
	if(IsValidDynamicObject(nomer_zad[vehicleid]) && IsValidDynamicObject(nomer_pered[vehicleid]))
		{
		 	DestroyDynamicObjected(nomer_zad[vehicleid]);
		 	DestroyDynamicObjected(nomer_pered[vehicleid]);
	 	}
	return 1;
}

CMD:fixcar(playerid, params[])
{
	if(IsAdmin(playerid, 4)) return 1;
    if(GetPlayerVehicleSeat(playerid) != 0) return SCM(playerid,COLOR_WHITE,"�� ������ ���� �� ���� ������������� ��������!");

	pformat:( "�� �������� ��������� "C_GRAY"[id:%d]",GetPlayerVehicleID(playerid));
	psend:( playerid, COLOR_WHITE );
	SetVehicleHealth(GetPlayerVehicleID(playerid), 1000), RepairVehicle(GetPlayerVehicleID(playerid));
  	for( new i; i != LoadAllCar; i++ )
	{
	    if(GetPlayerVehicleID(playerid) == cInfo[i][cCar])
	    {
		 	mysql_format:str_cmd("UPDATE `" #DB_CARS "` SET `engine` = '0' WHERE `ID` = '%d'",cInfo[i][cID]);
    		mysql_function_query(mysql_connect_ID, str_cmd, false, "", "");
		 	mysql_format:str_cmd("UPDATE `" #DB_CARS "` SET `health` = '1000' WHERE `ID` = '%d'",cInfo[i][cID]);
    		mysql_function_query(mysql_connect_ID, str_cmd, false, "", "");
		 	mysql_format:str_cmd("UPDATE `" #DB_CARS "` SET `damage` = '0|0|0|0' WHERE `ID` = '%d'", cInfo[i][cID]);
    		mysql_function_query(mysql_connect_ID, str_cmd, false, "", "");
    		cInfo[i][cHealth] = 1000;
    		cInfo[i][cEngine] = 0;
    		strmid(cInfo[i][cEngine], str_least, 0, strlen(str_least), 11);
			GetVehicleDamageStatus(cInfo[i][cCar], cInfo[i][cDamage][0], cInfo[i][cDamage][1], cInfo[i][cDamage][2], cInfo[i][cDamage][3]);
			break;
	    }
	}
	
	return 1;
}

CMD:setmusic(playerid, params[])
{
    if(IsAdmin(playerid, 4)) return 1;
    if(sscanf(params, "s[150]", params[0])) return SCM(playerid, COLOR_WHITE, "�����������: /setmusc [������ ������� .mp3 .m3u � �.�.]");
	f(music),"%s",params[0]);
	return 1;
}

CMD:setmusicpos(playerid, params[])
{
    if(IsAdmin(playerid, 4)) return 1;
    GetPlayerPos(playerid,XM,YM,ZM);
	return 1;
}

CMD:onj(playerid)//tamasita*
{
	if(IsAdmin(playerid, 1)) return 1;
	foreach(Player,i)
	{
	    if(IsPlayerConnected(i) && pInfo[i][pArrest] > 1)
	    {
            format:str_small("����� %s �������� ���������: %d ���",pInfo[i][pName],pInfo[i][pArrest]);
            SCM(playerid,-1,str_small);
	    }
	}
	return 1;
}

CMD:slap(playerid,params[])//tamasita*
{
    if(IsAdmin(playerid, 1)) return 1;
    if(sscanf(params, "u", params[0])) return SCM(playerid, COLOR_WHITE, "�����������: /slap [id]");

    new Float:Zx,Float:Zy,Float:Zz;
    GetPlayerPos(params[0],Zx,Zy,Zz);
    SetPlayerPos(params[0],Zx,Zy,Zz+4);
    
    format:str_small("������������� %s �������� ������ %s",pInfo[playerid][pName],pInfo[params[0]][pName]);
    SAM(-1,str_small);
    
	return 1;
}

CMD:univs(playerid, params[])
{
	if(IsAdmin(playerid, 1)) return 1;
    if(sscanf(params, "d", params[0])) return SCM(playerid, COLOR_WHITE, "�����������: /univs [ID ������]");
    pInfo[params[0]][pArrest]=0; SetPlayerPosF(params[0],1748.3696,1740.3652,2.1554,90.0000);
    mysql_format:str_small("UPDATE `" #DB_ACCOUNTS "` SET `Arrest` = '0' WHERE `Name` = '%s'",pInfo[params[0]][pName]); mysql_function_query(mysql_connect_ID, str_small, false, "", "");
	return 1;
}

CMD:alog(playerid, params[])
{
    if(pInfo[playerid][pAdmin] < 1 ) return SCM( playerid, COLOR_DARK_GRAY, !NOT_PERMITTED );
    if(sscanf(params, "i", params[0])) return SCM(playerid, COLOR_WHITE, "�����������: /alog [���]");
    if(params[0] != ABILITY_ADMIN_PASSWORD )
    {
        SCM(playerid, COLOR_DARK_GRAY, "�� ����� �������� ������ �� ������ �����������������");
        format:str_cmd("[A] %s[%d] ��� �������� ������ �� ������ �����������������",
            pInfo[playerid][pName],
            playerid,
            pInfo[playerid][pAdmin]
        );
        SAM( COLOR_LIGHT_RED, str_cmd);
        return Kick(playerid);
    }
    if(GetPVarInt(playerid,"alogin")==0)
    {
        format:str_cmd("{658c6a}[A] %s [ID:%d] ��������������� ��� ������������� %d ������",
	        pInfo[playerid][pName],
	        playerid,
	        pInfo[playerid][pAdmin]
        );
        SAM( COLOR_LIGHT_GREEN, str_cmd);
        SCM( playerid, COLOR_LIGHT_GREEN, "{658c6a} - ������ ��� �������� ������� /admin");
        SetPVarInt(playerid, "alogin", 1);
        GetPlayerName(playerid, pInfo[playerid][pName], MAX_PLAYER_NAME);
        if(strcmp(pInfo[playerid][pName], "Aleksandr_Kanaev", true) == 0)
        {
		 	mysql_format:str_cmd("UPDATE `" #DB_ACCOUNTS "` SET `Name` = 'Kanaev' WHERE `ID` = '%d'",pInfo[playerid][pID]);
    		mysql_function_query(mysql_connect_ID, str_cmd, false, "", "");
			SetPlayerName(playerid, "Kanaev"), GetPlayerName(playerid, pInfo[playerid][pName], MAX_PLAYER_NAME);
		}
        if(strcmp(pInfo[playerid][pName], "Said_Aliguseev", true) == 0)
        {
		 	mysql_format:str_cmd("UPDATE `" #DB_ACCOUNTS "` SET `Name` = 'Alishka' WHERE `ID` = '%d'",pInfo[playerid][pID]);
    		mysql_function_query(mysql_connect_ID, str_cmd, false, "", "");
			SetPlayerName(playerid, "Alishka"), GetPlayerName(playerid, pInfo[playerid][pName], MAX_PLAYER_NAME);
		}
        if(strcmp(pInfo[playerid][pName], "Boeslav_Majorov", true) == 0)
        {
		 	mysql_format:str_cmd("UPDATE `" #DB_ACCOUNTS "` SET `Name` = '4elik' WHERE `ID` = '%d'",pInfo[playerid][pID]);
    		mysql_function_query(mysql_connect_ID, str_cmd, false, "", "");
			SetPlayerName(playerid, "4elik"), GetPlayerName(playerid, pInfo[playerid][pName], MAX_PLAYER_NAME);
		}
	}
    else
    {
        format:str_cmd("{658c6a}[A] %s [ID:%d] �������� ���������",
	        pInfo[playerid][pName],
	        playerid
        );
        SAM( COLOR_LIGHT_GREEN, str_cmd);
        SetPVarInt(playerid, "alogin", 0);
        GetPlayerName(playerid, pInfo[playerid][pName], MAX_PLAYER_NAME);
        if(strcmp(pInfo[playerid][pName], "Kanaev", true) == 0)
        {
		 	mysql_format:str_cmd("UPDATE `" #DB_ACCOUNTS "` SET `Name` = 'Aleksandr_Kanaev' WHERE `ID` = '%d'",pInfo[playerid][pID]);
    		mysql_function_query(mysql_connect_ID, str_cmd, false, "", "");
			SetPlayerName(playerid, "Aleksandr_Kanaev"), GetPlayerName(playerid, pInfo[playerid][pName], MAX_PLAYER_NAME);
		}
        if(strcmp(pInfo[playerid][pName], "Alishka", true) == 0)
        {
		 	mysql_format:str_cmd("UPDATE `" #DB_ACCOUNTS "` SET `Name` = 'Said_Aliguseev' WHERE `ID` = '%d'",pInfo[playerid][pID]);
    		mysql_function_query(mysql_connect_ID, str_cmd, false, "", "");
			SetPlayerName(playerid, "Said_Aliguseev"), GetPlayerName(playerid, pInfo[playerid][pName], MAX_PLAYER_NAME);
		}
        if(strcmp(pInfo[playerid][pName], "4elik", true) == 0)
        {
		 	mysql_format:str_cmd("UPDATE `" #DB_ACCOUNTS "` SET `Name` = 'Boeslav_Majorov' WHERE `ID` = '%d'",pInfo[playerid][pID]);
    		mysql_function_query(mysql_connect_ID, str_cmd, false, "", "");
			SetPlayerName(playerid, "Boeslav_Majorov"), GetPlayerName(playerid, pInfo[playerid][pName], MAX_PLAYER_NAME);
		}
	}
	return 1;
}

