CMD:uninvite(playerid, params[])
{
	if(pInfo[playerid][pFrak]>0)
	{
		if(pInfo[playerid][pRang] != 5) return SCM(playerid,-1,"�� �� ��������� �������");
		if(sscanf(params, "d", params[0])) return SCM(playerid, COLOR_WHITE, "�����������: /uninvite [�� ������]");
		if(pInfo[params[0]][pOrg][0]!=pInfo[playerid][pOrg][0]) return SCM(playerid, COLOR_WHITE, "����� ������� � ������ �����������");
		if(pInfo[params[0]][pFrak]!=pInfo[playerid][pFrak]) return SCM(playerid, COLOR_WHITE, "����� ������� � ������ �������");
		if(GetPVarInt(params[0],"gLogged")!=1) return SCM(playerid, COLOR_WHITE, "����� � ����� �� ���");
	    if(params[0]==playerid) return SCM(playerid, COLOR_WHITE, "�� �� ������ ������� ���� ����");
		
		pformat:( "{FFEF00}����� ������� %s ������ ���",pInfo[playerid][pName]);
		psend:( params[0], COLOR_WHITE );
		
		pformat:( "{FFEF00}�� ������� ���������� %s",pInfo[params[0]][pName]);
		psend:( playerid, COLOR_WHITE );
		
	    if(GetPVarInt(params[0],"duty")==1)
		{
			SetPlayerSkin(params[0],pInfo[params[0]][pChart][1]);
		}
		
		strmid(pInfo[params[0]][pDol], "0", 0, strlen("0"), 35);
		strmid(pInfo[params[0]][pDols], "0", 0, strlen("0"), 35);
		pInfo[params[0]][pFrak]=0;
		pInfo[params[0]][pRang]=0;
		
		mysql_format:str_small("UPDATE `" #DB_ACCOUNTS "` SET `Frak` = '0|0', `Dol` = 'none', `Dols` = 'none' WHERE `ID` = '%d'",pInfo[params[0]][pID]);
		mysql_function_query(mysql_connect_ID, str_small, false, "", "");
		
		ResetPlayerWeapons( params[0] );
		DeletePVar( params[0], "duty" );
        SaveWeapon( params[0] );
		
		return 1;
	}
	
	if(pInfo[playerid][pOrg][0]>0)
	{
	    if(strcmp(oInfo[ pInfo[playerid][pOrg][0] ][oLeader],pInfo[playerid][pName],true)) return SCM(playerid,-1,"�� �� ��������� �������!");
	    if(sscanf(params, "d", params[0])) return SCM(playerid, COLOR_WHITE, "�����������: /uninvite [�� ������]");
		if(params[0]==playerid) return SCM(playerid, COLOR_WHITE, "�� �� ������ ������� ������ ����");
		if(pInfo[params[0]][pOrg][0]!=pInfo[playerid][pOrg][0]) return SCM(playerid, COLOR_WHITE, "����� ������� � ������ �����������");
		if(pInfo[params[0]][pFrak]!=0) return SCM(playerid, COLOR_WHITE, "����� ������� � ������ �������");
		if(GetPVarInt(params[0],"gLogged")!=1) return SCM(playerid, COLOR_WHITE, "����� �� ������!");

		pformat:( "" #C_GRAY "�� ������� �� ����������� ������ {ffffff}%s",pInfo[params[0]][pName]);
		psend:( playerid, COLOR_WHITE );
		
		pformat:( "" #C_GRAY "����� {ffffff}%s " #C_GRAY "������ ��� �� ����������� {ffffff}%s !",pInfo[playerid][pName], oInfo[pInfo[playerid][pOrg][0]][oName]);
		psend:( params[0], COLOR_WHITE );
		
		pInfo[params[0]][pOrg][0]=-1;
		pInfo[params[0]][pOrg][1]=0;
		
		mysql_format:str_small("UPDATE `" #DB_ACCOUNTS "` SET `Org` = '0', `Orang` = '0' WHERE `ID` = '%d'",pInfo[params[0]][pID]);
		mysql_function_query(mysql_connect_ID, str_small, false, "", "");
		
		return 1;
	}
	
	return 1;
}

CMD:setdol(playerid, params[])
{
	if(pInfo[playerid][pFrak]>0)
	{
		if(pInfo[playerid][pRang] != 5) return SCM(playerid,-1,"�� �� ��������� �������");
		new text[35];
		if(sscanf(params, "ds[35]", params[0], text)) return SCM(playerid, COLOR_WHITE, "�����������: /setdol [�� ������] [���������]");
		if(pInfo[params[0]][pFrak] != pInfo[playerid][pFrak]) return SCM(playerid, COLOR_WHITE, "����� ������� � ������ �������");
		if(GetPVarInt(params[0],"gLogged")!=1) return SCM(playerid, COLOR_WHITE, "����� � ����� �� ���");
		if(strlen(text)>35||strlen(text)<1) return SCM(playerid, COLOR_WHITE, "�������� ��������� ������ �������� �� 35 ��������");

		for(new z = strlen(text)-1; z != -1; z--)
  		{
	    	switch(text[z])
	     	{
		     	case '0'..'9', 'a'..'z', 'A'..'Z', '�'..'�', '�'..'�', ' ', '-': continue;
		     	default: return SCM(playerid,-1,"����������� ������ ����� � �����!");
	  		}
  		}
		
		mysql_format:str_small("UPDATE `" #DB_ACCOUNTS "` SET `Dol` = '%s' WHERE `ID` = '%d'",text,pInfo[params[0]][pID]); mysql_function_query(mysql_connect_ID, str_small, false, "", "");
		SendMes(params[0],-1,"{FFEF00}����� ������� %s ������� ���� ������ �� %s",pInfo[playerid][pName],text);
		SendMes(playerid,-1,"{FFEF00}�� �������� ������ %s �� %s",pInfo[params[0]][pName],text);
		strmid(pInfo[params[0]][pDol], text, 0, strlen(text), 35);
	}
	
	if(pInfo[playerid][pOrg][1] == 10)
	{
		new text[35];
		if(sscanf(params, "ds[35]", params[0], text)) return SCM(playerid, COLOR_WHITE, "�����������: /setdol [�� ������] [���������]");
		if(pInfo[params[0]][pOrg][0] != pInfo[playerid][pOrg][0]) return SCM(playerid, COLOR_WHITE, "����� ������� � ������ �����������");
		if(pInfo[params[0]][pFrak] != pInfo[playerid][pFrak]) return SCM(playerid, COLOR_WHITE, "����� ������� � ������ �������");
		if(GetPVarInt(params[0],"gLogged")!=1) return SCM(playerid, COLOR_WHITE, "����� � ����� �� ���");
		if(strlen(text)>35||strlen(text)<1) return SCM(playerid, COLOR_WHITE, "�������� ��������� ������ �������� �� 35 ��������");

		for(new z = strlen(text)-1; z != -1; z--)
  		{
	    	switch(text[z])
	     	{
		     	case '0'..'9', 'a'..'z', 'A'..'Z', '�'..'�', '�'..'�', ' ', '-': continue;
		     	default: return SCM(playerid,-1,"����������� ������ ����� � �����!");
	  		}
  		}

		mysql_format:str_small("UPDATE `" #DB_ACCOUNTS "` SET `Dol` = '%s' WHERE `ID` = '%d'",text,pInfo[params[0]][pID]); mysql_function_query(mysql_connect_ID, str_small, false, "", "");
		SendMes(params[0],-1,"{FFEF00}����� ������� %s ������� ���� ������ �� %s",pInfo[playerid][pName],text);
		SendMes(playerid,-1,"{FFEF00}�� �������� ������ %s �� %s",pInfo[params[0]][pName],text);
		strmid(pInfo[params[0]][pDol], text, 0, strlen(text), 35);
	}
	return 1;
}

