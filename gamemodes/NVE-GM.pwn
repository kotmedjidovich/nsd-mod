	}

	if(pInfo[playerid][pOrg][0] <= 0) // ����������� ���
	{
		f(org),"���"), f(rang),"���");
	}
	else // ����������� ����
	{
		f(org),"%s",oInfo[pInfo[playerid][pOrg][0]][oName]);
		f(rang),"%s[%d]",pInfo[playerid][pDol],pInfo[playerid][pOrg][1]);
		f(rang),"%s[%d]",pInfo[playerid][pDols],pInfo[playerid][pOrg][1]);
