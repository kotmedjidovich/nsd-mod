        else SPD(playerid,d_null,list,"" #C_GRAY "��������� �����������",str_big,"�������","");
        str_big[0] = EOS;
    }
    return true;
}

public: OnLeaderFrak(playerid)
{
    new rows, fields;
    cache_get_data(rows, fields);
    if(rows)
    {
        new Names[MAX_PLAYER_NAME],full,ttext[40];
        while(--rows >= 0)
        {
            cache_get_field_content(rows,"Name",Names); new frak[2], rang[40];
		    cache_get_field_content(rows, "Frak",frak, mysql_connect_ID,35);
			sscanf(frak, "p<|>dd",frak[0],frak[1]);
			if(frak[0]!=pInfo[playerid][pFrak]) continue;
			cache_get_field_content(rows, "Dol", rang, mysql_connect_ID, 35);
			if(GetPlayerID(Names) == -1) ttext = "{E40C0C}�������{FFFFFF}";
			else ttext = "{2CE40C}������{FFFFFF}";
            format:str_small("{ffffff}[%s]\t" #C_GRAY "%s{ffffff} - %s[%d]\n", ttext, Names, rang, frak[1]);
			strcat(str_big,str_small);
			full++;
        }
		f(ttext),"" #C_GRAY "���������� ������� " #C_WHITE "%s " #C_GRAY "| �����: " #C_WHITE "%d",GetFrakName(pInfo[playerid][pFrak],0),full);
        SPD(playerid,d_null,info,ttext,str_big,"�������","");
        str_big[0]=EOS;
        str_small[0]=EOS;
        return 1;
    }
    else
    {
    	SCM(playerid,-1,"�� ������� ����������!");
    	return 1;
    }
}

