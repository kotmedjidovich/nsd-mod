public: brats1(playerid)
{
    if(GetPVarInt(playerid,"jobs")!=1) return 1;
	RemovePlayerAttachedObject(playerid,9);
	TogglePlayerControllable(playerid,1);
	ApplyAnimation(playerid,"PED","IDLE_tired",4.1,0,1,1,0,1);
	DisablePlayerCheckpoint(playerid), SetPVarInt(playerid,"check12",1), SetPlayerCheckpoint(playerid,106.8003,1682.6926,6.1441,1.5), RemovePlayerAttachedObject(playerid, 9), ClearAnimations(playerid), ApplyAnimation(playerid,"PED","IDLE_tired",4.1,0,1,1,0,1), SetPVarInt(playerid,"perenos1",GetPVarInt(playerid,"perenos1")+1);
    new neset = random(5); new zarplata[9], perenos1[9]; if(neset == 0) SetPVarInt(playerid,"zarplata",GetPVarInt(playerid,"zarplata")+125); if(neset == 1) SetPVarInt(playerid,"zarplata",GetPVarInt(playerid,"zarplata")+109); if(neset == 2) SetPVarInt(playerid,"zarplata",GetPVarInt(playerid,"zarplata")+61); if(neset == 3) SetPVarInt(playerid,"zarplata",GetPVarInt(playerid,"zarplata")+150); if(neset == 4) SetPVarInt(playerid,"zarplata",GetPVarInt(playerid,"zarplata")+97);
	f(zarplata),"%d",GetPVarInt(playerid,"zarplata"));
	f(perenos1),"%d",GetPVarInt(playerid,"perenos1"));
	PlayerTextDrawSetString(playerid,pstr1[playerid],zarplata);
	PlayerTextDrawSetString(playerid,pstr2[playerid],perenos1);
	return 1;
}

