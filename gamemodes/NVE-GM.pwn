    if(pInfo[playerid][pFrak]==0) return SCM(playerid,-1,"�� �� �������� �� � ����� �� �������!");
    if(pInfo[playerid][pFrak]==3)
	{
		if(sscanf(params, "ddd", params[0],params[1],params[2])) return SCM(playerid, COLOR_WHITE, "�����������: /ridcar [�� ������] [VIN ����� |-��� �����] [����]");
		if(GetPVarInt(params[0],"gLogged")!=1) return SCM(playerid,-1,"����� � ������ ID �� ������!");
		new Float:x, Float:y, Float:z;
		GetPlayerPos(playerid,x,y,z);
		if(!IsPlayerInRangeOfPoint(params[0], 10.0,x,y,z)) return SCM(playerid,-1,"��������� ���� �����, ������ ���������� ����� ���!");
		if(params[2]<5000 || params[2]>50000) return SCM(playerid,-1,"���� �� ������ ������ ���������� �� ������ ���� ������ " #C_GRAY "5.000 {ffffff}� �� ������ " #C_GRAY "50.000!");
		
		new bool:found = false;
		
		for( new i; i != LoadAllCar; i++ )
		{
			if(cInfo[i][cID]==params[1])
			{
			    found = true;
			    if(cInfo[i][cArrest]!=1) return SCM(playerid,-1,"��������� ��������� �� ���������� �� �/�!");
			    if(strcmp(cInfo[i][cOwner],pInfo[params[0]][pName],true)) return SCM(playerid,-1,"������ ����� �� �������� ����������, ���������� �� " #C_GRAY "VIN{ffffff} ������, ����������!");
			    if(pInfo[params[0]][pMoney]<params[2]) return SCM(playerid,-1,"� ������ ��� ��������� �����!"), SCM(params[0],-1,"� ��� �� ������� ����� ��� ������ ������ ������ ����������!");
				format:str_cmd("{ffffff}��������� ����� " #C_GRAY "%s {ffffff}���������� ��� �������� ����� � ������� " #C_GRAY "%d {ffffff}������ �� ��������� " #C_GRAY "%s{ffffff}\n         �� �������� �� ������ ��������� �����?",pInfo[playerid][pName],params[2],GetCarMark(cInfo[i][cModel]));
				SPD(params[0],dFrak+14,info,"" #C_GRAY "������ �� �/�",str_cmd,"��","���");
				
				pformat:( "�� ���������� ������ "C_GRAY"%s"C_WHITE" ������� ���� ��������� "C_GRAY"%s"C_WHITE" �� "C_GRAY"%d"C_WHITE" ������",pInfo[params[0]][pName], GetCarMark(cInfo[i][cModel]), params[2]);
				psend:( playerid, COLOR_WHITE );
				
				SetPVarInt(params[0],"ridcarcop",playerid);
				SetPVarInt(params[0],"ridcarid",i);
				SetPVarInt(params[0],"ridcarprice",params[2]);
				break;
			}
		}
		
		if(found==false) return SCM(playerid,-1,"���������� � ��������� VIN ������� - �� ������!");
	}
	return 1;
}

CMD:search(playerid, params[])
{
	if(pInfo[playerid][pFrak]==0) return SCM(playerid,-1,"�� �� �������� �� � ����� �� �������!");
    if(pInfo[playerid][pFrak]==3 || pInfo[playerid][pFrak]==1 || pInfo[playerid][pFrak]==2)
	{
		if(IsPlayerInRangeOfPoint(playerid, 5.0, 1735.4647,1742.0859,2.1554) && IsPlayerInRangeOfPoint(playerid, 5.0, 2335.8350,-2415.1926,22.0613))
		{
		    SPD(playerid,dFrak+15,list,""C_GRAY"���� ������ ���",search_text,"��","�������");
			return 1;
		}
		
		if(IsPlayerInRangeOfPoint(playerid, 20.0,395.7168,-334.5025,1094.4600))
		{
		    SPD(playerid,dFrak+15,list,""C_GRAY"���� ������ ���",search_text,"��","�������");
			return 1;
		}
		
	    if(!IsPlayerInAnyVehicle(playerid)) return SCM(playerid,-1,"�� ������ ���������� � ���������� ��� ��� �������� �����!");
		new car = GetPlayerVehicleID(playerid);
	    if(car < ymvd[0] && car > ymvd[20]) return SCM(playerid,-1,"�� ������ ���������� � ���������� ���!");
	    if(car < omon[0] && car > omon[18]) return SCM(playerid,-1,"�� ������ ���������� � ���������� ���!");
	    if(car < gibdd[0] && car > gibdd[25]) return SCM(playerid,-1,"�� ������ ���������� � ���������� ���!");
		SPD(playerid,dFrak+15,list,""C_GRAY"���� ������ ���",search_text,"��","�������");
	}
	return 1;
}

CMD:time(playerid)
{
    if(GetPVarInt(playerid,"death") == 1 || GetPVarInt(playerid,"death") == 2) return 1;
    
    new bool:found = false;
    
    for( new i; i != 10; i++ )
	{
		if(_invPlayer[playerid][invSlot][i] == 1 || _invPlayer[playerid][invSlot][i] == 3) found = true;
	}
	
	if(found == true)
	{
		new h,m;
		new d,mo,y;
		getdate(y,mo,d);
		gettime(h,m,_);
		format:str_least("~Y~MCK - ~W~%d:%d~n~%d.%d.%d",h,m,d,mo,y);
		DeletePVar(playerid,"selectSlot");
		SetPlayerChatBubble(playerid,"���������(�) ����� �� ����� �����",0xAF5DD2FF,20.0,7000);
		if(!IsPlayerInAnyVehicle(playerid)) ApplyAnimation(playerid,"COP_AMBIENT","Coplook_watch",4.1,0,0,0,0,0);
		GameTextForPlayer(playerid, str_least, 5000, 1);
	}
	else SCM(playerid,-1,"� ��� ��� �������� �����. ���� ����� ������ � ����� ��������!");
	
	if(GetPVarInt(playerid,"mute")!=0) SendMes(playerid,0x4C9DBFFF,"(( � ��� ���������� OOC ���� ��" #C_ORANGE " %d ������ {4C9DBF}))",GetPVarInt(playerid,"mute"));
	if(pInfo[playerid][pArrest]!=0) SendMes(playerid,0x4C9DBFFF,"(( �� ������ ������������ ��������: " #C_ORANGE "%d {4C9DBF}������ ))",pInfo[playerid][pArrest]);
	
	return 1;
}

CMD:phone(playerid)
{
    if(GetPVarInt(playerid,"death") == 1 || GetPVarInt(playerid,"death") == 2) return 1;
    
    if( pInfo[playerid][pArrest] != 0 ) return SCM(playerid, -1,"� ��� ������� ��� ����, � ������ ������  ����� ��������� ������ ����������");

    new bool:found = false;

    for( new i; i != 10; i++ )
	{
		if(_invPlayer[playerid][invSlot][i] > 3 && _invPlayer[playerid][invSlot][i] < 13)
		{
			found = true, SetPVarInt(playerid,"selectSlot", i);
			break;
		}
	}
	
	if(found == false) return SCM(playerid,-1,"� ����� ��������� ��� ��������!");

	if(pInfo[playerid][pNumber]==0) return SCM(playerid,-1,"� ��� ��� SIM-�����");
	new string2[30];
	if(GetPVarInt(playerid,"phone")==0) f(string2),"{8CE062}�������"); else f(string2),"{DF5151}��������");
	format:str_least("" #C_GRAY "������� %s {ffffff}| %s",_itemsInfo[_invPlayer[playerid][invSlot][GetPVarInt(playerid,"selectSlot")]][invName],string2);
	if(GetPVarInt(playerid,"phone")==0) return SPD(playerid,dPhone,list,str_least,"" #C_GRAY "1. {ffffff}���������� � ��������\n" #C_GRAY "2. {ffffff}������� �����\n" #C_GRAY "3. {ffffff}��������� SMS\n{DF5151}4. ��������� �������","��","�������");
 	if(GetPVarInt(playerid,"phone")!=0) return SPD(playerid,dPhone,list,str_least,"" #C_GRAY "1. {ffffff}���������� � ��������\n" #C_GRAY "2. {ffffff}������� �����\n" #C_GRAY "3. {ffffff}��������� SMS\n{8CE062}4. �������� �������","��","�������");
 	SetPlayerChatBubble(playerid,"������ �������",0xAF5DD2FF,20.0,7000);
	return 1;
}

CMD:sms(playerid, params[])
{
    if(GetPVarInt(playerid,"death") == 1 || GetPVarInt(playerid,"death") == 2) return 1;
    
    if( pInfo[playerid][pArrest] != 0 ) return SCM(playerid, -1,"� ��� ������� ��� ����, � ������ ������  ����� ��������� ������ ����������");

    if(sscanf(params, "ds[170]", params[0], params[1])) return SCM(playerid, COLOR_WHITE, "�����������: /sms [����� ��������] [����� ���������]");
    
    if(strlen(params[0]) != 6) return SCM(playerid,-1,"����� ������ �������� �� 6 ����");
    
    if(strlen(params[1]) <= 0 || strlen(params[1]) > 170) return SCM(playerid,-1,"����� ��������� �� 1 �� 170 ��������");

    new bool:found = false;

    for( new i; i != 10; i++ )
	{
		if(_invPlayer[playerid][invSlot][i] > 3 && _invPlayer[playerid][invSlot][i] < 13)
		{
			found = true;
			break;
		}
	}
	
	if(found == false) return SCM(playerid,-1,"� ����� ��������� ��� ��������!");
	
	found = false;
	
	foreach(Player, i)
	{
		if(pInfo[i][pNumber]!=params[0]) continue;
		if(pInfo[i][pNumber]==params[0])
		{
		    new price = floatround( strlen(params[1]) * 0.5, floatround_ceil);
		    found = true;

			if(pInfo[playerid][pPhonemoney] < price) return SCM(playerid,-1,"� ��� �� ������� ����� �� �����, ����� ��������� ��� SMS ���������");

			SendMes(i,-1,"{E7DF4B}SMS �� %d: %s",pInfo[playerid][pNumber], params[1]);
			SendMes(playerid,-1,"{E7DF4B}SMS ��� %d: %s " #C_GRAY "( - %d ������ )",pInfo[i][pNumber], params[1], price);

			pInfo[playerid][pPhonemoney] -= price;
			mysql_format:str_small("UPDATE `" #DB_ACCOUNTS "` SET `Phonemoney` = '%d' WHERE `ID` = '%d'",pInfo[playerid][pPhonemoney],pInfo[playerid][pID]);
			mysql_function_query(mysql_connect_ID, str_small, false, "", "");
			
		    break;
		}
	}

	if(found == false) return SCM(playerid,-1,"��������� ���� ����� - �� ������!");
	
	return 1;
}

CMD:call(playerid, params[])
{
    if(GetPVarInt(playerid,"death") == 1 || GetPVarInt(playerid,"death") == 2) return 1;
    
    if( pInfo[playerid][pArrest] != 0 ) return SCM(playerid, -1,"� ��� ������� ��� ����, � ������ ������  ����� ��������� ������ ����������");
    if(sscanf(params, "d", params[0])) return SCM(playerid, COLOR_WHITE, "�����������: /call [����� ��������]");
    if(params[0]==playerid) return SCM(playerid,-1,"�� �� ������ ��������� ������ ����!");
    new bool:found = false;

    for( new i; i != 10; i++ )
	{
		if(_invPlayer[playerid][invSlot][i] > 3 || _invPlayer[playerid][invSlot][i] < 13) found = true;
	}

	if(found == true)
	{
		if(GetPVarInt(playerid,"goodok")!=0 || GetPVarInt(playerid,"zvon1")!=0 || GetPVarInt(playerid,"zvon2")!=0) return SCM(playerid,-1,"�� ��� �������������� �� ������ �����");

		if(pInfo[playerid][pPhonemoney]<2) return SCM(playerid,-1,"�� ����� ������ �������� ������������ ������� ��� ���������� ������");

		if(params[0]==101)
		{
			return SPD(playerid,dPhone+3,input,"" #C_GRAY "���������� ������ | ���������","{ffffff}������� ��������� ��� ��� - 101","��","�������");
		}
		if(params[0]==102)
		{
			return SPD(playerid,dPhone+4,input,"" #C_GRAY "���������� ������ | ���������","{ffffff}������� ��������� ��� ������� - 102","��","�������");
		}
		if(params[0]==103)
		{
			return SPD(playerid,dPhone+5,input,"" #C_GRAY "���������� ������ | ���������","{ffffff}������� ��������� ��� ������ ������ - 103","��","�������");
		}

		if(params[0]==777)
		{
			if(GetPVarInt(playerid,"taxi")==1 && GetPVarInt(playerid,"taxitype")!=0) return SCM(playerid,-1,"���� �� ���������� �� ���������, �� �� ������ �������� �����");
			for(new id; id < MAX_VIZ; id ++)
			{
				if(viInfo[id][viPlayerid]==playerid && viInfo[id][viEnter]==1)
				{
					pformat:( "{FFD918}�� ��� �������� ���� ����� ����� {ffffff}(�%d)",id);
					psend:( playerid, COLOR_WHITE );
					return 1;
				}
			}
			return SPD(playerid,dPhone+2,input,"" #C_GRAY "����� �����","{FFFFFF}������� �����, ��� �� ����������:\n  - ����� �� 70 ��������","�������","�������");
		}

		if(params[0]==344)
		{
			return SPD(playerid,dPhone+6, input,"" #C_GRAY "���������� ������ | ���������","{ffffff}������� ��������� ��� ��� - 344","��","�������");
		}

		if(strlen(params[0])!=6) return SCM(playerid,-1,"����� �������� ������ ����� ������ �� 6 ����");

		if( c_info[playerid][cStatus] != 0 ) SCM(playerid,-1,"�� ��� ����� �������� ���-�� ������ ��� �� ��� �������������� �� ��������!");

		found = false;

		foreach(Player, i)
		{
			if(pInfo[i][pNumber]!=params[0]) continue;
			if(pInfo[i][pNumber]==params[0])
			{
				if( c_info[i][cStatus] != 0 )
				{
					PlayAudioStreamForPlayer(playerid, "http://exrptest.myarena.ru/Tele.mp3");
					pformat:( "{FFDE00}����� �������� %d - �����!",pInfo[i][pNumber]);
					psend:( playerid, COLOR_WHITE );
					found = true;
					break;
				}

				pformat:( "{FFDE00}�� ��� ��������� ������� ���� ����� �� �������� %d",pInfo[playerid][pNumber]);
				psend:( i, COLOR_WHITE );
				SCM(i,-1,"{FFDE00}����� ������� �����, ������� /p ��� ��������� /c");

				c_info[playerid][cCaller] = playerid;
				c_info[playerid][cAnswerer] = i;
				c_info[playerid][cStatus] = 1;

				c_info[i][cCaller] = playerid;
				c_info[i][cAnswerer] = i;
				c_info[i][cStatus] = 2;

				pformat:( "{FFDE00} �� ��������� �� ����� %d",pInfo[i][pNumber]);
				psend:( playerid, COLOR_WHITE );
