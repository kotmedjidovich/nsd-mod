	if(hide==1) { for(new i; i != 13; i ++) { TextDrawHideForPlayer(playerid,drawtaxi[i][playerid]); } }
	if(dopshow==1) { for(new i=10; i != 13; i ++) { TextDrawShowForPlayer(playerid,drawtaxi[i][playerid]); } }
	if(dophide==1) { for(new i=10; i != 13; i ++) { TextDrawHideForPlayer(playerid,drawtaxi[i][playerid]); } }
	return 1;
}

taxiupdate(playerid)
{
	if(GetPVarInt(playerid,"taxitype")==1) format:str_least("�O �PEMEH�");
	if(GetPVarInt(playerid,"taxitype")==2) format:str_least("�O PACC�O�H��");
	if(GetPVarInt(playerid,"taxitype")==3) format:str_least("C�O�O�H��");
	TextDrawSetString(drawtaxi[4][playerid],str_least);
	if(vizov<0) vizov=0;
	if(vizov==0) format:str_least("HE�"); else format:str_least("%d",vizov);
	TextDrawSetString(drawtaxi[2][playerid],str_least);

	if(GetPVarInt(playerid,"perevoz")==1)
	{
		if(GetPVarInt(playerid,"taxitype")==2 && SpeedVehicle(GetPlayerVehicleID(playerid))>1)
		{
			new Float:km = SpeedVehicle(GetPlayerVehicleID(playerid)) / 1500.0; SetPVarFloat(playerid,"s",GetPVarFloat(playerid,"s")+km); format:str_least("%.1f KM",GetPVarFloat(playerid,"s")); TextDrawSetString(drawtaxi[11][playerid],str_least); SetPVarInt(playerid,"plata",floatround(GetPVarFloat(playerid,"s")*100,floatround_round)), format:str_least("%dP",GetPVarInt(playerid,"plata")); TextDrawSetString(drawtaxi[12][playerid],str_least);
		}
		if(GetPVarInt(playerid,"taxitype")==1) { SetPVarInt(playerid,"s",GetPVarInt(playerid,"s")+1), SetPVarInt(playerid,"plata",GetPVarInt(playerid,"s")*5), format:str_least("%s",Convert(GetPVarInt(playerid,"s"))), TextDrawSetString(drawtaxi[11][playerid],str_least), format:str_least("%dP",GetPVarInt(playerid,"plata")), TextDrawSetString(drawtaxi[12][playerid],str_least); }
		if(GetPVarInt(playerid,"taxitype")==2) { format:str_least("~y~%.1f KM - ~w~%d PY�", GetPVarFloat(playerid,"s"), GetPVarInt(playerid,"plata")), GameTextForPlayer(GetPVarInt(playerid,"taxip"), str_least, 850, 4); }
		if(GetPVarInt(playerid,"taxitype")==1) { format:str_least("~y~%s - ~w~%d PY�", Convert(GetPVarInt(playerid,"s")), GetPVarInt(playerid,"plata")), GameTextForPlayer(GetPVarInt(playerid,"taxip"), str_least, 850, 4); }
		if(GetPVarInt(playerid,"taxitype")==3) { GameTextForPlayer(GetPVarInt(playerid,"taxip"),"~y~O��A�A �O �O�O�OPY", 850, 4); }
		if(pInfo[GetPVarInt(playerid,"taxip")][pMoney]<=GetPVarInt(playerid,"plata")) return RemovePlayerFromVehicle(GetPVarInt(playerid,"taxip")), SCM(playerid,-1,"{D8D8D8}� ��������� �� ������� �����, ����� ���������� �������"), SCM(playerid,-1,"{D8D8D8}� ��� �� ������� �����, ����� ���������� �������");
		//if(GetPVarInt(playerid,"taxitype")==3)
	}
	return 0;
}

