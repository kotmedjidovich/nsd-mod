UpdateCar(in,s)
{
	if(s==1)
	{
		DestroyVehicle(cInfo[in][cCar]), cInfo[in][cCar] = CreateVehicle(cInfo[in][cModel],cInfo[in][cPos][0],cInfo[in][cPos][1],cInfo[in][cPos][2],cInfo[in][cPos][3],cInfo[in][cColor][0],cInfo[in][cColor][1],-1);
		DestroyDynamicObjected( nomer_zad[in] ), DestroyDynamicObjected( nomer_pered[in] );
	}
	// ���������� ���������
	new i = in;
	return mysql_format:str_big("UPDATE `" #DB_CARS "` SET `X` = '%f', `Y` = '%f', `Z` = '%f', `F` = '%f', `color1` = '%d', `color2` = '%d', `owner` = '%s', `number` = '%s', `number2` = '%d', `number3` = '%d', `number4` = '%d', `number5` = '%s', `number6` = '%s', `print` = '%d', `price` = '%d', `virt` = '%d', `model` = '%d', `lock` = '%d', `org` = '%d', `ban` = '%d', `date` = '%d', `arrest` = '%d', `arrestinfo` = '%s' WHERE `ID` = '%d'",
	cInfo[i][cPos][0],cInfo[i][cPos][1],cInfo[i][cPos][2],cInfo[i][cPos][3],cInfo[i][cColor][0],cInfo[i][cColor][1],cInfo[i][cOwner],cInfo[i][cNumber],cInfo[i][cNumber2],cInfo[i][cNumber3],cInfo[i][cNumber4],cInfo[i][cNumber5],cInfo[i][cNumber6],cInfo[i][cPrint],cInfo[i][cPrice],cInfo[i][cVirt],cInfo[i][cModel],cInfo[i][cLock],oInfo[ cInfo[i][cOrg] ][ oID ],cInfo[i][cBan],cInfo[i][cDate],cInfo[i][cArrest],cInfo[i][cArrestinfo], cInfo[i][cID]),
	mysql_function_query(mysql_connect_ID, str_big, false, "", "");

}

CarLock(i,nuc,tcar)
{
	new engine,lights,alarm,doors,bonnet,boot,objective;
	if(tcar==-1) GetVehicleParamsEx(i,engine,lights,alarm,doors,bonnet,boot,objective), SetVehicleParamsEx(i, engine,lights,alarm,nuc,bonnet,boot,objective);
	if(tcar!=-1) GetVehicleParamsEx(cInfo[i][cCar],engine,lights,alarm,doors,bonnet,boot,objective), SetVehicleParamsEx(cInfo[i][cCar], engine,lights,alarm,nuc,bonnet,boot,objective), cInfo[i][cLock]=nuc,
	mysql_format:str_small("UPDATE `" #DB_CARS "` SET `lock` = '%d' WHERE `ID` = '%d'",nuc,cInfo[i][cID]); mysql_function_query(mysql_connect_ID, str_small, false, "", "");
	return 1;
}

