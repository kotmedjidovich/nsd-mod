    return mysql_format:str_cmd("INSERT INTO `" #DB_CARS "` (`X`, `Y`, `Z`, `F`,`color1`, `color2`, `owner`, `number`, `number2`, `number3`, `number4`, `number5`, `number6`, `price`, `virt`, `model`, `lock`, `org`, `ban`) VALUES ('%f', '%f', '%f', '%f', '%d', '%d', '%s', '%s', '%s', '%s', '%s', '%s', '%s', '%d', '%d', '%d', '%d', '%d', '%d')",
    cInfo[i][cPos][0],cInfo[i][cPos][1],cInfo[i][cPos][2],cInfo[i][cPos][3],cInfo[i][cColor][0],cInfo[i][cColor][1],cInfo[i][cOwner],cInfo[i][cNumber],cInfo[i][cNumber2],cInfo[i][cNumber3],cInfo[i][cNumber4],cInfo[i][cNumber5],cInfo[i][cNumber6],cInfo[i][cPrice],cInfo[i][cVirt],cInfo[i][cModel],cInfo[i][cLock],cInfo[i][cOrg],cInfo[i][cBan]),
    mysql_function_query(mysql_connect_ID, str_cmd, false, "", "");
	//cInfo[i][cCar] = A
}

