CMD:setrang(playerid, params[])
{
	if(pInfo[playerid][pFrak]>0)
	{
		if(pInfo[playerid][pRang] != 5) return SCM(playerid,-1,"�� �� ��������� �������");
		if(sscanf(params, "dd", params[0],params[1])) return SCM(playerid, COLOR_WHITE, "�����������: /setrang [�� ������] [1-9 ����]");
		if(params[0]==playerid) return SCM(playerid, COLOR_WHITE, "�� �� ������ �������� ���� ������ ����");
		if(pInfo[params[0]][pOrg][0]!=pInfo[playerid][pOrg][0]) return SCM(playerid, COLOR_WHITE, "����� ������� � ������ �����������");
		if(pInfo[params[0]][pFrak]!=pInfo[playerid][pFrak]) return SCM(playerid, COLOR_WHITE, "����� ������� � ������ �������");
		if(GetPVarInt(params[0],"gLogged")!=1) return SCM(playerid, COLOR_WHITE, "����� � ����� �� ���");
		if(params[1]>9||params[1]<1) return SCM(playerid, COLOR_WHITE, "�����������: /setrang [�� ������] [1-9 ����]");
		pInfo[params[0]][pFrak]=params[1]; mysql_format:str_small("UPDATE `" #DB_ACCOUNTS "` SET `Rang` = '%d' WHERE `Name` = '%s'",params[1], pInfo[params[0]][pName]); mysql_function_query(mysql_connect_ID, str_small, false, "", "");
		SendMes(params[0],-1,"{FFEF00}����� ������� %s ������� ��� ���� �� %d",pInfo[playerid][pName],params[1]);
		SendMes(playerid,-1,"{FFEF00}�� �������� ���� %s �� %d",pInfo[params[0]][pName],params[1]);
		return 1;
	}
	
	if(pInfo[playerid][pOrg][1] == 10)
	{
	    if(strcmp(oInfo[ pInfo[playerid][pOrg][0] ][oLeader],pInfo[playerid][pName],true)) return SCM(playerid,-1,"�� �� ��������� �������!");
	    if(sscanf(params, "dd", params[0],params[1])) return SCM(playerid, COLOR_WHITE, "�����������: /giverang [�� ������] [����]");
		if(params[0]==playerid) return SCM(playerid, COLOR_WHITE, "�� �� ������ �������� ������ ���� ����");
		if(pInfo[params[0]][pOrg][0]!=pInfo[playerid][pOrg][0]) return SCM(playerid, COLOR_WHITE, "����� ������� � ������ �����������");
		if(pInfo[params[0]][pFrak]!=0) return SCM(playerid, COLOR_WHITE, "����� ������� � ������ �������");
		if(GetPVarInt(params[0],"gLogged")!=1) return SCM(playerid, COLOR_WHITE, "����� �� ������!");
		if(params[1]>9 || params[1]<1) return SCM(playerid,-1,"���� �� ������ 1 � �� ������ 9");

		pformat:( "" #C_GRAY "�� �������� ���� ������ {ffffff}%s" #C_GRAY " �� {ffffff}%d",pInfo[params[0]][pName],params[1]);
		psend:( playerid, COLOR_WHITE );

		pformat:( "" #C_GRAY "����� {ffffff}%s " #C_GRAY "������� ��� ���� �� {ffffff}%d",pInfo[playerid][pName], params[1]);
		psend:( params[0], COLOR_WHITE );

		pInfo[params[0]][pOrg][1] = params[1];

		mysql_format:str_small("UPDATE `" #DB_ACCOUNTS "` SET `Orang` = '%d' WHERE `ID` = '%d'",params[1],pInfo[params[0]][pID]);
		mysql_function_query(mysql_connect_ID, str_small, false, "", "");

		return 1;
	}
	
	return 1;
}
ALTX:setrang("/giverang","/giverank");

CMD:invite(playerid, params[])
{
	if(pInfo[playerid][pFrak]>0)
	{
		if(pInfo[playerid][pRang] != 5) return SCM(playerid,-1,"�� �� ��������� �������");
		if(sscanf(params, "d", params[0])) return SCM(playerid, COLOR_WHITE, "�����������: /invite [�� ������]");
		if(params[0]==playerid) return SCM(playerid, COLOR_WHITE, "�� �� ������ ������� ������ ����");
		if(pInfo[params[0]][pOrg][0] > 0) return SCM(playerid, COLOR_WHITE, "����� ������� � ������ �����������");
		if(pInfo[params[0]][pFrak] > 0) return SCM(playerid, COLOR_WHITE, "����� ������� � ������ �������");
		if(GetPVarInt(params[0],"gLogged")!=1) return SCM(playerid, COLOR_WHITE, "�����, �������� �� ������ ������� ���");
		
		pformat:( "" #C_GRAY "�� ���������� %s �������� � ���� �������",pInfo[params[0]][pName]);
		psend:( playerid, COLOR_WHITE );
		
		SetPVarInt(params[0],"ileader",playerid);
		
	    format:str_small("{ffffff}%s ���������� ��� �������� � ������� " #C_GRAY "%s",pInfo[playerid][pName],GetFrakName(pInfo[playerid][pFrak],1));
		SPD(params[0],dFrak,info,"" #C_GRAY "����������� � �������",str_small,"�������","��������");
		
		return 1;
	}
	
	if(pInfo[playerid][pOrg][0]>0)
	{
	    if(strcmp(oInfo[ pInfo[playerid][pOrg][0] ][oLeader],pInfo[playerid][pName],true)) return SCM(playerid,-1,"�� �� ��������� �������!");
	    if(sscanf(params, "d", params[0])) return SCM(playerid, COLOR_WHITE, "�����������: /invite [�� ������]");
		if(params[0]==playerid) return SCM(playerid, COLOR_WHITE, "�� �� ������ ������� ������ ����");
		if(pInfo[params[0]][pOrg][0] > 0) return SCM(playerid, COLOR_WHITE, "����� ������� � ������ �����������");
		if(pInfo[params[0]][pFrak] > 0) return SCM(playerid, COLOR_WHITE, "����� ������� � ������ �������");
		if(GetPVarInt(params[0],"gLogged")!=1) return SCM(playerid, COLOR_WHITE, "�����, �������� �� ������ ������� ���");
		
		pformat:( "" #C_GRAY "�� ���������� %s �������� � ���� �����������",pInfo[params[0]][pName]);
		psend:( playerid, COLOR_WHITE );
		
		SetPVarInt(params[0],"ileader",playerid);

	    format:str_small("{ffffff}%s ���������� ��� �������� � ����������� " #C_GRAY "%s",pInfo[playerid][pName], oInfo[ pInfo[playerid][pOrg][0] ][oName]);
		SPD(params[0],dOrg,info,"" #C_GRAY "����������� � �����������",str_small,"�������","��������");
		
		return 1;
	}
	
	return 1;
}

