VehNumber()
{
  	new rand = random(11);
  	switch(rand)
  	{
    	case 0: format:str_least("%s","A");
		case 1: format:str_least("%s","B");
    	case 2: format:str_least("%s","C");
	    case 3: format:str_least("%s","E");
	    case 4: format:str_least("%s","H");
	    case 5: format:str_least("%s","K");
	    case 6: format:str_least("%s","M");
	    case 7: format:str_least("%s","O");
	    case 8: format:str_least("%s","P");
	    case 9: format:str_least("%s","T");
	    case 10: format:str_least("%s","X");
  	}
  	return str_least;
}

Convert(number)
{
	new hours = 0, mins = 0, secs = 0;
	hours = floatround(number / 3600);
	mins = floatround((number / 60) - (hours * 60));
	secs = floatround(number - ((hours * 3600) + (mins * 60)));
	if(hours > 0)
	{
		format:str_small("%d:%02dm:%02ds", hours, mins, secs);
	}
	else
	{
		format:str_small("%d:%02d", mins, secs);
	}
	return str_small;
}

ShowPropertyInv(playerid,id)
{
    ClearVar();

	new num;

	format:str_small("{ffffff}������������:                            {ffffff}| ���-��:\n"), strcat(str_big, str_small);

	for(new i; i != MAX_SLOTSN; i ++)
	{
		if(nInv[id][ninvSlot][i]!=0 && nInv[id][ninvSlotKol][i]!=0)
		{
			switch(strlen(_itemsInfo[nInv[id][ninvSlot][i]][invName]))
			{
				case 0..6: format:str_least("%s\t\t\t\t",_itemsInfo[nInv[id][ninvSlot][i]][invName]);
				case 7..12: format:str_least("%s\t\t\t",_itemsInfo[nInv[id][ninvSlot][i]][invName]);
				case 13..18: format:str_least("%s\t\t",_itemsInfo[nInv[id][ninvSlot][i]][invName]);
				case 19..24: format:str_least("%s\t",_itemsInfo[nInv[id][ninvSlot][i]][invName]);
			}
			format:str_small("" #C_GRAY "%s{ffffff} |     " #C_GRAY "%d\n", str_least,nInv[id][ninvSlotKol][i]), strcat(str_big, str_small), num++;
		}
	}

	format:str_least("{ffffff}���� " #C_GRAY "| %d/20",num);

	return SPD(playerid,dnInv,list,str_least,str_big,"��","�����"), str_big[0] = EOS, str_small[0] = EOS;
}

buymenu(playerid,id)
{
	ClearVar();

	if(nInfo[id][nType] != 6) format:str_small("{ffffff}����:\t\t |   ������������:\n"), strcat(str_big, str_small);
	if(nInfo[id][nType] == 6) format:str_small("������������:\n"), strcat(str_big, str_small);
	
	for(new i; i != MAX_SLOTSN; i ++)
	{
		if(nInv[id][ninvSlot][i] != 0 && nInv[id][ninvSlotKol][i] != 0)
		{
		    new zag[60];
			f(zag),"%d ���",nInv[id][ninvSlotPrice][i]);
			switch(strlen(str_least))
			{
				case 0..7: format:str_least("%s\t\t",zag);
				case 8..18: format:str_least("%s\t",zag);
			}
			if(nInfo[id][nType]!=6) format:str_small("" #C_GRAY "%s {ffffff}|   " #C_GRAY "%s\n",str_least,_itemsInfo[nInv[id][ninvSlot][i]][invName]), strcat(str_big, str_small);
			if(nInfo[id][nType]==6) format:str_small("" #C_GRAY "%s\n",_itemsInfo[nInv[id][ninvSlot][i]][invName]), strcat(str_big, str_small);
		}
	}
	format:str_small("" #C_GRAY "%s",nInfo[id][nText]);
	
	if(nInfo[id][nType] != 6) SPD(playerid,dNed+13,list,str_small,str_big,"������","�������");
	if(nInfo[id][nType] == 6) SPD(playerid,dNed+25,list,str_small,str_big,"������","�������");
	
	SetPVarInt(playerid,"id",id);
	
	str_big[0] = EOS;
	str_small[0] = EOS;
	
	return 1;
}

buymenured(playerid,id)
{
	ClearVar();

	if(nInfo[id][nType]!=6) format:str_small("����:\t\t|\t����������:\t|\t������������:\n"), strcat(str_big, str_small);
	if(nInfo[id][nType]==6) format:str_small("����������:\t|\t������������:\n"), strcat(str_big, str_small);

	for(new i; i != MAX_SLOTSN; i ++)
	{
		if(nInv[id][ninvSlot][i]!=0 && nInv[id][ninvSlotKol][i]!=0)
		{
			format:str_least("%d ���",nInv[id][ninvSlotPrice][i]);
			if(nInfo[id][nType]==6)
			switch(strlen(str_least))
			{
				case 0..8: format:str_least("%s\t\t",str_least);
				case 9..18: format:str_least("%s\t",str_least);
			}
			if(nInfo[id][nType]!=6) format:str_small("" #C_GRAY "%s{ffffff}|\t         " #C_GRAY "%d {ffffff}\t\t|\t" #C_GRAY "%s\n",str_least,nInv[id][ninvSlotKol][i],_itemsInfo[nInv[id][ninvSlot][i]][invName]), strcat(str_big, str_small);
			if(nInfo[id][nType]==6) format:str_small("" #C_GRAY "%d {ffffff}\t\t|\t" #C_GRAY "%s\n",nInv[id][ninvSlotKol][i],_itemsInfo[nInv[id][ninvSlot][i]][invName]), strcat(str_big, str_small); // ������� ������
		}
	}
	if(nInfo[id][nType]!=6) SPD(playerid,dNed+15,list,"" #C_GRAY "�������������� �������",str_big,"��������","�������");
	if(nInfo[id][nType]==6) SPD(playerid,d_null,list,"" #C_GRAY "���������� � �������",str_big,"�������","");
	SetPVarInt(playerid,"id",id);
	str_big[0] = EOS;
	str_small[0] = EOS;
	return 1;
}

