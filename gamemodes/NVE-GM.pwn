    return true;
}

timec(timestamp, &year = 1970, &month = 1, &day = 1, &hour = 0, &minute = 0, &second = 0)
{
	static dayclock,
	_ytab[2][12] = {
	{ 31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31 },
	{ 31, 29, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31 }
	};


	year = 1970;
	dayclock = timestamp % (24 * 60 * 60);
	day = timestamp / (24 * 60 * 60);

	second = dayclock % 60;
	minute = (dayclock % 3600) / 60;
	hour = dayclock / 3600;

	while (day >= ((!((year) % 4) && (((year) % 100) || !((year) % 400))) ? 366 : 365)) {
		day -= ((!((year) % 4) && (((year) % 100) || !((year) % 400))) ? 366 : 365);
		year++;
	}

	month = 0;

	while (day >= _ytab[(!((year) % 4) && (((year) % 100) || !((year) % 400)))][month]) {
		day -= _ytab[(!((year) % 4) && (((year) % 100) || !((year) % 400)))][month];
		month++;
	}

	day++;
	month++;
	format:str_least("%d.%d.%d",day,month,year);
	return str_least;
}

timem(timestamp, &year = 1970, &month = 1, &day = 1, &hour = 0, &minute = 0, &second = 0)
{
	static dayclock,
	_ytab[2][12] = {
	{ 31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31 },
	{ 31, 29, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31 }
	};


	year = 1970;
	dayclock = timestamp % (24 * 60 * 60);
	day = timestamp / (24 * 60 * 60);

	second = dayclock % 60;
	minute = (dayclock % 3600) / 60;
	hour = dayclock / 3600;

	while (day >= ((!((year) % 4) && (((year) % 100) || !((year) % 400))) ? 366 : 365)) {
		day -= ((!((year) % 4) && (((year) % 100) || !((year) % 400))) ? 366 : 365);
		year++;
	}

	month = 0;

	while (day >= _ytab[(!((year) % 4) && (((year) % 100) || !((year) % 400)))][month]) {
		day -= _ytab[(!((year) % 4) && (((year) % 100) || !((year) % 400)))][month];
		month++;
	}

	day++;
	month++;
	format:str_least("%d:%d",hour,minute);
	return str_least;
}

public:OnLeaderPanel(playerid)
{
	ClearVar();

	new
		rows = cache_get_row_count(),
		count,
		Names[MAX_PLAYER_NAME],
		ttext[40],
		Dolj[40];

	for ( new i = GetPVarInt( playerid, "leaderpanel_list" ); i < rows; i++ )
	{
		count++;
		if( count == 21 ) break;

  		cache_get_field_content(i,"Name",Names);
  		cache_get_field_content(i,"Dol",Dolj);

		if( GetPlayerID( Names ) == -1 ) 
		{ 
			
			ttext = "{E40C0C}-{FFFFFF}"; 
		}
		else 
		{
			ttext = "{2CE40C}+{FFFFFF}"; 
		}

		format:str_small("" #C_WHITE "[%s] %s\t" #C_GRAY "[%d] %s\n", ttext, Names, cache_get_field_content_int(i, "Orang", mysql_connect_ID), Dolj);
		strcat(str_big,str_small);
	}

	if( count == 0 )
	{
		SCM(playerid, -1,"� ����������� ��� �����������!");
		return 1;
	}

	if( count == 21 ) return SPD(playerid, dOrg+2, info, "" #C_WHITE "���������� �����������", str_big, "�����","�����");
	return SPD(playerid, dOrg+2, info, "" #C_WHITE "���������� �����������", str_big, "�������","");
}

public: uval(playerid)
{
	new rows, fields;
	cache_get_data(rows, fields);
	new inputtext[30]; GetPVarString(playerid,"nicku",inputtext,sizeof(inputtext));
	if(!rows) return SendMes(playerid, -1, "{FFEF00}������� %s �� ������ � ���� ������",inputtext), DeletePVar(playerid,"nicku");
	if(!strcmp(inputtext,pInfo[playerid][pName],true)) return SCM(playerid,-1,"{FFEF00}�� �� ������ ������� ���� ����");
	new tmp[4];
	cache_get_field_content(0, "Org", tmp);
	if(strval(tmp) != pInfo[playerid][pOrg][0]) return SendMes(playerid,-1,"{FFEF00}%s �� �������� ����������� ����� �����������",inputtext), DeletePVar(playerid,"nicku");
	SendMes(playerid,-1,"{FFEF00}�� ������� %s �� ����� �����������",inputtext);
	mysql_format:str_small("UPDATE `" #DB_ACCOUNTS "` SET `Org` = '0', `Orang` = '0', `Dol` = 'none' WHERE `Name` = '%s'",inputtext);
	mysql_function_query(mysql_connect_ID, str_small, false, "", "");
	DeletePVar(playerid,"nicku");
	return 1;
}


public:PayTicket(playerid)
{
    new rows, fields;
	format:str_least("" #C_GRAY "�������� | �� �����: {ffffff}%d",pInfo[playerid][pBank]);
	cache_get_data(rows, fields);
    if(!rows) SCM(playerid,-1,"����� � ����� ������� �� ������"), SPD(playerid,dBank,list,str_least,"" #C_GRAY "1. {ffffff}�������� ������\n" #C_GRAY "2. {ffffff}����� ������ �� �����\n" #C_GRAY "3. {ffffff}�������� �����\n" #C_GRAY "4. {ffffff}�������� ������ �� ���������\n" #C_GRAY "5. {ffffff}��������� �������� �������","��","�������");
	else
	{
		if(pInfo[playerid][pBank]<cache_get_field_content_int(0, "Sum", mysql_connect_ID)) return SCM(playerid,-1,"�� ����� ���������� ����� �� ������� �����");
		pInfo[playerid][pBank]-=cache_get_field_content_int(0, "Sum", mysql_connect_ID);
		format:str_small("" #C_GRAY "�� ������� �������� ����� � %d\n" #C_GRAY "� ������ ����� ������: {ffffff}%d �",cache_get_field_content_int(0, "Num", mysql_connect_ID),cache_get_field_content_int(0, "Sum", mysql_connect_ID));
		SPD(playerid,d_null,info,"" #C_GRAY "�������� ������ ���������",str_small,"�������","");
		mysql_format:str_small("UPDATE `" #DB_ACCOUNTS "` SET `Bank` = '%d' WHERE `ID` = '%d'",pInfo[playerid][pBank],pInfo[playerid][pBank]);
		mysql_function_query(mysql_connect_ID, str_small, false, "", "");
		mysql_format:str_small("DELETE FROM `tickets` WHERE `Num` = '%d'",cache_get_field_content_int(0, "Num", mysql_connect_ID));
		mysql_function_query(mysql_connect_ID, str_small, false, "", "");
		str_big[0] = EOS;
        str_small[0] = EOS;
	}
    return 1;
}

public:PayTel(playerid,tel)
{
    new rows, fields; format:str_least("" #C_GRAY "�������� | �� �����: {ffffff}%d",pInfo[playerid][pBank]); cache_get_data(rows, fields);
    if(!rows) SCM(playerid,-1,"������ ����� �� ������ � ����"), SPD(playerid,dBank,list,str_least,"" #C_GRAY "1. {ffffff}�������� ������\n" #C_GRAY "2. {ffffff}����� ������ �� �����\n" #C_GRAY "3. {ffffff}�������� �����\n" #C_GRAY "4. {ffffff}�������� ������ �� ���������\n" #C_GRAY "5. {ffffff}��������� �������� �������","��","�������");
	else
	{
		format:str_small("{ffffff}����� ��������: " #C_GRAY "%d\n{ffffff}������� �����, ������� �� ������ �������� �� ����:",tel);
		SPD(playerid,dBank+5,input,str_least,str_small,"��������","�����"); SetPVarInt(playerid,"paytel",tel); SetPVarInt(playerid,"pmoney",cache_get_field_content_int(0, "Phonemoney", mysql_connect_ID));
	}
    return 1;
}

public:CheckTickets(playerid)
{
    new rows, fields;
    cache_get_data(rows, fields);
    if(rows)
    {
        new Names[MAX_PLAYER_NAME],Names2[MAX_PLAYER_NAME],full,Reason[70],Date[12];
        while(--rows >= 0)
        {
            cache_get_field_content(rows,"Writer",Names);
            cache_get_field_content(rows,"Name",Names2);
            cache_get_field_content(rows,"Reason",Reason);
            cache_get_field_content(rows,"Date",Date); //134+70+6+9+14+24=257
            format:str_cmd("" #C_GRAY "[� %d] {ffffff}� ������: " #C_GRAY "%d � {ffffff}| �������: " #C_GRAY "%s {ffffff}| ����: " #C_GRAY "%s {ffffff}| �������: " #C_GRAY "%s\n",cache_get_field_content_int(rows, "Num", mysql_connect_ID),cache_get_field_content_int(rows, "Sum", mysql_connect_ID),Reason,Date,Names), strcat(str_big,str_cmd), full++;
        }
        format:str_small("" #C_GRAY "������ %s | ����� %d",Names2,full);
        if(full == 0) return SPD(playerid,d_null,info,"" #C_GRAY "������","{ffffff}������ ������� - ����!","�������","");
        else SPD(playerid,d_null,info,str_small,str_big,"�������","");
    }
    else SPD(playerid,d_null,info,"" #C_GRAY "������","������� � ����� ������ � �������� - " #C_GRAY "�� ������!","�������","");
    str_big[0] = EOS;
