GivePlayerItem(playerid,item,kol)
{
	new bool:itemkol = false, bool:itemv = false;
	//for(new i; i != 56; i++) kg += _itemsInfo[_invPlayer[playerid][invSlot][i]][invKg];
	//if(kg + _itemsInfo[item][invKg] > MAX_PLAYER_KG) return SCM(playerid,-1,"�� ��� � ��� ������ ����� ����� � �����!");
	for(new i; i != 10; i++)
	{
		if(_invPlayer[playerid][invSlot][i] == 0)
		{
			if( _invPlayer[playerid][invSlotKol][i] >= 15 )
			{
			    return SCM( playerid, -1, "� ��� � ��������� ��������� ���������� ������� ��������!");
			}
			
			itemkol = true;
			_invPlayer[playerid][invSlot][i] = item;
			_invPlayer[playerid][invSlotKol][i] = kol;
			SaveInventory(playerid);
			return 1;
		}
		if(itemv==false)
		{
			for(new z; z != 11; z++)
			{
				if(_invPlayer[playerid][invSlot][z] == item)
				{
				    if( _invPlayer[playerid][invSlotKol][z] >= 15 )
					{
					    return SCM( playerid, -1, "� ��� � ��������� ��������� ���������� ������� ��������!");
					}
			
					return _invPlayer[playerid][invSlotKol][z] += kol, itemkol = true, SaveInventory(playerid);
				}
			}
			itemv=true;
		}
	}
	if(itemkol == false) return SCM(playerid,-1,"� ��� ������������ ����� ��� ����� ��������!");
	return 1;
}

SaveOrgs(i)
{
    ClearVar();
    mysql_format:str_cmd("UPDATE `" #DB_ORGS "` SET\
	 `name` = '%s', \
	 `leader` = '%s', \
	 `type` = '%d', \
	 `ned` = '%d', \
	 `money` = '%d', \
	 `chart` = '%d' \
	 WHERE `ID` = '%d'",
    oInfo[i][oName],
    oInfo[i][oLeader],
    oInfo[i][oType],
    oInfo[i][oNed],
    oInfo[i][oMoney],
    oInfo[i][oChart],
	oInfo[i][oID]);
    mysql_function_query(mysql_connect_ID, str_cmd, false, "", "");
    return 1;
}

SaveInventory(playerid)
{
    ClearVar();

    mysql_format:str_big("UPDATE `" #DB_ACCOUNTS "` SET `pInvSlots` = '%d|%d|%d|%d|%d|%d|%d|%d|%d|%d' WHERE `ID` = '%d'",
    _invPlayer[playerid][invSlot][0],_invPlayer[playerid][invSlot][1],_invPlayer[playerid][invSlot][2],_invPlayer[playerid][invSlot][3],_invPlayer[playerid][invSlot][4],_invPlayer[playerid][invSlot][5],_invPlayer[playerid][invSlot][6],_invPlayer[playerid][invSlot][7],
	_invPlayer[playerid][invSlot][8],_invPlayer[playerid][invSlot][9],pInfo[playerid][pID]);
    mysql_function_query(mysql_connect_ID, str_big, false, "", "");

    str_big[0] = EOS;

   	mysql_format:str_big("UPDATE `" #DB_ACCOUNTS "` SET `pInvSlotsKol` = '%d|%d|%d|%d|%d|%d|%d|%d|%d|%d' WHERE `ID` = '%d'",
	_invPlayer[playerid][invSlotKol][0],_invPlayer[playerid][invSlotKol][1],_invPlayer[playerid][invSlotKol][2],_invPlayer[playerid][invSlotKol][3],_invPlayer[playerid][invSlotKol][4],_invPlayer[playerid][invSlotKol][5],_invPlayer[playerid][invSlotKol][6],_invPlayer[playerid][invSlotKol][7],
	_invPlayer[playerid][invSlotKol][8],_invPlayer[playerid][invSlotKol][9],pInfo[playerid][pID]);
	mysql_function_query(mysql_connect_ID, str_big, false, "", "");

 	str_cmd[0] = EOS;

    return 1;
}

SaveNinventory(i)
{
    ClearVar();

    mysql_format:str_big("UPDATE `" #DB_PROPERTY "` SET `nInvSlots` = '%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d' WHERE `ID` = '%d'",
    nInv[i][ninvSlot][0],nInv[i][ninvSlot][1],nInv[i][ninvSlot][2],nInv[i][ninvSlot][3],nInv[i][ninvSlot][4],nInv[i][ninvSlot][5],nInv[i][ninvSlot][6],nInv[i][ninvSlot][7],nInv[i][ninvSlot][8],nInv[i][ninvSlot][9],
	nInv[i][ninvSlot][10],nInv[i][ninvSlot][11],nInv[i][ninvSlot][12],nInv[i][ninvSlot][13],nInv[i][ninvSlot][14],nInv[i][ninvSlot][15],nInv[i][ninvSlot][16],nInv[i][ninvSlot][17],nInv[i][ninvSlot][18],nInv[i][ninvSlot][19],nInfo[i][nID]);
    mysql_function_query(mysql_connect_ID, str_big, false, "", "");
    
    str_big[0] = EOS;

    mysql_format:str_big("UPDATE `" #DB_PROPERTY "` SET `nInvSlotsKol` = '%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d' WHERE `ID` = '%d'",
    nInv[i][ninvSlotKol][0],nInv[i][ninvSlotKol][1],nInv[i][ninvSlotKol][2],nInv[i][ninvSlotKol][3],nInv[i][ninvSlotKol][4],nInv[i][ninvSlotKol][5],nInv[i][ninvSlotKol][6],nInv[i][ninvSlotKol][7],nInv[i][ninvSlotKol][8],nInv[i][ninvSlotKol][9],
	nInv[i][ninvSlotKol][10],nInv[i][ninvSlotKol][11],nInv[i][ninvSlotKol][12],nInv[i][ninvSlotKol][13],nInv[i][ninvSlotKol][14],nInv[i][ninvSlotKol][15],nInv[i][ninvSlotKol][16],
	nInv[i][ninvSlotKol][17],nInv[i][ninvSlotKol][18],nInv[i][ninvSlotKol][19],nInfo[i][nID]);
    mysql_function_query(mysql_connect_ID, str_big, false, "", "");
    
    str_big[0] = EOS;

    mysql_format:str_big("UPDATE `" #DB_PROPERTY "` SET `nInvSlotsPrice` = '%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d' WHERE `ID` = '%d'",
    nInv[i][ninvSlotPrice][0],nInv[i][ninvSlotPrice][1],nInv[i][ninvSlotPrice][2],nInv[i][ninvSlotPrice][3],nInv[i][ninvSlotPrice][4],nInv[i][ninvSlotPrice][5],nInv[i][ninvSlotPrice][6],nInv[i][ninvSlotPrice][7],nInv[i][ninvSlotPrice][8],nInv[i][ninvSlotPrice][9],
	nInv[i][ninvSlotPrice][10], nInv[i][ninvSlotPrice][11], nInv[i][ninvSlotPrice][12], nInv[i][ninvSlotPrice][13], nInv[i][ninvSlotPrice][14], nInv[i][ninvSlotPrice][15], nInv[i][ninvSlotPrice][16],
	nInv[i][ninvSlotPrice][17], nInv[i][ninvSlotPrice][18], nInv[i][ninvSlotPrice][19], nInfo[i][nID]);
