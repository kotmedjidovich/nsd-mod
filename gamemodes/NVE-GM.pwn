TextdrawFurniture(playerid, bool:action)
{
	if( action == true )
	{
		for( new i; i != 11; i++ ) TextDrawShowForPlayer( playerid, ftextdraw[ i ] );
		TextDrawShowForPlayer( playerid, ftextdrawp[ 0 ][ playerid ] );
		TextDrawShowForPlayer( playerid, ftextdrawp[ 1 ][ playerid ] );
	}
	else if( action == false )
	{
		for( new i; i != 11; i++ ) TextDrawHideForPlayer( playerid, ftextdraw[ i ] );
		TextDrawHideForPlayer( playerid, ftextdrawp[ 0 ][ playerid ] );
		TextDrawHideForPlayer( playerid, ftextdrawp[ 1 ][ playerid ] );
	}
	
	return 1;
}

UpdateMusic(i)
{
    if( nInfo[ i ][ nMusic ] == 1 )
	{
 		new
   			Float:radius;

		switch( nInfo[i][nMusicVolume] )
		{
  			case 0: radius = 10.0;
	    	case 1: radius = 20.0;
	    	case 2: radius = 30.0;
	    	default: radius = 10.0;
		}
		
		if( nInfo[ i ][ nMusicstID ] != 0 ) DestroyDynamicAreas( nInfo[ i ][ nMusicstID ] );
		if( nInfo[ i ][ nMusicID ] != 0 ) DestroyDynamicAreas( nInfo[ i ][ nMusicID ] );

		if( nInfo[i][nMusicVolume] == 2 && nInfo[i][nPick][0] != 0.0 ) nInfo[ i ][ nMusicstID ] = CreateDynamicSphere(nInfo[i][nPick][0],nInfo[i][nPick][1],nInfo[i][nPick][2], 5.0, -1, -1, -1);
		if( nInfo[i][nExite][0] != 0.0 ) nInfo[ i ][ nMusicID ] = CreateDynamicSphere(nInfo[i][nExite][0],nInfo[i][nExite][1],nInfo[i][nExite][2], radius, nInfo[i][nInt], -1, -1);
	}
	else
	{ 
	    foreach( Player, id )
	    {
	        if( IsPlayerInDynamicArea( id, nInfo[ i ][ nMusicstID ] ) || IsPlayerInDynamicArea( id, nInfo[ i ][ nMusicID ] ) )
			{
			    StopAudioStreamForPlayer( id );
			    StopAudioStreamForPlayer( id );
			    StopAudioStreamForPlayer( id );
			}
	    }
	
		if( nInfo[i][nMusicVolume] == 2 ) DestroyDynamicAreas( nInfo[ i ][ nMusicstID ] ), nInfo[ i ][ nMusicstID ] = EOS;
		DestroyDynamicAreas( nInfo[ i ][ nMusicID ] ), nInfo[ i ][ nMusicID ] = EOS;
	}
	
	return 1;
}

DestroyDynamicAreas(i)
{
	if( IsValidDynamicArea(i) ) return DestroyDynamicArea( i );
	return 1;
}

CheckEditObject(playerid, Float:X, Float:Y, Float:Z )
{
	if( !IsPlayerInRangeOfPoint( playerid, 8.5, X, Y, Z) )
	{
		if( GetPVarInt(playerid,"fursel") == 1 )
		{
			DestroyDynamicObjected( fInfo[ GetPVarInt(playerid,"nmenuid") ][ fObjectid ][ GetPVarInt( playerid, "furslot" ) ]);
		    fInfo[ GetPVarInt(playerid,"nmenuid") ][ fObjectid ][ GetPVarInt( playerid, "furslot" ) ] = EOS;
		    fInfo[ GetPVarInt(playerid,"nmenuid") ][ fObject ][ GetPVarInt( playerid, "furslot" ) ] = EOS;
		    DeletePVar( playerid, "fursel" );
		}
		
		if( GetPVarInt(playerid,"fursel") == 2 )
		{
			SPD( playerid, dFurniture, list, " ","" #C_GRAY "�{FFFFFF} ��������������� ������\n" #C_GRAY "�{FFFFFF} ���������� ������","��","�����");
		    DeletePVar( playerid, "fursel" );
		}
		
		if(GetPVarInt(playerid,"editcarattach") == 2)
		{
			new
				i = GetPVarInt( playerid, "editattachcar"),
				car = GetPVarInt( playerid, "attachcar");
				
			SCM(playerid, -1, "�� �������� ��������� ��������!");
			cInfo[ car ][ cAttachID ][ i ] = 0;
			cInfo[ car ][ cObjectInv ][ i ] = 0;
			cInfo[ car ][ cAttachObject ][ i ] = 0;
		}
		DeletePVar(playerid,"editcarattach");
		
		DeletePVar(playerid,"editobject");
		
		DeletePVar(playerid,"editfrakobject");
		DeletePVar(playerid,"selectSlot");
		
		DestroyDynamicObjected(eobj[playerid]);

		SCM(playerid,0xCD4B47FF,"��������������� ������� ������ ��������� �� ����� 8 ������ �� ������ ���������");

		CancelEdit(playerid);

		Streamer_UpdateEx(playerid, X, Y, Z );
	}

	return 0;
}

public: CheckNumber( playerid, number )
{
    if( !cache_get_row_count() ) 
    {
    	if( number < 100000 ) number = random(999999);

    	pInfo[playerid][pNumber] = number;

    	mysql_format:str_small("UPDATE `" #DB_ACCOUNTS "` SET `Number` = '%d' WHERE `ID` = '%d'",pInfo[playerid][pNumber],pInfo[playerid][pID]);
    	mysql_function_query(mysql_connect_ID, str_small, false, "", "");

		SendMes(playerid,-1,"" #C_GRAY "���� SIM-����� ������������ �� ����� %d",pInfo[playerid][pNumber]);
    }
    else 
    {
    	number = random(999999);

		if( number < 100000 ) number = random(999999);

		mysql_format:str_small("SELECT * FROM `" #DB_ACCOUNTS "` WHERE `Number` = '%d'", number ),
		mysql_function_query(mysql_connect_ID, str_small, true, "CheckNumber", "dd", playerid, number);
    }

    return 1;
}
