LoadNed() return mysql_function_query(mysql_connect_ID, "SELECT * FROM `" #DB_PROPERTY "`",true,"NextLoadNed","");
public: NextLoadNed()
{
    new rows, fields, time = GetTickCount();
    cache_get_data(rows, fields);
    for(new i; i < rows; i++)
    {
        nInfo[i][nID] = cache_get_field_content_int(i, "ID", mysql_connect_ID);
        nInfo[i][nPick][0] = cache_get_field_content_float(i, "X", mysql_connect_ID);
        nInfo[i][nPick][1] = cache_get_field_content_float(i, "Y", mysql_connect_ID);
        nInfo[i][nPick][2] = cache_get_field_content_float(i, "Z", mysql_connect_ID);
        nInfo[i][nPick][3] = cache_get_field_content_float(i, "F", mysql_connect_ID);
        nInfo[i][nExite][0] = cache_get_field_content_float(i, "exX", mysql_connect_ID);
        nInfo[i][nExite][1] = cache_get_field_content_float(i, "exY", mysql_connect_ID);
        nInfo[i][nExite][2] = cache_get_field_content_float(i, "exZ", mysql_connect_ID);
        nInfo[i][nExite][3] = cache_get_field_content_float(i, "exF", mysql_connect_ID);
        nInfo[i][nSpawn][0] = cache_get_field_content_float(i, "spX", mysql_connect_ID);
        nInfo[i][nSpawn][1] = cache_get_field_content_float(i, "spY", mysql_connect_ID);
        nInfo[i][nSpawn][2] = cache_get_field_content_float(i, "spZ", mysql_connect_ID);
        nInfo[i][nBuy][0] = cache_get_field_content_float(i, "buyX", mysql_connect_ID);
        nInfo[i][nBuy][1] = cache_get_field_content_float(i, "buyY", mysql_connect_ID);
        nInfo[i][nBuy][2] = cache_get_field_content_float(i, "buyZ", mysql_connect_ID);
        nInfo[i][nPickid] = cache_get_field_content_int(i, "pickid", mysql_connect_ID);
        nInfo[i][nMoney] = cache_get_field_content_int(i, "money", mysql_connect_ID);
        nInfo[i][nCost] = cache_get_field_content_int(i, "cost", mysql_connect_ID);
        cache_get_field_content(i, "owner", nInfo[i][nOwner], mysql_connect_ID, 24);
        cache_get_field_content(i, "text", nInfo[i][nText], mysql_connect_ID, 128);
        nInfo[i][nPrice] = cache_get_field_content_int(i, "price", mysql_connect_ID);
        nInfo[i][nType] = cache_get_field_content_int(i, "type", mysql_connect_ID);
        nInfo[i][nInt] = cache_get_field_content_int(i, "int", mysql_connect_ID);
        nInfo[i][nLock] = cache_get_field_content_int(i, "lock", mysql_connect_ID);
        nInfo[i][nCup] = cache_get_field_content_int(i, "cup", mysql_connect_ID);
        nInfo[i][nCarenter] = cache_get_field_content_int(i, "carenter", mysql_connect_ID);
        nInfo[i][nDate] = cache_get_field_content_int(i, "date", mysql_connect_ID);
        
        cache_get_field_content(i, "musicurl", nInfo[i][nMusicUrl], mysql_connect_ID, 128);
        nInfo[i][nMusic] = cache_get_field_content_int(i, "music", mysql_connect_ID);
        nInfo[i][nMusicVolume] = cache_get_field_content_int(i, "musicvolume", mysql_connect_ID);
        
		UpdateMusic(i);
        
        LoadAllNed++;

	    cache_get_field_content(i, "nInvSlots", str_small, mysql_connect_ID,200);
		sscanf(str_small, "p<|>dddddddddddddddddddd",
		nInv[i][ninvSlot][0],
		nInv[i][ninvSlot][1],
		nInv[i][ninvSlot][2],
		nInv[i][ninvSlot][3],
		nInv[i][ninvSlot][4],
		nInv[i][ninvSlot][5],
		nInv[i][ninvSlot][6],
		nInv[i][ninvSlot][7],
		nInv[i][ninvSlot][8],
		nInv[i][ninvSlot][9],
		nInv[i][ninvSlot][10],
		nInv[i][ninvSlot][11],
		nInv[i][ninvSlot][12],
		nInv[i][ninvSlot][13],
		nInv[i][ninvSlot][14],
		nInv[i][ninvSlot][15],
		nInv[i][ninvSlot][16],
		nInv[i][ninvSlot][17],
		nInv[i][ninvSlot][18],
		nInv[i][ninvSlot][19]);
        str_small[0] = EOS;

		cache_get_field_content(i, "nInvSlotsKol", str_small, mysql_connect_ID,200);
		sscanf(str_small, "p<|>dddddddddddddddddddd",
		nInv[i][ninvSlotKol][0],
		nInv[i][ninvSlotKol][1],
		nInv[i][ninvSlotKol][2],
		nInv[i][ninvSlotKol][3],
		nInv[i][ninvSlotKol][4],
		nInv[i][ninvSlotKol][5],
		nInv[i][ninvSlotKol][6],
		nInv[i][ninvSlotKol][7],
		nInv[i][ninvSlotKol][8],
		nInv[i][ninvSlotKol][9],
		nInv[i][ninvSlotKol][10],
		nInv[i][ninvSlotKol][11],
		nInv[i][ninvSlotKol][12],
		nInv[i][ninvSlotKol][13],
		nInv[i][ninvSlotKol][14],
		nInv[i][ninvSlotKol][15],
		nInv[i][ninvSlotKol][16],
		nInv[i][ninvSlotKol][17],
		nInv[i][ninvSlotKol][18],
		nInv[i][ninvSlotKol][19]);
		str_small[0] = EOS;

		cache_get_field_content(i, "nInvSlotsPrice", str_small, mysql_connect_ID,200);
		sscanf(str_small, "p<|>dddddddddddddddddddd",
		nInv[i][ninvSlotPrice][0],
		nInv[i][ninvSlotPrice][1],
		nInv[i][ninvSlotPrice][2],
		nInv[i][ninvSlotPrice][3],
		nInv[i][ninvSlotPrice][4],
		nInv[i][ninvSlotPrice][5],
		nInv[i][ninvSlotPrice][6],
		nInv[i][ninvSlotPrice][7],
		nInv[i][ninvSlotPrice][8],
		nInv[i][ninvSlotPrice][9],
		nInv[i][ninvSlotPrice][10],
		nInv[i][ninvSlotPrice][11],
		nInv[i][ninvSlotPrice][12],
		nInv[i][ninvSlotPrice][13],
		nInv[i][ninvSlotPrice][14],
		nInv[i][ninvSlotPrice][15],
		nInv[i][ninvSlotPrice][16],
		nInv[i][ninvSlotPrice][17],
		nInv[i][ninvSlotPrice][18],
		nInv[i][ninvSlotPrice][19]);
        str_small[0] = EOS;

		CreateProperty(i);
		
	}
	printf("[��������� ������� ������������]: <%i>. ����� ��������: <%i ��>",LoadAllNed,GetTickCount()-time);
    return 1;
}

UpdateProperty(i,s)
{
    ClearVar();

	// ���������� ���������
	mysql_format:str_big("UPDATE `" #DB_PROPERTY "` SET \
	`X` = '%f', \
	`Y` = '%f', \
	`Z` = '%f', \
	`F` = '%f', \
	`exX` = '%f', \
	`exY` = '%f', \
	`exZ` = '%f', \
	`exF` = '%f', \
	`spX` = '%f', \
	`spY` = '%f', \
	`spZ` = '%f', \
	`buyX` = '%f', \
	`buyY` = '%f', \
	`buyZ` = '%f', \
	`pickid` = '%d', \
	`owner` = '%s', \
	`text` = '%s', \
	`price` = '%d', \
	`type` = '%d', \
	`int` = '%d', \
	`lock` = '%d', \
	`money` = '%d', \
	`cost` = '%d', \
	`cup` = '%d', \
	`carenter` = '%d', \
	`date` = '%d' WHERE \
	`ID` = '%d'",
	nInfo[i][nPick][0],
	nInfo[i][nPick][1],
	nInfo[i][nPick][2],
	nInfo[i][nPick][3],
	nInfo[i][nExite][0],
	nInfo[i][nExite][1],
	nInfo[i][nExite][2],
	nInfo[i][nExite][3],
	nInfo[i][nSpawn][0],
	nInfo[i][nSpawn][1],
	nInfo[i][nSpawn][2],
	nInfo[i][nBuy][0],
	nInfo[i][nBuy][1],
	nInfo[i][nBuy][2],
	nInfo[i][nPickid],
	nInfo[i][nOwner],
	nInfo[i][nText],
	nInfo[i][nPrice],
	nInfo[i][nType],
	nInfo[i][nInt],
	nInfo[i][nLock],
	nInfo[i][nMoney],
	nInfo[i][nCost],
	nInfo[i][nCup],
	nInfo[i][nCarenter],
	nInfo[i][nDate],
	nInfo[i][nID]),
	mysql_function_query(mysql_connect_ID, str_big, false, "", "");

	SaveNinventory(i);

	if(s == 1)
	{
	    DeleteProperty(i);
		CreateProperty(i);
	}
	return 1;
}

CreateProperty(i)
{
    ClearVar();

	// ������������ 3� ������
	if(!strcmp(nInfo[i][nOwner], "none", true)) format:str_small("{FFDA00}���������{ffffff}\n"), strcat(str_cmd, str_small);
	format:str_small("{FFFFFF}�����: {FFDA00}%d\n",i), strcat(str_cmd, str_small);
	format:str_small("{FFFFFF}��� ������������: {FFDA00}%s\n",GetPropertyType(i)), strcat(str_cmd, str_small);
	if(nInfo[i][nType]==4 && nInfo[i][nCost]==0) nInfo[i][nCost]=30;
	format:str_small("{FFFFFF}��������: {FFDA00}%s\n",nInfo[i][nText]), strcat(str_cmd, str_small);
	if(strcmp(nInfo[i][nOwner], "none", true) && nInfo[i][nType]==4) format:str_small("{FFFFFF}���� �� 1 ���� �������: {FFDA00}%d\n",nInfo[i][nCost]), strcat(str_cmd, str_small);
	if(strcmp(nInfo[i][nOwner], "none", true) && nInfo[i][nType]==4) format:str_small("{FFFFFF}������� �������{FFDA00} ALT\n",nInfo[i][nPrice]), strcat(str_cmd, str_small);
	if(!strcmp(nInfo[i][nOwner], "none", true)) format:str_small("{FFFFFF}���� ������������: {FFDA00}%d",nInfo[i][nPrice]), strcat(str_cmd, str_small);

	// �������� 3� ������ � �������
	if(nInfo[i][nPick][0]!=0.0) nInfo[i][nPickup][0] = CreateDynamicPickup(nInfo[i][nPickid], 1, nInfo[i][nPick][0], nInfo[i][nPick][1], nInfo[i][nPick][2], -1, -1, -1, 100.0);
	if(nInfo[i][nExite][0]!=0.0) nInfo[i][nPickup][1] = CreateDynamicPickup(1559, 1, nInfo[i][nExite][0], nInfo[i][nExite][1], nInfo[i][nExite][2], nInfo[i][nInt], -1, -1, 100.0);
	if(nInfo[i][nBuy][0]!=0.0) nInfo[i][nPickup][2] = CreateDynamicPickup(19198, 23, nInfo[i][nBuy][0], nInfo[i][nBuy][1], nInfo[i][nBuy][2], nInfo[i][nInt], -1, -1, 100.0);
	if(nInfo[i][nPick][0]!=0.0) nInfo[i][n3Dtext] = CDT(str_cmd,-1,nInfo[i][nPick][0], nInfo[i][nPick][1], nInfo[i][nPick][2],10.0,INVALID_PLAYER_ID,INVALID_PLAYER_ID,0,-1,-1,-1,100.0);
	else nInfo[i][n3Dtext] = CDT(str_cmd,-1,nInfo[i][nBuy][0], nInfo[i][nBuy][1], nInfo[i][nBuy][2],10.0,INVALID_PLAYER_ID,INVALID_PLAYER_ID,0,-1,-1,-1,100.0);

	str_cmd[0] = EOS;
	str_small[0] = EOS;

	return printf( "[P] ������������ �%i �������" , i );
}

DeleteProperty(i)
{
	DeleteDynamic3DText( nInfo[i][n3Dtext] );
	if( IsValidDynamicPickup( nInfo[i][nPickup][0] )) DestroyDynamicPickup( nInfo[i][nPickup][0] );
	if( IsValidDynamicPickup( nInfo[i][nPickup][1] )) DestroyDynamicPickup( nInfo[i][nPickup][1] );
	if( IsValidDynamicPickup( nInfo[i][nPickup][2] )) DestroyDynamicPickup( nInfo[i][nPickup][2] );
	return printf( "[P] ������������ �%i ����������", i );
}

