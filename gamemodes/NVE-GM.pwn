CMD:gate(playerid)
{
	if(pInfo[playerid][pFrak]==2)
	{
	    if(GetPVarInt(playerid,"AntiFlood") > gettime()) return SCM(playerid, COLOR_WHITE, "��������������: " #C_GRAY "�� ������� !");
	    
		if(!IsPlayerInRangeOfPoint(playerid, 15.0,-891.58582, 1946.78943, 44.98001)) return SCM(playerid,-1,"�� ������ ���������� ����� � ������� !");
		
		if(omongatestatus==false) 	// ���������
		{
			MoveDynamicObject(omongate,-891.43201, 1938.00000, 44.98000, 2.0 ,0.00000, 0.00000, 91.00000);
			omongatestatus=true;
			omongatetime=11;
			SetPVarInt(playerid,"AntiFlood",gettime() + 1);
			return SCM(playerid,-1,"������ ������� �� " #C_GRAY "10 ������ !");
		}
		else 						// ���������
		{
			MoveDynamicObject(omongate,-891.58582, 1946.78943, 44.98001, 2.0 ,0.00000, 0.00000, 91.00000);
			omongatestatus=false;
			omongatetime=0;
			SetPVarInt(playerid,"AntiFlood",gettime() + 1);
			return SCM(playerid,-1,"������ ������� !");
		}
	}
	SCM(playerid,-1,"� ��� ��� ������� � ���� �������!");
	SetPVarInt(playerid,"AntiFlood",gettime() + 1);
	return 1;
}

CMD:shgate(playerid)
{
	if(pInfo[playerid][pFrak]==3)
	{
	    if(GetPVarInt(playerid,"AntiFlood") > gettime()) return SCM(playerid, COLOR_WHITE, "��������������: " #C_GRAY "�� ������� !");

		if(!IsPlayerInRangeOfPoint(playerid, 15.0,454.730743,913.541748,12.264351)) return SCM(playerid,-1,"�� ������ ���������� ����� � ������� !");

		if(shgatestatus==false && hsgatestatus==false) 	// ���������
		{
			MoveDynamicObject(shgate,453.7890, 914.9200, 12.2644, 2.0, 0.0000, 0.0000, -13.0000);
			MoveDynamicObject(hsgate,452.7933, 910.2554, 12.2643, 2.0, 0.0000, 0.0000, 171.0000);
			shgatestatus=true;
			hsgatestatus=true;
			shgatetime=11;
			hsgatetime=11;
			SetPVarInt(playerid,"AntiFlood",gettime() + 1);
			return SCM(playerid,-1,"������ ������� �� " #C_GRAY "10 ������ !");
		}
		else 						// ���������
		{
			MoveDynamicObject(shgate,454.730743,913.541748,12.264351, 2.0, 0.000000,0.000000,77.000099);
			MoveDynamicObject(hsgate,454.244628,911.201904,12.264348, 2.0, 0.000000,0.000000,79.399848);
			shgatestatus=false;
			hsgatestatus=false;
			shgatetime=0;
   			hsgatetime=0;
			SetPVarInt(playerid,"AntiFlood",gettime() + 1);
			return SCM(playerid,-1,"������ ������� !");
		}
	}
	SCM(playerid,-1,"� ��� ��� ������� � ���� �������!");
	SetPVarInt(playerid,"AntiFlood",gettime() + 1);
	return 1;
}

CMD:pts(playerid, params[])
{
    if(sscanf(params, "d", params[0])) return SCM(playerid, COLOR_WHITE, "�����������: /pts [�� ������]");
    if(!IsPlayerConnected(params[0])) return SCM(playerid,-1,"������ � ����� ID ��� �� �������");
    new Float:pos1,Float:pos2,Float:pos3; GetPlayerPos(params[0],pos1,pos2,pos3);
	if(!IsPlayerInRangeOfPoint(playerid, 15.0,pos1,pos2,pos3)) return SCM(playerid,-1,"�� ������ ���������� ����� ������, �������� ������ �������� ���� �����");
	
	SetPVarInt(playerid,"cmenuid",-1);
	new kolvo;
    for(new i; i != LoadAllCar; i++)
	{
		if(!strcmp(cInfo[i][cOwner],pInfo[playerid][pName],true))
		{
			SetPVarInt(playerid,"cmenuid",i), kolvo++; format:str_small("" #C_GRAY "%d.{ffffff} %s [%s%s%s%s%s%s]\n",kolvo,GetCarMark(cInfo[i][cModel]),cInfo[i][cNumber],
			cInfo[i][cNumber2],cInfo[i][cNumber3],cInfo[i][cNumber4],cInfo[i][cNumber5],cInfo[i][cNumber6]);
			strcat(str_big,str_small);
		}
	}
	if(GetPVarInt(playerid,"cmenuid")==-1) return SCM(playerid,-1,"�� �� ������� ������ ��");
	
	new i = GetPVarInt(playerid,"cmenuid"),
	    timee[24];

	if(kolvo==1)
	{
		format:str_small("" #C_GRAY "������� ������������� �������� %s",GetCarMark(cInfo[GetPVarInt(playerid,"cmenuid")][cModel]));
		
		if( cInfo[GetPVarInt(playerid,"cmenuid")][cDatebuy] != 0 )
		{
			f(timee),"%s", timec(cInfo[GetPVarInt(playerid,"cmenuid")][cDatebuy]));
		}
		else
		{
			f(timee),"�� �������");
		}
		format:str_cmd("\
		" #C_GRAY "����� VIN: {FFFFFF}1000%d\n\
		" #C_GRAY "������������ ������������ ��(��): {FFFFFF}%s\n\
		" #C_GRAY "���� ������������: {FFFFFF}%s\n\
		" #C_GRAY "����� ������ ��: {FFFFFF}%s\n\
		" #C_GRAY "���. ����: {FFFFFF}%s%s%s%s%s%s\n\
		" #C_GRAY "���� ������: {FFFFFF}%d\n\
		" #C_GRAY "������������� � ����������� ��\n\
		" #C_GRAY "����� ������� ��: {FFFFFF}%d ���� (�� %s[%s])\n\
		" #C_GRAY "������: {FFFFFF}����� �� ������������� �������",cInfo[i][cID],cInfo[i][cOwner],timee,GetCarMark(cInfo[i][cModel]),cInfo[i][cNumber],
		cInfo[i][cNumber2],cInfo[i][cNumber3],cInfo[i][cNumber4],cInfo[i][cNumber5],cInfo[i][cNumber6],cInfo[i][cColor][0],UnixDay( cInfo[i][cDate] ),timec( cInfo[i][cDate] ),timem( cInfo[i][cDate] ) );
        SPD(params[0],d_null,info,str_small,str_cmd,"�������","");
        strcat(str_big,str_cmd);
		str_big[0] = EOS;
        return 1;
	}
	return SPD(playerid,dCar+9,list,"" #C_GRAY "���� ����������",str_big,"��","�������"), SetPVarInt(playerid,"idp",params[0]), str_big[0] = EOS;
}

CMD:attachcar(playerid)
{
	new
		car,
		bool:found = false;
	
    for(new i; i != LoadAllCar; i++)
	{
	    if( GetPlayerVehicleID(playerid) == cInfo[ i ][ cCar ] )
		{
			if(!strcmp(cInfo[i][cOwner],pInfo[playerid][pName],true))
			{
                car = i;
			    found = true;
			    break;
			}
			else if( cInfo[ i ][ cOrg ] != 0 )
   			{
				if( cInfo[ i ][ cOrg ] == pInfo[ playerid ][ pOrg ][ 0 ] )
				{
				    car = i;
			    	found = true;
			    	break;
				}
			}
		}
	}
	 
	if( found == false && pInfo[ playerid ][ pOrg ][ 0 ] > 0 ) return SCM(playerid, -1, "�� ������ ���������� � ����� ������ ���������� ��� ���������� ����� �����������!");
	if( found == false ) return SCM(playerid, -1, "�� ������ ���������� � ����� ������ ����������!");
	if( EngineCar[ cInfo[car][cCar] ] != 0 ) return SCM(playerid, -1, "��������� ���������� ������ ���� ��������!");
	if( cInfo[car][cLock] != 1 ) return SCM(playerid, -1, "����� ���������� ������ ���� �������!");
	
    return ShowCarAttach(playerid, car);
}

CMD:cmenu(playerid)
{
	SetPVarInt(playerid,"cmenuid",-1); new kolvo=0, string3[90];
    for(new i; i != LoadAllCar; i++)
	{
		if(!strcmp(cInfo[i][cOwner],pInfo[playerid][pName],true))
		{
			SetPVarInt(playerid,"cmenuid",i);
			kolvo++;
			format:str_small("" #C_GRAY "%d.{ffffff} %s [%s%s%s%s%s%s]\n",kolvo,GetCarMark(cInfo[i][cModel]),cInfo[i][cNumber],cInfo[i][cNumber2],cInfo[i][cNumber3],cInfo[i][cNumber4],cInfo[i][cNumber5],cInfo[i][cNumber6]);
			if(cInfo[i][cArrest]==1) format:str_small("" #C_GRAY "%d.{ffffff} %s [%s%s%s%s%s%s] - {992F2F}�/�\n",kolvo,GetCarMark(cInfo[i][cModel]),cInfo[i][cNumber],cInfo[i][cNumber2],cInfo[i][cNumber3],cInfo[i][cNumber4],cInfo[i][cNumber5],cInfo[i][cNumber6]);
			strcat(str_big,str_small);
		}
	}

	if(GetPVarInt(playerid,"cmenuid")==-1) return SCM(playerid,-1,"�� �� ������� ������ ��");

	f(string3),"" #C_GRAY "���������� ���� %s",GetCarMark(cInfo[GetPVarInt(playerid,"cmenuid")][cModel]));

	if(cInfo[GetPVarInt(playerid,"cmenuid")][cArrest]==1)
	{
		format:str_small("" #C_GRAY "���������� ���� %s - {992F2F}�/�",GetCarMark(cInfo[GetPVarInt(playerid,"cmenuid")][cModel]));
	}

	if(kolvo==1 && cInfo[GetPVarInt(playerid,"cmenuid")][cArrest]==1) // ���� ���������� � �� ��
	{
		SPD(playerid,dCar,list,string3,"" #C_GRAY "1.{FFFFFF} ����������","��","�������");
		return 1;
	}

	if(kolvo==1) // ���� ����������
	{
		SPD(playerid,dCar,list,str_small,"" #C_GRAY "1.{FFFFFF} ����������\n" #C_GRAY "2.{FFFFFF} ������������\n" #C_GRAY "3.{FFFFFF} ����� \n" #C_GRAY "4.{FFFFFF} ����������\n" #C_GRAY "5.{FFFFFF} ����������� �����\n" #C_GRAY "6.{FFFFFF} �����","��","�������");
		return 1;
	}
	
	SPD(playerid,dCar+3,list,"" #C_GRAY "���� ����������",str_big,"��","�������");
	
	str_big[0] = EOS;
	str_small[0] = EOS;
	
	return 1;
}

// TODO

CMD:park( playerid )
{
	if( !IsPlayerInAnyVehicle( playerid ) )
		return SCM( playerid, -1, !"��� ������������� ������ �������, �� ������ ���������� � ����������." );

	new 
		vehicleid = GetPlayerVehicleID( playerid );

 	if(IsOwnerCar(playerid, vehicleid)) return 1;

	ParkVehicle( playerid, vehicleid);

	SCM( playerid, -1, !"�� ������� ������������ ���������." );
	return 1;
}

IsOwnerCar( playerid, vehicleid )
{
	new bool:found = false;

	for(new i; i != LoadAllCar; i++)
	{
		if( vehicleid == cInfo[i][cCar] )
		{
		    if(!strcmp(cInfo[i][cOwner],pInfo[playerid][pName],true)) found = true;
		}
	}
	if(found == false) return SCM(playerid,-1,"�� �� ��������� ���������� ������� ����������!");
	return false;
}

ParkVehicle( playerid, vehicleid)
{
	new i;
	
	for(new iz; iz != LoadAllCar; iz++)
	{
		if( vehicleid == cInfo[iz][cCar] )
		{
			i = iz;
			ChangeVehiclePaintjob( cInfo[iz][cCar], cInfo[iz][cPrint] );
		}
	}

	new Float:hp,
	    p, d, l, t;
	    
 	new Float:pba;
    pba = milleage[vehicleid];

	GetVehicleHealth(vehicleid,hp);
	GetVehicleDamageStatus(vehicleid, p, d, l, t);
	ChangeVehiclePaintjob( vehicleid, cInfo[i][cPrint] );
	GetVehiclePos( vehicleid, cInfo[i][cPos][0], cInfo[i][cPos][1], cInfo[i][cPos][2] );
	GetVehicleZAngle( vehicleid, cInfo[i][cPos][3] );
	
	//cInfo[i][cVirt] = GetVehicleVirtualWorld( vehicleid );
	cInfo[i][cVirt] = GetPlayerVirtualWorld( playerid );

	mysql_format:str_big( "UPDATE `" #DB_CARS "` SET `X` = '%f', `Y` = '%f', `Z` = '%f', `F` = '%f', `virt` = '%d' WHERE `ID` = '%d'",
		cInfo[i][cPos][0],
		cInfo[i][cPos][1],
		cInfo[i][cPos][2],
		cInfo[i][cPos][3],
		cInfo[i][cVirt],
		cInfo[i][cID]
	);

	mysql_tquery( mysql_connect_ID, str_big, "", "" );

   	DeleteCarAttach( i );
	DestroyVehicle( vehicleid );
	cInfo[i][cCar] = CreateVehicle( 
			cInfo[i][cModel],
			cInfo[i][cPos][0],
			cInfo[i][cPos][1],
			cInfo[i][cPos][2],
			cInfo[i][cPos][3],
			cInfo[i][cColor][0],
			cInfo[i][cColor][1],
			-1
	);
	
	SetVehicleVirtualWorld( cInfo[i][cCar], cInfo[i][cVirt] );
	ChangeVehiclePaintjob( cInfo[i][cCar], cInfo[i][cPrint] );
	LoadCarAttach( i, 0 );
	
	SetVehicleHealth(cInfo[i][cCar],hp);
	
	UpdateVehicleDamageStatus(cInfo[i][cCar], p, d, l, t);
	
	PutPlayerInVehicle( playerid, cInfo[i][cCar], 0 );
	
	milleage[vehicleid] = pba;
} 

CMD:okno(playerid,params[])
{
        if(GetPlayerState(playerid) != 2) return SendClientMessage(playerid,-1,"�� �� �� ������������ �����!");
        if(sscanf(params, "d", params[0]))
        {
                SendClientMessage(playerid,-1,"/window [id ����]");
                SendClientMessage(playerid,-1,"1 - ������������ | 2 - ������������(��������) | 3 - ������(�����) | 4 - ������(������)");
                return 1;
        }
        if(params[0] > 4 || params[0] < 1) return SendClientMessage(playerid,-1,"1 - ������������ | 2 - ������������(��������) | 3 - ������(�����) | 4 - ������(������)");
        new driver, passenger, backleft, backright;
        GetVehicleParamsCarWindows(GetPlayerVehicleID(playerid), driver, passenger, backleft, backright);
        switch(params[0])
        {
            case 1: driver = !driver ? (1) : (0);
            case 2: passenger = !passenger ? (1) : (0);
            case 3: backleft = !backleft ? (1) : (0);
            case 4: backright = !backright ? (1) : (0);
        }
        SetVehicleParamsCarWindows(GetPlayerVehicleID(playerid), driver, passenger, backleft, backright);
        return 1;
}

CMD:window(playerid, params[])
{
    if(!IsPlayerInAnyVehicle(playerid) || GetPlayerState(playerid) != PLAYER_STATE_DRIVER) return 1;

    extract params -> new type; else return SendClientMessage(playerid, 0xcececeFF, "�����������: {ffffff} /window [���] < ����: 1 - ������������ | 2 - ������������ (�������) | 3 - ������ (�����) | 4 - ������ (������) >");

    new vehicleid = GetPlayerVehicleID(playerid),
        driver,
        passenger,
        backleft,
        backright;

    GetVehicleParamsCarWindows(vehicleid, driver, passenger, backleft, backright);

    switch(type)
    {
        case 1: driver = !driver ? (1) : (0);
        case 2: passenger = !passenger ? (1) : (0);
        case 3: backleft = !backleft ? (1) : (0);
        case 4: backright = !backright ? (1) : (0);
    }

    SetVehicleParamsCarWindows(vehicleid, driver, passenger, backleft, backright);

    return 1;
}

CMD:dn(playerid, params[])
{
	if(IsAdmin(playerid, 2)) return 1;
	if(sscanf(params, "d", params[0])) return SCM(playerid, COLOR_WHITE, "�����������: /down [�������]");
	new Float:pos1,Float:pos2,Float:pos3; GetPlayerPos(playerid,pos1,pos2,pos3);
	SetPlayerPos(playerid,pos1,pos2,pos3-params[0]);
	return 1;
}

CMD:up(playerid, params[])
{
	if(IsAdmin(playerid, 2)) return 1;
	if(sscanf(params, "d", params[0])) return SCM(playerid, COLOR_WHITE, "�����������: /up [�������]");
	new Float:pos1,Float:pos2,Float:pos3; GetPlayerPos(playerid,pos1,pos2,pos3);
	SetPlayerPos(playerid,pos1,pos2,pos3+params[0]);
	return 1;
}

CMD:lt(playerid, params[])
{
	if(IsAdmin(playerid, 2)) return 1;
	if(sscanf(params, "d", params[0])) return SCM(playerid, COLOR_WHITE, "�����������: /left [�������]");
	new Float:pos1,Float:pos2,Float:pos3; GetPlayerPos(playerid,pos1,pos2,pos3);
	SetPlayerPos(playerid,pos1-params[0],pos2,pos3);
	return 1;
}

CMD:rt(playerid, params[])
{
	if(IsAdmin(playerid, 2)) return 1;
	if(sscanf(params, "d", params[0])) return SCM(playerid, COLOR_WHITE, "�����������: /right [�������]");
	new Float:pos1,Float:pos2,Float:pos3; GetPlayerPos(playerid,pos1,pos2,pos3);
	SetPlayerPos(playerid,pos1+params[0],pos2,pos3);
	return 1;
}

CMD:nametag(playerid, params[])
{
	if(sscanf(params, "d", params[0])) return SCM(playerid, COLOR_WHITE, "�����������: /nametag [1 ��� 2]");
	if(params[0]==1) { for(new i = 0; i < MAX_PLAYERS; i++) ShowPlayerNameTagForPlayer(playerid, i, 0); }
	if(params[0]==2) { for(new i = 0; i < MAX_PLAYERS; i++) ShowPlayerNameTagForPlayer(playerid, i, 1); }
	return 1;
}

