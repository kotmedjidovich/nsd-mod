    str_big[0] = EOS;
    
    return 1;
}

SaveCinventory(i)
{
    ClearVar();

    mysql_format:str_big("UPDATE `" #DB_CARS "` SET `cInvSlots` = '%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d' WHERE `ID` = '%d'",
    cInv[i][cinvSlot][0],cInv[i][cinvSlot][1],cInv[i][cinvSlot][2],cInv[i][cinvSlot][3],cInv[i][cinvSlot][4],cInv[i][cinvSlot][5],cInv[i][cinvSlot][6],cInv[i][cinvSlot][7],cInv[i][cinvSlot][8],cInv[i][cinvSlot][9],
	cInv[i][cinvSlot][10],cInv[i][cinvSlot][11],cInv[i][cinvSlot][12],cInv[i][cinvSlot][13],cInv[i][cinvSlot][14],cInfo[i][cID]);
    mysql_function_query(mysql_connect_ID, str_big, false, "", "");
    
    str_big[0] = EOS;

    mysql_format:str_big("UPDATE `" #DB_CARS "` SET `cInvSlotsKol` = '%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d|%d' WHERE `ID` = '%d'",
    cInv[i][cinvSlotKol][0],cInv[i][cinvSlotKol][1],cInv[i][cinvSlotKol][2],cInv[i][cinvSlotKol][3],cInv[i][cinvSlotKol][4],cInv[i][cinvSlotKol][5],cInv[i][cinvSlotKol][6],cInv[i][cinvSlotKol][7],cInv[i][cinvSlotKol][8],cInv[i][cinvSlotKol][9],
	cInv[i][cinvSlotKol][10],cInv[i][cinvSlotKol][11],cInv[i][cinvSlotKol][12],cInv[i][cinvSlotKol][13],cInv[i][cinvSlotKol][14],cInfo[i][cID]);
