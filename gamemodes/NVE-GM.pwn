CMD:setgametime(playerid, params[])
{
    if(IsAdmin(playerid, 5)) return 1;
    if(sscanf(params, "dd", params[0],params[1])) return SCM(playerid, COLOR_WHITE, "�����������: /settime [�� ������] [����� �� �������]");
   	if( !IsPlayerLogged( params[0] ) ) return SCM( playerid, COLOR_DARK_GRAY, !INCORRECT_PLAYER_ID );
    pInfo[params[0]][pGame]=params[1]; SendMes(playerid,-1,"�� �������� ����� ������ %s",pInfo[params[0]][pName]);
    mysql_format:str_small("UPDATE `" #DB_ACCOUNTS "` SET `Game` = '%d' WHERE `Name` = '%s'",pInfo[params[0]][pGame],pInfo[params[0]][pName]);
    mysql_function_query(mysql_connect_ID, str_small, false, "", "");
	return 1;
