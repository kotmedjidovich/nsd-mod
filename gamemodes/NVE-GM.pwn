CMD:firest(playerid)
{
	if(IsAdmin(playerid, 3)) return 1;
	new online;
 	if(allads >= 10) return SCM(playerid,-1,"� ������ ������ ��������� ���� ��� ������ ���������� - ���");
  	foreach(Player, i) if(pInfo[i][pFrak] == 7) online++;
  	if(online == 0) return SCM(playerid,-1,"� ������ ������ ���������� ��� - ���");
	SPD(playerid,dReporter,list,"" #C_GRAY "�������� ����������","" #C_GRAY "1. " #C_WHITE "������ ����������\n" #C_GRAY "2. " #C_WHITE "������","��","�������");
	return 1;
}

