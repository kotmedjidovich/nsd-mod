CheckDelay(playerid)
{
	mysql_format:str_small("SELECT * FROM `" #DB_MSG "` WHERE AcID = '%d'",pInfo[playerid][pID]);
	return mysql_function_query(mysql_connect_ID, str_small, true, "ShowDelayMessages", "d", playerid);
}

public:ShowDelayMessages(playerid)
{
    new rows, fields;
    cache_get_data(rows, fields);
    
    if(rows)
    {
        new
			id;
			
        while(--rows >= 0)
        {
            str_small[0] = EOS;
           	str_cmd[0] = EOS;
        
            cache_get_field_content(rows,"Text",str_small);
            
            id = cache_get_field_content_int(rows,"ID");
            
            format:str_cmd("%s",str_small);
            SCM( playerid, -1, str_cmd );
            
            str_small[0] = EOS;
			str_cmd[0] = EOS;
			
			mysql_format:str_small("DELETE FROM `" #DB_MSG "` WHERE `ID` = '%d'", id);
			mysql_function_query(mysql_connect_ID, str_small, false, "", "");
			
			str_small[0] = EOS;
        }
    }
    
    return 1;
}

CreateDelayMessages(id,text[])
{
    str_big[0] = EOS;

	mysql_format:str_big( "\
	INSERT INTO `" #DB_MSG "` \
		(`AcID`, `Text`) \
	VALUES \
		('%d', '%s')",
	id,
	text
	);

	mysql_function_query(mysql_connect_ID, str_big, false, "", "");
	
	str_big[0] = EOS;
	
	return 1;
}

public:CheckTicketsKol(playerid)
{
    new rows, fields, kol;
    cache_get_data(rows, fields);
    if(rows)
    {
        while(--rows >= 0)
        {
           kol++;
        }
    }
	if( kol != 0 ) return SCM(playerid, -1,"�������� ��� ���� ������, ����� �������� ��������� ����!");
    return SPD(playerid,dFrak+7,list,"" #C_GRAY "��������� ����","" #C_GRAY "1. {FFFFFF}��������� A [15.000�]\n" #C_GRAY "2. {FFFFFF}��������� B [24.000�]\n" #C_GRAY "3. {FFFFFF}��������� C [30.000�]\n" #C_GRAY "4. {FFFFFF}��������� D [28.000�]","�����","�������");
}

