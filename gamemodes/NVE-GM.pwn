	return 1;
}

public OnVehicleDeath(vehicleid, killerid)
{
	if(siren[vehicleid] != 0)
 	{
 		if(IsValidDynamicObject(sirenobj[vehicleid]))
		{
		 	DestroyDynamicObjected(sirenobj[vehicleid]),
	 		siren[vehicleid] = 0,
	 		sirenobj[vehicleid] = 0;
	 	}
  	}
  	
  	Gas[vehicleid] = 50.0;
	
	for( new i; i != LoadAllCar; i++ )
	{
		if( vehicleid == cInfo[i][cCar] )
		{
			cInfo[i][cHealth] = 400.0;
			cInfo[i][cEngine] = 1;
			GetVehicleDamageStatus(cInfo[i][cCar], cInfo[i][cDamage][0], cInfo[i][cDamage][1], cInfo[i][cDamage][2], cInfo[i][cDamage][3]);
			DestroyDynamicObjected( nomer_zad[i] ), DestroyDynamicObjected( nomer_pered[i] );
			mysql_format:str_big( "UPDATE `" #DB_CARS "` SET `health` = '%f', `damage` = '%d|%d|%d|%d', `engine` = '%d' WHERE `ID` = '%d'",
					cInfo[i][cHealth],
					cInfo[i][cDamage][0],
					cInfo[i][cDamage][1],
					cInfo[i][cDamage][2],
					cInfo[i][cDamage][3],
					cInfo[i][cEngine],
					cInfo[i][cID]
					);

			mysql_tquery( mysql_connect_ID, str_big, "", "" );
			break;
		}
	}
	
	return 1;
}

