public OnVehicleDamageStatusUpdate(vehicleid, playerid)
{
	for( new i; i != LoadAllCar; i++ )
	{
	    if(vehicleid == cInfo[i][cCar])
	    {
			if( cInfo[i][cEngine] == 1 )
			{
				SetVehicleHealth(cInfo[i][cCar], 400.0);
				cInfo[i][cHealth] = 400.0;
				
				mysql_format:str_big( "UPDATE `" #DB_CARS "` SET `health` = '%f', `damage` = '%d|%d|%d|%d', `engine` = '%d' WHERE `ID` = '%d'",
				cInfo[i][cHealth],
				cInfo[i][cDamage][0],
				cInfo[i][cDamage][1],
				cInfo[i][cDamage][2],
				cInfo[i][cDamage][3],
				cInfo[i][cEngine],
				cInfo[i][cID]
				);

				mysql_tquery( mysql_connect_ID, str_big, "", "" );
				
				break;
			}
	        new engine,lights,alarm,doors,bonnet,boot,objective;
			GetVehicleParamsEx(cInfo[i][cCar],engine,lights,alarm,doors,bonnet,boot,objective);
        	
	        GetVehicleHealth(cInfo[i][cCar], cInfo[i][cHealth]);
	        GetVehicleDamageStatus(cInfo[i][cCar], cInfo[i][cDamage][0], cInfo[i][cDamage][1], cInfo[i][cDamage][2], cInfo[i][cDamage][3]);
	        
	        if(cInfo[i][cHealth] <= 400.0)
		    {
				if( cInfo[i][cHealth] == 0 )
				{
					cInfo[i][cEngine] = 0;
					cInfo[i][cHealth] = 1000.0;
					SetVehicleHealth( cInfo[i][cCar], 1000.0 );
					break;
				}
				
		    	cInfo[i][cEngine] = 1;
		        SetVehicleHealth(cInfo[i][cCar], 400.0);
				if(GetPlayerVehicleID(playerid) == cInfo[i][cCar]) SCM(playerid, -1, "" #C_ORANGE "��������� ���������� ������!");
				SetVehicleParamsEx(cInfo[i][cCar],0,lights,alarm,doors,bonnet,boot,objective);
				
				mysql_format:str_big( "UPDATE `" #DB_CARS "` SET `health` = '%f', `damage` = '%d|%d|%d|%d', `engine` = '%d' WHERE `ID` = '%d'",
				cInfo[i][cHealth],
				cInfo[i][cDamage][0],
				cInfo[i][cDamage][1],
				cInfo[i][cDamage][2],
				cInfo[i][cDamage][3],
				cInfo[i][cEngine],
				cInfo[i][cID]
				);

				mysql_tquery( mysql_connect_ID, str_big, "", "" );
				
				break;
		    }
		    
	        break;
	    }
	}
    return 1;
}

public OnPlayerEnterCheckpoint(playerid)
