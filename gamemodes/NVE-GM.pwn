				SetPVarInt( playerid, "carkey", cInfo[ i ][ cCar ] );

				SendMes( playerid, -1, "" #C_GRAY "%s ������� ��� ����� �� %s. " #C_WHITE "��������� ������� /lock, /lockb", pInfo[ id ][ pName ], GetCarMark( cInfo[ i ][ cModel ] ) );
				SendMes( id, -1, "�� ������� �������� ����� �� " #C_GRAY "%s " #C_WHITE "������ " #C_GRAY "%s. " #C_WHITE "������� ����� ����� ����� /cmenu", GetCarMark( cInfo[ i ][ cModel ] ), pInfo[ playerid ][ pName ] );
				
				format:str_small( "* %s ������� �����",pInfo[id][pName]);
