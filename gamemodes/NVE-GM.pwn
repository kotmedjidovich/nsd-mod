					GetDynamicObjectRot( cInfo[ car ][ cAttachID ][ i ], pos1, pos1, fRotZ );
					
					ofaz = fRotZ-roz;
					
					SetDynamicObjectRot( cInfo[ car ][ cAttachID ][ i ], 0.0, 0.0, ofaz );

					cInfo[ car ][ cObjectInv ][ i ] = _invPlayer[playerid][invSlot][GetPVarInt(playerid,"selectSlotAttach")];
					
					cInfo[ car ][ cAttachObject ][ i ] = _itemsInfo[_invPlayer[playerid][invSlot][GetPVarInt(playerid,"selectSlotAttach")]][invObject];

