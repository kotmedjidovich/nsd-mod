CMD:id(playerid, params[])
{
    if(sscanf(params, "s[24]", params[0])) return SCM(playerid, COLOR_WHITE, "�����������: /id [Nick_Name]");
    
    if( strlen( params[0] ) > 24 ) return SCM(playerid, -1, "������� ������� ���");
    
    new num;
    
	foreach(Player, i)
	{
	   	if(strfind(pInfo[i][pName], params[0], true) !=-1)
	   	{
            if(!strcmp(params[0],pInfo[i][pName],true))
            {
                pformat:( ""C_GRAY"%s {ffffff}[%d]", pInfo[i][pName], i);
				psend:( playerid, COLOR_WHITE );
				num++;
                break;
            }
	   	    if(i == 0) SCM(playerid,-1,"��� ��������� ����������:");
		   	if(num >= 5) break;
			num++;
		   	pformat:( ""C_GRAY"%s {ffffff}[%d]", pInfo[i][pName], i);
			psend:( playerid, COLOR_WHITE );
	   	}
	}
	if(num == 0) return SCM(playerid,-1,"���������� �� �������!");
	
	return 1;
}

CMD:report(playerid, params[])
{
    if(sscanf(params, "s[428]", params[0])) return SCM(playerid, COLOR_WHITE, "�����������: /report [�����]");
   	format:str_big("{E2F43D}[REPORT] %s[%d]{ffffff}: %s",pInfo[playerid][pName],playerid,params[0]), SAM(COLOR_WHITE, str_big), SCM(playerid, COLOR_WHITE, str_big);
	return 1;
}

CMD:attachlist(playerid)
{
    for(new i; i != 3; i ++)
	{
		if(aObj[playerid][aSlot][i]==0)
		{
			format:str_small("" #C_ABILITY "%d.{ffffff} �����\n",i+1), strcat(str_cmd, str_small);
			continue;
		}
		format:str_small("" #C_GRAY "[%d]{ffffff} %s | %s\n",i+1,GetBoneName(aObj[playerid][aBone][i]),GetObjName(aObj[playerid][aObject][i]));
        strcat(str_cmd, str_small);
	}
	SPD(playerid,dInv+5,list,"{658c6a}����� ��������� ���������",str_cmd,"��","�����");
	str_cmd[0] = EOS;
	str_small[0] = EOS;
	return 1;
}

CMD:damages(playerid, p[])
{
	if(sscanf(p, "d", p[0])) return SCM(playerid, COLOR_WHITE, "�����������: /damages [�� ������]");
	
	if(GetPVarInt(playerid,"death") == 0) return SCM(playerid, -1, "����� �� ����� ������� ��� ����������� ������!");
	
    new zzs[20];
    new te[10][10];

    for(new i; i != 10; i ++)
	{
		if(dInfo[p[0]][dGun][i]!=0 && dInfo[p[0]][dType][i]!=0)
		{
			if(dInfo[p[0]][dType][i]==1) f(zzs),"�������");
			if(dInfo[p[0]][dType][i]==2) f(zzs),"������");
			sscanf(dInfo[p[0]][dTime], "p<|>s[6]s[6]s[6]s[6]s[6]s[6]s[6]s[6]s[6]s[6]",
			te[0],te[1],te[2],te[3],te[4],te[5],te[6],te[7],te[8],te[9]);

			if(strlen(te[i])>6 || strlen(te[i])==0) continue;
			format:str_small("[%s] %s �� %s\n",te[i],zzs,GetGunName(dInfo[p[0]][dGun][i]));
			//SCM(playerid,-13534,str);
	        strcat(str_cmd, str_small);
		}
	}
	SPD(playerid,d_null,list,"" #C_GRAY "����������",str_cmd,"��","");
	str_cmd[0] = EOS;
	str_small[0] = EOS;
	return 1;
}

CMD:accdeath(playerid)
{
	if(GetPVarInt(playerid,"death")!=2) return 1;
	DeletePVar(playerid,"death");
	for(new i; i != 10; i ++) { dInfo[playerid][dGun][i]=0, dInfo[playerid][dTime][i]=0, dInfo[playerid][dType][i]=0; }
	DestroyDynamic3DPlayer( dtext[playerid], playerid );
	SCM(playerid,0x7FFF66FF,"�� ������� ����������� ���. ������ � ��� ��������, � ������ ���� ��� �� ���� \"��\", �������� ������ ��������");
	SendMes(playerid,0x7FFF66FF,"��� ������ �� �������� %d ������",pInfo[playerid][pMoney]*20/100);
	pInfo[playerid][pMoney]-=pInfo[playerid][pMoney]*20/100;
	ClearDeathPlayer(playerid), DeletePVar(playerid, "death");
	SpawnPlayer(playerid), SaveMoney(playerid), setPlayerHealth(playerid,100.0);
	return 1;
}

CMD:givecarkey(playerid)
{
	if(GetPVarInt(playerid,"AntiFlood") > gettime()) return SCM(playerid, COLOR_WHITE, "��������������: " #C_GRAY "�� ������� !");
    for(new i; i != LoadAllCar; i++)
	{
		if(!strcmp(cInfo[i][cOwner],pInfo[playerid][pName],true))
		{
			SPD( playerid, dCar+20, list, "" #C_GRAY "���������� ������� ��","\
			" #C_GRAY "1.{ffffff} ������ �����\n\
			" #C_GRAY "2.{ffffff} ������� �����","��","�������");
  		}
	}
	return 1;
}

CMD:lock(playerid)
{
	if(GetPVarInt(playerid,"AntiFlood") > gettime()) return SCM(playerid, COLOR_WHITE, "��������������: " #C_GRAY "�� ������� !");

    for(new i; i != LoadAllCar; i++)
	{
		if(!strcmp(cInfo[i][cOwner],pInfo[playerid][pName],true))
		{
			new Float:pos1,Float:pos2,Float:pos3;
			GetVehiclePos(cInfo[i][cCar],pos1,pos2,pos3);
			if(IsPlayerInRangeOfPoint(playerid, 4.0,pos1,pos2,pos3)) { if(cInfo[i][cLock]==1) { CarLock(i,0,1),GameTextForPlayer(playerid, "~g~�������", 500, 3), PlayerPlaySound(playerid, 2001, 0.0, 0.0, 0.0); return 1; } else { CarLock(i,1,1), GameTextForPlayer(playerid, "~r~�������", 500, 3), PlayerPlaySound(playerid, 2001, 0.0, 0.0, 0.0); return 1; } }
		}
		else if( cInfo[ i ][ cOrg ] == pInfo[ playerid ][ pOrg ][ 0 ] && cInfo[ i ][ cOrg ] != 0 )
		{
			new Float:pos1,Float:pos2,Float:pos3;
			GetVehiclePos(cInfo[i][cCar],pos1,pos2,pos3);
			if(IsPlayerInRangeOfPoint(playerid, 4.0,pos1,pos2,pos3)) { if(cInfo[i][cLock]==1) { CarLock(i,0,1),GameTextForPlayer(playerid, "~g~�������", 500, 3), PlayerPlaySound(playerid, 2001, 0.0, 0.0, 0.0); return 1; } else { CarLock(i,1,1), GameTextForPlayer(playerid, "~r~�������", 500, 3), PlayerPlaySound(playerid, 2001, 0.0, 0.0, 0.0); return 1; } }
		}
		else if( cInfo[ i ][ cCar ] == GetPVarInt( playerid, "carkey" ) )
		{
			new Float:pos1,Float:pos2,Float:pos3;
			GetVehiclePos(cInfo[i][cCar],pos1,pos2,pos3);
			if(IsPlayerInRangeOfPoint(playerid, 4.0,pos1,pos2,pos3)) { if(cInfo[i][cLock]==1) { CarLock(i,0,1),GameTextForPlayer(playerid, "~g~�������", 500, 3), PlayerPlaySound(playerid, 2001, 0.0, 0.0, 0.0); return 1; } else { CarLock(i,1,1), GameTextForPlayer(playerid, "~r~�������", 500, 3), PlayerPlaySound(playerid, 2001, 0.0, 0.0, 0.0); return 1; } }
		}
	}

	for(new i; i != LoadAllNed; i++)
	{
		if(!strcmp(nInfo[i][nOwner],pInfo[playerid][pName],true))
		{
			if( nInfo[ i ][ nPick ][ 0 ] == 0.0 )
			{
				continue;
			}


			if(IsPlayerInRangeOfPoint(playerid, 4.0,nInfo[i][nPick][0],nInfo[i][nPick][0],nInfo[i][nPick][0]) || IsPlayerInRangeOfPoint(playerid, 4.0,nInfo[i][nExite][0],nInfo[i][nExite][0],nInfo[i][nExite][0]))
			{
				if(nInfo[i][nLock]==0)
				{
					nInfo[i][nLock]=1;
					pformat:( "�� ������� ������� ������������");
					GameTextForPlayer(playerid, "~r~�������", 500, 3);
				}
				else
				{
				 	nInfo[i][nLock]=0;
				 	pformat:( "�� ������� ������� ������������");
				 	GameTextForPlayer(playerid, "~y~�������", 500, 3);
				 }

				mysql_format:str_small( "UPDATE `" #DB_PROPERTY "` SET `lock` = '%d' WHERE `ID` = '%d'",nInfo[i][nLock], nInfo[i][nID]);
				mysql_function_query(mysql_connect_ID, str_small, false, "", "");
				break;
			}
		}

	}

	return SetPVarInt(playerid,"AntiFlood",gettime() + 1);
}
CMD:lockb(playerid)
{
	new gg;
    for(new i; i != LoadAllCar; i++)
	{
		if(!strcmp(cInfo[i][cOwner],pInfo[playerid][pName],true))
		{
		    new Float:pos1, Float:pos2, Float:pos3;
			gg++;
		 	new engine,lights,alarm,doors,bonnet,boot,objective, cars = cInfo[i][cCar];
		 	GetVehicleParamsEx(cars,engine,lights,alarm,doors,bonnet,boot,objective);

			GetBonnetVehiclePos(cars, pos1,pos2,pos3); // ��������
			if(IsPlayerInRangeOfPoint(playerid,2.1, pos1,pos2,pos3))
			{
				if(cInfo[i][cLockb]==0)
				{
					cInfo[i][cLockb] = 1, GameTextForPlayer(playerid, "~g~�������", 500, 3);
 					//BonnetCar[cars] = 1;
     				//SetVehicleParamsEx(cars,engine,lights,alarm,doors,bonnet,1,objective);
     				SetPlayerChatBubble(playerid,"������ �������� ����������",0xAF5DD2FF,30.0,10000);
				}
				else
				{
					cInfo[i][cLockb] = 0, GameTextForPlayer(playerid, "~r~�������", 500, 3);
 					if(boot == 1) SetVehicleParamsEx(cars,engine,lights,alarm,doors,bonnet,0,objective), BonnetCar[cars] = 0;
 					SetPlayerChatBubble(playerid,"������ �������� ����������",0xAF5DD2FF,30.0,10000);
				}
				return mysql_format:str_small("UPDATE `" #DB_CARS "` SET `lockb` = '%d' WHERE `ID` = '%d'",cInfo[i][cLockb],cInfo[i][cID]),
	 		           mysql_function_query(mysql_connect_ID, str_small, false, "", "");
			}
		}
		
		else if( cInfo[ i ][ cCar ] == GetPVarInt( playerid, "carkey" ) )
		{
		    new Float:pos1, Float:pos2, Float:pos3;
			gg++;
		 	new engine,lights,alarm,doors,bonnet,boot,objective, cars = cInfo[i][cCar];
		 	GetVehicleParamsEx(cars,engine,lights,alarm,doors,bonnet,boot,objective);

			GetBonnetVehiclePos(cars, pos1,pos2,pos3); // ��������
			if(IsPlayerInRangeOfPoint(playerid,2.1, pos1,pos2,pos3))
			{
				if(cInfo[i][cLockb]==0)
				{
					cInfo[i][cLockb] = 1, GameTextForPlayer(playerid, "~g~�������", 500, 3);
 					//BonnetCar[cars] = 1;
     				//SetVehicleParamsEx(cars,engine,lights,alarm,doors,bonnet,1,objective);
     				SetPlayerChatBubble(playerid,"������ �������� ����������",0xAF5DD2FF,30.0,10000);
				}
				else
				{
					cInfo[i][cLockb] = 0, GameTextForPlayer(playerid, "~r~�������", 500, 3);
 					if(boot == 1) SetVehicleParamsEx(cars,engine,lights,alarm,doors,bonnet,0,objective), BonnetCar[cars] = 0;
 					SetPlayerChatBubble(playerid,"������ �������� ����������",0xAF5DD2FF,30.0,10000);
				}
				return mysql_format:str_small("UPDATE `" #DB_CARS "` SET `lockb` = '%d' WHERE `ID` = '%d'",cInfo[i][cLockb],cInfo[i][cID]),
	 		           mysql_function_query(mysql_connect_ID, str_small, false, "", "");
			}
		}

		
	}
	if(gg>0) return SCM(playerid,-1,"�� ������ ���������� ����� ���������");
	if(gg==0) return SCM(playerid,-1,"� ��� ��� ������� ����");
	return 1;
}

