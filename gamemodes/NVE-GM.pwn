CMD:taxi(playerid)
{
	new bool:found = false;

    for( new i; i != 10; i++ )
	{
		if(_invPlayer[playerid][invSlot][i] == 413) found = true;
	}

	if(found == true)
	{
		if( GetPVarInt( playerid, "taxi" ) == 1 )
		{
		    SCM( playerid, -1, "�� ��������� ����� ���������� �����!" );
		    DeletePVar( playerid, "taxi" );
		}
		else
		{
			SCM( playerid, -1, "{FFD918}�� �������� ����� ���������� �����" );
			SCM( playerid, -1, "�������� ��������� ��� ����������� ��� ������������ " #C_GRAY "- /tmenu" );
			SetPVarInt( playerid, "taxi", 1 );
		}
	}
	else
	{
	    return SCM( playerid, -1, "� ��� � ��������� ��� �����!" );
	}
	return 1;
}

CMD:tinfo(playerid)
{
	if(GetPVarInt(playerid,"taxi")==1 && GetPVarInt(playerid,"taxitype")!=0)
	{
		format:str_small("" #C_GRAY "��� ������� ��������:\t {ffffff}%s\n" #C_GRAY "��������:\t {ffffff}%d ���",pInfo[playerid][pName],GetPVarInt(playerid,"zarplata"));
		SPD(playerid,dJob+13,info,"" #C_GRAY "���������� �� ������",str_small,"����","�������");
	}
	else
	{
		SCM(playerid,-1,"��� �������");
	}
	return 1;
}

CMD:animlist(playerid)
{
    if(GetPlayerAnimationIndex(playerid) == 1189 || GetPlayerAnimationIndex(playerid) == 1275 || GetPlayerAnimationIndex(playerid) == 1186)
    {
		SPD(playerid,dMenu+7,list,"" #C_GRAY "���� ��������","" #C_GRAY "1. {ffffff}�������� 1\n" #C_GRAY "2. {ffffff}�������� 2\n" #C_GRAY "3. {ffffff}�������� 3\n" #C_GRAY "4. {ffffff}�������� 4\n" #C_GRAY "5. {ffffff}�������� 5","�������","�������");
		SCM(playerid, COLOR_WHITE, "�������������� ��������: {AEAEAE}/animhelp");
	}
	return 1;
}

