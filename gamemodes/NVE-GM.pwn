CMD:savecars(playerid)
{
	if(IsAdmin(playerid, 5)) return 1;
	for( new za; za != LoadAllCar; za++ )
	{
 		if(cInfo[za][cCar] == INVALID_VEHICLE_ID) continue;
 		
		mysql_format:str_big("UPDATE `" #DB_CARS "` SET `milleage` = '%f', `health` = '%f', `damage` = '%d|%d|%d|%d' WHERE `ID` = '%d'", milleage[cInfo[za][cCar]], cInfo[za][cHealth], cInfo[za][cDamage][0],cInfo[za][cDamage][1],cInfo[za][cDamage][2],cInfo[za][cDamage][3], cInfo[za][cID]);
		mysql_function_query(mysql_connect_ID, str_big, false, "", "");
	}
	return 1;
}

