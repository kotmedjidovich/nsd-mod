public OnPlayerSelectedMenuRow(playerid, row)
{
	if(pInfo[playerid][pAdmin] < 1) return 1;
    new Menu:Current = GetPlayerMenu(playerid);
    
	if(Current == spec)
	{
	    new
			specid,
	        specid2 = GetPVarInt( playerid, "spectable" ),
			maxid = GetPlayersID(1),
			minid = GetPlayersID(0);
   			
	    switch(row)
	    {
	        case 0: // NEXT
	        {
				for(new id = specid2; id != maxid+1; id ++)
				{
					if( id > maxid )
					{
						specid = minid;
	        			break;
					}
				
    				if( IsPlayerConnected(id) && specid2 != id && GetPVarInt(id,"spec") != 1 && GetPVarInt(id,"gLogged") == 1 )
    				{
	        			specid = id;
	        			break;
    				}
				}
				
				if( specid == specid2 )
				{
					return SCM(playerid, -1, "�� ������� ��� ������ �������!"), Specon(playerid, specid);
				}

				DeletePVar(playerid,"spec"), HideMenuForPlayer(spec,playerid),
				DeletePVar(playerid,"spectable");
				
				Specon(playerid, specid);
     			
			    return 1;
	        }
	        
	        case 1: // BACK
	        {
				for(new id = specid2; id != maxid; id-- )
				{
				    if( id < minid )
				    {
				    	specid = maxid;
	        			break;
				    }
				    
        			if( IsPlayerConnected(id) && specid2 != id && GetPVarInt(id,"spec") != 1 && GetPVarInt(id,"gLogged") == 1 )
    				{
	        			specid = id;
	        			break;
    				}
				}

                if( specid == specid2 )
				{
					return SCM(playerid, -1, "�� ������� ��� ������ �������!"), Specon(playerid, specid);
				}

				DeletePVar(playerid,"spec"), HideMenuForPlayer(spec,playerid),
				DeletePVar(playerid,"spectable");
				
				Specon(playerid, specid);
				
			    return 1;
	        }
	        
	        case 2: // stats
	        {
	            if(!IsPlayerConnected(specid2) || ( specid2 == playerid) || GetPVarInt(specid2,"spec") == 1) return SCM(playerid,-1,"ID ������ �� �������!");
	            statsa(specid2,playerid);
	        }
	        
	        case 3: // inv
	        {
	            if(!IsPlayerConnected(specid2) || ( specid2 == playerid) || GetPVarInt(specid2,"spec") == 1) return SCM(playerid,-1,"ID ������ �� �������!");
	            ShowInva(specid2,playerid);
	            
	        }
	        
	        case 4: // slap
	        {
             	if(!IsPlayerConnected(specid2) || ( specid2 == playerid) || GetPVarInt(specid2,"spec") == 1) return SCM(playerid,-1,"ID ������ �� �������!");
	            format:str_least("%d", GetPVarInt(playerid,"spectable") );
				cmd::slap(playerid, str_least);
	        }

	        case 5: // exit
	        {
	        	if(GetPVarInt(playerid,"spec") == 1)
			    {
					return Specoff(playerid);
				}
	        }
	    }
	    return 1;
	}
	return 1;
}

