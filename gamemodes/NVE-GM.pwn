	    if(!IsPlayerConnected(p[0])) return SCM(playerid,-1,"������ � ����� ID ��� �� �������");
	    new Float:p1,Float:p2,Float:p3; GetPlayerPos(p[0],p1,p2,p3);
		if(!IsPlayerInRangeOfPoint(playerid, 15.0,p1,p2,p3)) return SCM(playerid,-1,"�� ������ ���������� ����� ������, � �������� �� ������ ������ �����");
