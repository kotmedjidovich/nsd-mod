	ApplyAnimation(playerid, "PED","KO_shot_stom",4.1,0,1,1,1,1,1);
 	return 1;
}

CMD:tpcor(playerid, params[])
{
    if(IsAdmin(playerid, 3)) return SCM(playerid,-1,"�� �� ������������ ������������ ��� �������.");
    new Float: coorx,Float: coory,Float: coorz;
    if(sscanf(params, "fff", coorx,coory,coorz)) return SCM(playerid, -1, "�����������: /tpcor x y z");
    return SetPlayerPos(playerid,coorx,coory,coorz);
}

CMD:st(playerid, params[])
{
    if(IsAdmin(playerid, 2)) return SCM(playerid,-1,"�� �� ������������ ������������ ��� �������.");
    if(sscanf(params, "d", params[0])) return SCM(playerid,-1,"�����������: /st [�� ������ �������� ������ ������� �� ������]");
	if(GetPVarInt(params[0],"death")!=2) return 1;
	{
		DeletePVar(params[0],"death");
		pformat:( "������������� "C_GRAY"%s[%d]"C_WHITE" ����� ��� �� ������!", pInfo[playerid][pName], playerid );
		psend:( params[0], COLOR_WHITE );
		pformat:( "�� ������ "C_GRAY"%s[%d]"C_WHITE" �� ������!", pInfo[params[0]][pName], params[0] );
		psend:( playerid, COLOR_WHITE );
		ClearDeathPlayer(params[0]), DeletePVar(params[0], "death");
	}
	return 1;
}

CMD:nedit(playerid, params[])
{
	if(IsAdmin(playerid, 5)) return 1;
	if(sscanf(params, "d", params[0])) return SCM(playerid,-1,"�����������: /nedit [����� ������������]");
	if(params[0]>LoadAllNed) return SCM(playerid,-1,"�� ����� 0");
	format:str_cmd("{FF3300}�������������� ������������ %d",params[0]); SetPVarInt(playerid,"redn",params[0]);
	SPD(playerid,dNed+9,list,str_cmd,"{FF3300}1. {ffffff}����������\n{FF3300}2. {ffffff}�������/�������\n{FF3300}3. {ffffff}�������� ����\n{FF3300}4. {ffffff}�������� ���������\n{FF3300}5. {ffffff}�������� ���\n{FF3300}6. {ffffff}�������� ��������\n{FF3300}7. {ffffff}�������� ����� �����\n{FF3300}8. {ffffff}�������� ����� ������\n{FF3300}9. {ffffff}�������� ����� ������\n{FF3300}10. {ffffff}�������� ����� ������ �������/�����\n{FF3300}11. {ffffff}�������� ����� ���������","��","�������");
	return 1;
}

CMD:setoffice(playerid, params[])
{
    if(IsAdmin(playerid, 5)) return 1;
    
	if(sscanf(params, "dd", params[0], params[1])) return SCM(playerid,-1,"�����������: /setoffice [����� ������������] [����� ����� (1-6)]");
	
	if(params[0]>LoadAllNed) return SCM(playerid,-1,"������������ ����� ������������");

	params[1] --;
	
	if(!(0 <= params[1] <= sizeof g_office_pos - 1)) return SCM(playerid, -1, "����� ����� �� 1 �� 6");
	
	nInfo[params[0]][nExite][0] = g_office_pos[params[1]][0];
	nInfo[params[0]][nExite][1] = g_office_pos[params[1]][1];
	nInfo[params[0]][nExite][2] = g_office_pos[params[1]][2];
	
	UpdateProperty(params[0], 1);
	
	SCM(playerid, -1, "�������� ����� �������");
	
	return 1;
}

CMD:testi(playerid, params[])
{
	if(IsAdmin(playerid, 5)) return 1;
	if(sscanf(params, "f", Float:params[0] )) return SCM(playerid,-1,"�����������: /testi [X]");

	SendMes( playerid, -1, "%f",params[0]);
	SetVehicleZAngle(GetPlayerVehicleID(playerid), params[0]);

	return 1;
}

CMD:nint(playerid, params[])
{
	if(IsAdmin(playerid, 5)) return 1;
	if(sscanf(params, "dfff", params[0], Float:params[1], Float:params[2], Float:params[3]  )) return SCM(playerid,-1,"�����������: /nint [����� ������������] [X] [Y] [Z]");
	if(params[0]>LoadAllNed) return SCM(playerid,-1,"�� ����� 0");
	
	nInfo[ params[0] ][ nExite ][ 0 ] = params[1];
	nInfo[ params[0] ][ nExite ][ 1 ] = params[2];
	nInfo[ params[0] ][ nExite ][ 2 ] = params[3];
	
	UpdateProperty( params[0], 1 );
	
	return 1;
}

CMD:dice(playerid)//Tamasita*
{
    new bool:found = false,iddd;
    for( new i; i != 10; i++ )
	{
		if(_invPlayer[playerid][invSlot][i] == 410) found = true, iddd = i;
	}
	if(found == true)
	{
	    new vbros = random(1000);
	    if(vbros > 500 && vbros < 550)
	    {
	        _invPlayer[playerid][invSlotKol][iddd]--;
	        if(_invPlayer[playerid][invSlotKol][iddd] <= 0) _invPlayer[playerid][invSlot][iddd] = 0;
	        if(GetPVarInt(playerid,"mask") != 0) format:str_small( "* �����[%d] ������ ��� ������������ ������ �� ������� ������ {ffffff}\"%d\"{AF5DD2}, � ������ ����-�� ��������",GetPVarInt(playerid,"mask"), random(6)+1, random(6)+1);
			else format:str_small( "* %s ������ ��� ������������ ������ �� ������� ������ {ffffff}\"%d\"{AF5DD2}, � ������ ����-�� ��������",pInfo[playerid][pName], random(6)+1, random(6)+1);
			ProxDetector(20.0,playerid,str_small,0xAF5DD2FF,0xAF5DD2FF,0xAF5DD2FF,0xAF5DD2FF,0xAF5DD2FF);
			SetPlayerChatBubble(playerid,str_small,0xAF5DD2FF,30.0,10000);
	    	return 1;
	    }
		if(GetPVarInt(playerid,"mask") != 0) format:str_small( "* �����[%d] ������ ��� ������������ ������ �� ������� ������ {ffffff}\"%d\"{AF5DD2} � {ffffff}\"%d\"",GetPVarInt(playerid,"mask"), random(6)+1, random(6)+1);
		else format:str_small( "* %s ������ ��� ������������ ������ �� ������� ������ {ffffff}\"%d\"{AF5DD2} � {ffffff}\"%d\"",pInfo[playerid][pName], random(6)+1, random(6)+1);
		ProxDetector(20.0,playerid,str_small,0xAF5DD2FF,0xAF5DD2FF,0xAF5DD2FF,0xAF5DD2FF,0xAF5DD2FF);
		SetPlayerChatBubble(playerid,str_small,0xAF5DD2FF,30.0,10000);
	}
	else return SCM(playerid,-1,"� ��� ��� ��������� ������");
	return 1;
}
CMD:cedit(playerid, params[])
{
	if(IsAdmin(playerid, 5)) return 1;
	if(sscanf(params, "d", params[0])) return SCM(playerid,-1,"�����������: /cedit [id ����������]");
	
	new bool:found = false;
	
	for(new i; i != LoadAllCar; i ++)
	{
		if(cInfo[i][cCar] == params[0])
		{
			SetPVarInt(playerid,"redc",i); found = true; break;
		}
	}
	
	if(found == false) return SCM(playerid,-1,"��������� ID ���������� �� �������� ������");
	
	format:str_cmd("{FF3300}�������������� ���������� �� %d",GetPVarInt(playerid,"redc"));
	SPD(playerid,dAdmin+5,list,str_cmd,"{FF3300}1. {ffffff}����������\n{FF3300}2. {ffffff}�������� ���������\n{FF3300}3. {ffffff}�������� ����\n{FF3300}4. {ffffff}�������� ������\n{FF3300}5. {ffffff}�������� �������\n{FF3300}6. {ffffff}�������� ������\n{FF3300}7. {ffffff}�������� �����������\n{FF3300}8. {ffffff}�������������\n{FF3300}9. {ffffff}�������/�������\n{FF3300}10. {ffffff}���������/��������� �������\n{FF3300}11. {ffffff}�������","��","�������");
	return 1;
}

