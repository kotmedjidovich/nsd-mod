	TextDrawSetOutline(Logotype[playerid], 0);
    TextDrawFont(Logotype[playerid], 4);
    TextDrawShowForPlayer(playerid, Logotype[playerid]);

	new c,m;
	gettime(c,m,_);
	SetPlayerTime(playerid,c,m);

    PreloadAnimLib(playerid,"CRACK");
    PreloadAnimLib(playerid,"WEAPONS");
    PreloadAnimLib(playerid,"GANGS");
    PreloadAnimLib(playerid,"MISC");
    PreloadAnimLib(playerid,"PED");
    SetPlayerArmour(playerid,0.0);
	TogglePlayerSpectating(playerid,0);
    if(GetPVarInt(playerid,"duty") == 0) SetPlayerSkin(playerid, pInfo[playerid][pChart][1]);
    if(GetPVarInt(playerid,"duty") == 1) SetPlayerSkin(playerid,pInfo[playerid][pFrakskin]);

    if(pInfo[playerid][pFrakskin] != 0) // �������������� ���������
    {
        if(pInfo[playerid][pFrak] != 0)
        {
	        SetPlayerSkin(playerid,pInfo[playerid][pFrakskin]);
	        SetPVarInt(playerid,"duty",1);
			SCM(playerid,-1,"" #C_ORANGE "{c13f3f}���� ��������� ���� ������������� ����� ���������� ������ � �������");
		}
		else
		{
		 	mysql_format:str_small("UPDATE `" #DB_ACCOUNTS "` SET `Fskin` = '0' WHERE `ID` = '%d'",pInfo[playerid][pID]);
			mysql_function_query(mysql_connect_ID, str_small, false, "", "");
			str_small[0] = EOS;
			pInfo[playerid][pFrakskin] = 0;
		}
    }

    //probar[playerid][0] = CreateProgressBar(549.00, 27.00, 57.50, 3.50, -1048321, 100.0); probar[playerid][1] = CreateProgressBar(548.00, 41.00, 57.50, 3.50, 10682282, 100.0);
    //for(new n; n < 2; n++) ShowProgressBarForPlayer(playerid, probar[playerid][n]), TextDrawShowForPlayer(playerid,protext[n]);
    //potreb[0]=100.0; potreb[1]=100.0;
    //////////////////     �������/������ //////////////////////////////////////
    new hour,minute,second; gettime(hour,minute,second);
    if(GetPVarInt(playerid,"death")==1 && GetPVarInt(playerid,"spawn")==1)
    {
        SetPlayerTime(playerid,hour,minute);
        if(GetPVarInt(playerid,"duty") == 1) SetPlayerSkin(playerid, pInfo[playerid][pFrakskin]);
        if(GetPVarInt(playerid,"duty") == 0) SetPlayerSkin(playerid, pInfo[playerid][pChart][1]);
        new kolvo;
	    for(new i; i !=10; i++) { if(dInfo[playerid][dGun][i] != 0) { kolvo++; } }
	    format:str_small("(( ���� ����� ��� ����� %d ���(�). ��� ��������� ��������� ���������� �������: /damages %d ))",kolvo,playerid);
	    dtext[playerid] = CreateDynamic3DTextLabel(str_small, 0xAF5DD2FF, 0.0, 0.0, 2.0, 5.0, playerid, INVALID_VEHICLE_ID,1,-1,-1,-1,5.0);
	    SetPlayerHealth(playerid, 20.0);
		kolvo=0;
		SetPlayerPos(playerid, pInfo[playerid][pCor][0], pInfo[playerid][pCor][1], pInfo[playerid][pCor][2]);
		new anim = random(7);
		if(anim==0) ApplyAnimation(playerid, "CRACK", "crckdeth2", 4.1, 0, 0, 0, 1, 0);
		if(anim==1) ApplyAnimationIndex(playerid, 385, 4.1, 0, 0, 0, 1, 0);
		if(anim==2) ApplyAnimationIndex(playerid, 387, 4.1, 0, 0, 0, 1, 0);
		if(anim==3) ApplyAnimationIndex(playerid, 388, 4.1, 0, 0, 0, 1, 0);
		if(anim==4) ApplyAnimationIndex(playerid, 389, 4.1, 0, 0, 0, 1, 0);
		if(anim==5) ApplyAnimationIndex(playerid, 390, 4.1, 0, 0, 0, 1, 0);
		if(anim==6) ApplyAnimationIndex(playerid, 392, 4.1, 0, 0, 0, 1, 0);
		SCM(playerid,0xCF3F3FAA,"��� ���������� ��������� ����������� ������ ������, ������� ������ ������� ��� ��� ����������� ������");
		SCM(playerid,0xCF3F3FAA,"���� �� ��������, ��� ��� ����� � ���������� ������ �������, �������� �� ���� ������������� ������� � �������� ������ �� �����");
		return 1;
	}
    if(GetPVarInt(playerid,"death")==2 && GetPVarInt(playerid,"spawn")==1)
	{
        SetPlayerTime(playerid,hour,minute);
        if(GetPVarInt(playerid,"duty") == 1) SetPlayerSkin(playerid, pInfo[playerid][pFrakskin]);
        if(GetPVarInt(playerid,"duty") == 0) SetPlayerSkin(playerid, pInfo[playerid][pChart][1]);
		format:str_small("(( ������ ����� �����, ��� ��������� ���������� /damages %d ))",playerid);
	    dtext[playerid] = CreateDynamic3DTextLabel(str_small, 0xAF5DD2FF, 0.0, 0.0, 2.0, 5.0, playerid, INVALID_VEHICLE_ID,1,-1,-1,-1,5.0);
		SetPlayerPos(playerid, pInfo[playerid][pCor][0], pInfo[playerid][pCor][1], pInfo[playerid][pCor][2]), ApplyAnimation(playerid, "PED", "KO_shot_front", 4.1, 0, 0, 0, 1, 0);
	    SCM(playerid,0xCF3F3FAA,"�� ���� ����� � ��� ������������� \"��\"");
	    SCM(playerid,0xCF3F3FAA,"��� �������� ������ �������: /accdeath");
		return 1;
	}
	////////////////////////////////////////////////////////////////////////////
	if( GetPVarInt(playerid,"death") == 0) DestroyDynamic3DPlayer( dtext[playerid], playerid );

	if(pInfo[playerid][pArrest]!=0 && GetPVarInt(playerid,"gLogged")==1) // �����
	{
		SetPlayerPosF(playerid, 472.4010,364.1892,13.1928,341.9814);
		SCM( playerid, -1, "���� ���������� �����. ��� ��������� �� ���");
        SetPVarInt(playerid,"spawn",1);
	}
	if(pInfo[playerid][pPos][0]==0.0) return SetPlayerPosF(playerid, 781.1750,1535.3135,-2.2303,90.0000), SetPVarInt(playerid,"spawn",1);
	if(GetPVarInt(playerid,"spawns")==3) return SetPlayerPosF(playerid, 781.1750,1535.3135,-2.2303,90.0000), SetPVarInt(playerid,"spawn",1);
	if(GetPVarInt(playerid,"spawns")==2) return SetPlayerPosF(playerid,pInfo[playerid][pPos][0],pInfo[playerid][pPos][1],pInfo[playerid][pPos][2],pInfo[playerid][pPos][3]), SetPlayerVirtualWorld(playerid,pInfo[playerid][pVirt]), pInfo[playerid][pVirt]=0, SetPVarInt(playerid,"spawn",1);
    if(GetPVarInt(playerid,"spawns")==4) return SetPlayerPosF(playerid,nInfo[pInfo[playerid][pHspawn]-1][nSpawn][0],nInfo[pInfo[playerid][pHspawn]-1][nSpawn][1],nInfo[pInfo[playerid][pHspawn]-1][nSpawn][2],0), SetPlayerVirtualWorld(playerid,nInfo[pInfo[playerid][pHspawn]-1][nInt]), SetPVarInt(playerid,"spawn",1);
    if(GetPVarInt(playerid,"spawns")==5)
	{
		if(pInfo[playerid][pFrak]==1) return SetPlayerPosF(playerid, 1714.5957,1721.6190,2.1692,90.0000), SetPVarInt(playerid,"spawn",1); // ����
		if(pInfo[playerid][pFrak]==2) return SetPlayerPosF(playerid, 2360.3850,-2368.7495,22.0949,180.0000), SetPVarInt(playerid,"spawn",1); // �����
		if(pInfo[playerid][pFrak]==3) return SetPlayerPosF(playerid, 2354.3669,-2354.9199,21.9718,90.0000), SetPVarInt(playerid,"spawn",1); // ������
		if(pInfo[playerid][pFrak]==4) return SetPlayerPosF(playerid, -2474.5835,1657.5858,52.4678,277.6623), SetPVarInt(playerid,"spawn",1); // �������������
		if(pInfo[playerid][pFrak]==5) return SetPlayerPosF(playerid, 175.6570,-552.8993,1002.9900,360.0000), SetPVarInt(playerid,"spawn",1); // ���
		if(pInfo[playerid][pFrak]==6) return SetPlayerPosF(playerid, 382.8708,331.7416,1003.9100,360.0000), SetPVarInt(playerid,"spawn",1); // ���
		if(pInfo[playerid][pFrak]==7) return SetPlayerPosF(playerid, 2363.6965,-2629.5479,1003.0000,1.2698), SetPVarInt(playerid,"spawn",1), ac_GivePlayerWeapon(playerid,43,999); //���
		if(pInfo[playerid][pOrg][0] > 0)
		{
		    for(new i; i != LoadAllNed; i++)
			{
				if(oInfo[ pInfo[playerid][pOrg] ][oNed] == 0)
				{
					SCM(playerid,-1,"� ����� ����������� ��� ������!");
					break;
				}
			    if(oInfo[ pInfo[playerid][pOrg] ][oNed] == i)
			    {
			        if(nInfo[i][nSpawn][0] != 0.0)
			        {
			            SetPlayerPosF(playerid, nInfo[i][nSpawn][0], nInfo[i][nSpawn][1], nInfo[i][nSpawn][2],0);
						SetPlayerVirtualWorld(playerid,nInfo[i][nInt]);
						SetPVarInt(playerid,"spawn",1);
						return 1;
			        }
			    }
			}
		}
	}

	SetPlayerPosF(playerid, 781.1750,1535.3135,-2.2303,90.0000), SetPVarInt(playerid,"spawn",1), SetPlayerVirtualWorld(playerid,0);
	
	new nickname[MAX_PLAYER_NAME];
	GetPlayerName(playerid, nickname, sizeof(nickname));
	cef_emit_event(playerid, 1, "classic:hud:update", CEFINT(pInfo[playerid][pCash]), CEFINT(pInfo[playerid][pBank]), CEFSTR(nickname), CEFINT(playerid));
	
	return 1;
}

public: SpeedoUpdate()
{
    foreach(Player, i)
    {
        if(GetPVarInt(i, "gLogged") == 0) continue;
        if(GetPVarInt(i, "nospeed") == 1) continue;
        if(GetPVarInt(i, "jobg") == 1) continue;
        if(GetPVarInt(i, "jobs") == 1) continue;
        new vehicleid = GetPlayerVehicleID(i);
		new engine,lights,alarm,doors,bonnet,boot,objective;
		GetVehicleParamsEx(vehicleid,engine,lights,alarm,doors,bonnet,boot,objective);
        if(IsPlayerConnected(i) && IsPlayerInAnyVehicle(i) && !IsVelo(vehicleid) && GetPlayerVehicleSeat(i)==0)
        {
            new Float:x,Float:y,Float:z,Float:hp,string[24],string2[24],string3[24]; GetVehicleVelocity(vehicleid,x,y,z); GetVehicleHealth(vehicleid,hp);
			new speed = floatround(floatsqroot(((x*x)+(y*y))+(z*z))*101.666667);
			new Float:mille = speed/5000.0;
			milleage[vehicleid] += mille;
  			if(speed > 300)
			{
				ac_Kick(i,2);
				continue;
			}
            format(string,sizeof(string),"%d",speed);
            PlayerTextDrawSetString(i, Speedmetr2[i],string);
            format(string2,sizeof(string2),"%.1f �",Gas[vehicleid]);
            TextDrawSetString(Speedmetr12[i],string2);
            format(string3,sizeof(string3),"%.3f ��",milleage[vehicleid]);
            TextDrawSetString(Speedmetr11[i],string3);
    	    if(hp < 600) TextDrawColor(Speedmetr10[i], 0x658c6aAA);
		    else TextDrawColor(Speedmetr10[i], 0xFFFFFFAA);
  		    if(doors==1) TextDrawColor(Speedmetr4[i], 0x658c6aAA);
    	    else TextDrawColor(Speedmetr4[i], 0xFFFFFFAA);
    	    if(lights==1) TextDrawColor(Speedmetr3[i], 0x658c6aAA);
    	    else TextDrawColor(Speedmetr3[i], 0xFFFFFFAA);
    	    if(EngineCar[vehicleid] == 1) TextDrawColor(Speedmetr8[i], 0x658c6aAA);
    	    else TextDrawColor(Speedmetr8[i], 0xFFFFFFAA);
    	    if(VehInfos[vehicleid][vRightBlink] == 0) TextDrawColor(Speedmetr5[i], 0x658c6aAA);
    	    else TextDrawColor(Speedmetr5[i], 0xFFFFFFAA);
    	    if(VehInfos[vehicleid][vLeftBlink] == 0) TextDrawColor(Speedmetr6[i], 0x658c6aAA);
    	    else TextDrawColor(Speedmetr6[i], 0xFFFFFFAA);
    	    if(VehInfos[vehicleid][vAvary] == 1) TextDrawColor(Speedmetr5[i], 0x658c6aAA), TextDrawColor(Speedmetr6[i], 0x658c6aAA);
    	    else TextDrawColor(Speedmetr5[i], 0xFFFFFFAA), TextDrawColor(Speedmetr6[i], 0xFFFFFFAA);
			if(Gas[vehicleid] >= 40 && Gas[vehicleid] <= 50) TextDrawColor(Speedmetr12[i], 0x658c6aAA);
			else if(Gas[vehicleid] >= 0 && Gas[vehicleid] <= 5) TextDrawColor(Speedmetr12[i], 0xf41700AA);
			else if(Gas[vehicleid] >= 0 && Gas[vehicleid] <= 1.0) TextDrawColor(Speedmetr12[i], 0xff0000AA), SCM(i,COLOR_WHITE,"��������� ������. ��� - ����!");
			ShowSpeedo(i);
		}
		if(!IsPlayerInAnyVehicle(i)) HideSpeedo(i);
    }
	return 1;
}

forward Player_Control(playerid);
public Player_Control(playerid)
{
   	if(MUSICACTIVE == true && activemusic[playerid] == false && IsPlayerInRangeOfPoint(playerid, MUSICDIST, MUSICX, MUSICY, MUSICZ))
    {
		if(PlayerMusic[playerid] == true)
		{
           PlayAudioStreamForPlayer(playerid, MUSICURL, MUSICX, MUSICY, MUSICZ,MUSICDIST, 1);
    	   activemusic[playerid] = true;
 		   SendClientMessage(playerid, COLOR_WHITE, "�� ������ � ���� ������������ ������.");
 		   SendClientMessage(playerid, COLOR_WHITE, "�� ��������� �������������, �������� ���������� ��������� ������� ����.");
 		   SendClientMessage(playerid, COLOR_WHITE, "� �����, ��������, ����� ������������ ����������� �����.");
 		}
    }
    if(MUSICACTIVE == true && activemusic[playerid] == true && !IsPlayerInRangeOfPoint(playerid, MUSICDIST, MUSICX, MUSICY, MUSICZ))
    {
        if(PlayerMusic[playerid] == true)
		{
    	   activemusic[playerid] = false;
     	   StopAudioStreamForPlayer(playerid);
     	   SendClientMessage(playerid, COLOR_WHITE, "�� �������� ���� ������������� ������!");
		}
    }
	return 1;
}

public: povorotnik()
{
    foreach(Player, i)
	{
        new vehicleid = GetPlayerVehicleID(i);
        if(IsPlayerConnected(i) && IsPlayerInAnyVehicle(i) && VehInfos[vehicleid][vAvary] == 1 || VehInfos[vehicleid][vRightBlink] == 1 || VehInfos[vehicleid][vLeftBlink] == 1)
        {
		    PlayerPlaySound(i, 0, 0.0, 0.0, 0.0), PlayerPlaySound(i, 2019, 0.0, 0.0, 0.0);
		    if(VehInfos[vehicleid][vRightBlink] == 1) TextDrawColor(Speedmetr5[i], 0x658c6aAA);
		    if(VehInfos[vehicleid][vLeftBlink] == 1) TextDrawColor(Speedmetr6[i], 0x658c6aAA), TextDrawColor(Speedmetr6[i], 0x658c6aAA);
		    if(VehInfos[vehicleid][vAvary] == 1) TextDrawColor(Speedmetr5[i], 0x658c6aAA), TextDrawColor(Speedmetr6[i], 0x658c6aAA);
		}
		else
		{
            TextDrawColor(Speedmetr5[i], 0xFFFFFFAA);
            TextDrawColor(Speedmetr6[i], 0xFFFFFFAA);
            PlayerPlaySound(i, 0, 0.0, 0.0, 0.0);
		}
    }
	return 1;
}

public: ALTTEXT()
{
    foreach(Player, i)
	{
        TogglePlayerControllable(i, true);
    }
	return 1;
}

public: vehhealth()
{
	for(new i; i != LoadAllCar; i++)
	{
        new vehicleid = GetPlayerVehicleID(i);
        GetVehicleHealth(vehicleid, v_health);
        if(v_health < 380.0)
        {
            SetVehicleHealth(vehicleid, 400);
        }
        if(cInfo[i][cHealth] < 380.0)
        {
            cInfo[i][cHealth] = 400.0;
            SetVehicleHealth(cInfo[i][cCar], 400);
        }
	}
	return 1;
}

