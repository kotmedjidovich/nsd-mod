konec(playerid)
{
	if(IsPlayerInAnyVehicle(playerid)) RemovePlayerFromVehicle(playerid);
	if(GetPVarInt(playerid,"idtruck")!=0) SetVehicleToRespawn(GetPVarInt(playerid,"idtruck")), DeletePVar(playerid,"idtruck");
	if(pricep[playerid]!=0) DestroyVehicle(pricep[playerid]), pricep[playerid]=EOS;
	DeletePVar(playerid,"truck"),DeletePVar(playerid,"zarplata"),DeletePVar(playerid,"deltruck"),DeletePVar(playerid,"razgruz"),DeletePVar(playerid,"reys"), SPD(playerid,d_null,info,"{D8D8D8}����������","{ffffff}������� ���� �������","�������",""), ttruck--, DisablePlayerCheckpoint(playerid), DeletePVar(playerid,"deltruck");
	format:str_least("[ ��������: {FFFFFF}%d/10 " #C_GRAY "]",ttruck),UpdateDynamic3DTextLabelText(t3dtext,0x00A2FFFF,str_least);
	if(ttime[1]==playerid) ttime[0]=0, ttime[1]=0;
	return 1;
}

ShowRegCharacterInfo( playerid, id, delemitor = 60 )
{
    str_big[0] = EOS;

	//strunpack( str_big, pInfo[playerid][pRegCharacter] );

	for( new i, k = 1, j = strlen( str_big ); i < j; i++ )
	{
		if( i == k * delemitor )
		{
			for( new x = i; x < j; x++ )
			{
				str_big[x + 1] = str_big[x];
			}

			str_big[i] = '\n';
			k++;
		}
	}

	str_cmd[0] = EOS;
	strcat( str_cmd, pInfo[playerid][pName] );

	return SPD( id, d_null, DIALOG_STYLE_MSGBOX, str_cmd, str_big, "�������", "" ), str_cmd[0] = EOS, str_big[0] = EOS;
}

IsSpace(playerid, id)
{
    new bool:itemkol = false, bool:itemv = false;

	for(new i; i != 10; i++)
	{
		if(_invPlayer[playerid][invSlot][i] == 0)
		{
			itemkol = true;
		}

		if(itemv==false)
		{
			for(new z; z != 11; z++)
			{
				if(_invPlayer[playerid][invSlot][z] == id) itemkol = true;
			}
			itemv=true;
		}
	}
	if(itemkol == false) return SCM(playerid,-1,!"� ��� ������������ ����� ��� ����� ��������!");
	return false;
}

