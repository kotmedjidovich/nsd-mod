CMD:delveh(playerid, params[])
{
	if(IsAdmin(playerid, 4)) return 1;
	if(sscanf(params, "d", params[0])) return SCM(playerid, COLOR_WHITE, "�����������: /delveh [id ����]");
	if(!admin_vehicle{params[0]}) return SCM(playerid, COLOR_DARK_GRAY, "������� ����� ��� ���������, ������� ��� ������ ����������������");
	admin_vehicle{params[0]} = 0;
	DestroyVehicle(params[0]);
	return 1;
}

CMD:veh(playerid, params[])
{
	if(IsAdmin(playerid, 6)) return 1;
	if(sscanf(params, "ddd", params[0],params[1],params[2])) return SCM(playerid, COLOR_WHITE, "�����������: /veh [������ ����] [���� 1] [���� 2]");
	
	if( params[0] > 612 || params[0] < 400 ) return SCM( playerid, -1, "ID ���������� �� ������ 612 � �� ������ 400");
	
	new Float:x, Float:y, Float:z;
	
	GetPlayerPos(playerid, x, y, z); 

	new
		car = CreateVehicle(params[0], x, y, z+0.5, 0.0, params[1], params[2], 9999);
		
	PutPlayerInVehicle( playerid, car, 0 );
	
	admin_vehicle{car} = 1;
	
	EngineCar[car] = 0;

	Gas[car] = 50.0;
	return 1;
}

CMD:veha(playerid, params[])
{
	if(IsAdmin(playerid, 5)) return 1;
	if(sscanf(params, "ddd", params[0],params[1],params[2])) return SCM(playerid, COLOR_WHITE, "�����������: /veh [������ ����] [���� 1] [���� 2]");

	if( params[0] > 611 || params[0] < 400 ) return SCM( playerid, -1, "ID ���������� �� ������ 611 � �� ������ 400");

	new Float:x, Float:y, Float:z;

	GetPlayerPos(playerid, x, y, z);

	new
		car = CreateVehicle(params[0], x+1.0, y, z+2.0, 0.0, params[1], params[2], 9999);

	admin_vehicle{car} = 1;

	EngineCar[car] = 0;

	Gas[car] = 50.0;

	return 1;
}

CMD:ahelp(playerid)
{
	if(IsAdmin(playerid, 1)) return 1;
	str_big[0] = EOS;
	if( pInfo[playerid][pAdmin] >= 1 ) strcat( str_big, ""C_GRAY"1 �������:"C_WHITE"\n/a, /ans, /kick, /mute, /unmute, /spec, /spawn, /freeze, /unfreeze, /gotocar, /sethp, /unarrest, /fixcar, /stats, /checkmask, /onj, /slap, /goto, /checkip, /checkcar, /checkned" );
	if( pInfo[playerid][pAdmin] >= 2 ) strcat( str_big, "\n\n"C_GRAY"2 �������:"C_WHITE"\n/tp, /paint, /st, /gotoint, /weather, /getcar, /gethere, /setsex, /loadcnum, /checkinv, /setarmor" );
	if( pInfo[playerid][pAdmin] >= 3 ) strcat( str_big, "\n\n"C_GRAY"3 �������:"C_WHITE"\n/aclearchat, /ban, /unban, /unbanip, /setskin, /o, /gotoned, /setname" );
	if( pInfo[playerid][pAdmin] >= 4 ) strcat( str_big, "\n\n"C_GRAY"4 �������:"C_WHITE"\n/kick, /mute, /unmute, /banip, /iban, /weapon /setint" );
	if( pInfo[playerid][pAdmin] >= 5 ) strcat( str_big, "\n\n"C_GRAY"5 �������:"C_WHITE"\n/restart, /veh(a), /delveh, /giveitem, /givelic, /settime, /setmoney, /gravity, /setpos, /makeleader, /givevip, /gunoff" );
	if( pInfo[playerid][pAdmin] >= 6 ) strcat( str_big, "\n\n"C_GRAY"6 �������:"C_WHITE"\n/makeleader, /createorg" );
	if( pInfo[playerid][pAdmin] >= 7 ) strcat( str_big, "\n\n"C_GRAY"7 �������:"C_WHITE"\n/makeadmin" );
	ShowPlayerDialog( playerid, d_null, DIALOG_STYLE_MSGBOX, "������� �����������������", str_big, "�������", "" );
	str_big[0] = EOS;
	return 1;
}

CMD:cc(playerid)
{
	if(IsAdmin(playerid, 3)) return 1;
	for(new i; i < 25; i++) SendClientMessageToAll(0xFFFFFFFF,"");
	return 1;
}

CMD:restart(playerid, params[])
{
    if( IsAdmin( playerid, 7 ) ) return 1;
	
    SendClientMessageToAll( -1, "" #C_GRAY "��������� ������! ���������� ������� �������" );
	SendClientMessageToAll( -1, "" #C_GRAY "���������� ����������������, ����� ���������� ����" );
	
	foreach( Player, i ) Kick( i );
	
	return GameModeExit( );
	
}

CMD:unwarn(playerid, params[])
{
    if(IsAdmin(playerid, 2)) return 1;
    if(sscanf(params, "u", params[0])) return SCM(playerid, COLOR_WHITE, "�����������: /unwarn [��]");
    if( !IsPlayerLogged( params[0] ) ) return SCM( playerid, COLOR_DARK_GRAY, !INCORRECT_PLAYER_ID );
    
    if(pInfo[params[0]][pWarn] == 0) return SCM(playerid,-1,"� ������ ��� ������!");

	pInfo[params[0]][pWarn]-=1;
	
	pformat:( "������������� " #C_GRAY "%s {ffffff}���� � ��� ���� �������������� " #C_GRAY "(%d/3)", pInfo[playerid][pName],pInfo[params[0]][pWarn]);
	psend:( params[0], -1 );
	
	pformat:( "�� ����� � ������ " #C_GRAY "%s {ffffff}���� �������������� " #C_GRAY "(%d/3)", pInfo[params[0]][pName],pInfo[params[0]][pWarn]);
	psend:( playerid, -1 );

   	mysql_format:str_small( "UPDATE `" #DB_ACCOUNTS "` SET `Warn` = %d WHERE `Name` = '%s'",
   		pInfo[params[0]][pWarn],
   		pInfo[params[0]][pName]
   	);
   	mysql_function_query( mysql_connect_ID, str_small, false, "", "");

	return 1;
}

CMD:makeadmin(playerid, params[])
{
    if(IsAdmin(playerid, 7)) return 1;
    if(sscanf(params, "ud", params[0],params[1])) return SCM(playerid, COLOR_WHITE, "�����������: /makeadmin [��] [admin-lvl]");
    if( !IsPlayerLogged( params[0] ) ) return SCM( playerid, COLOR_DARK_GRAY, !INCORRECT_PLAYER_ID );
    
    pformat:( "�� �������� ��������������� " #C_GRAY "%s {ffffff} ������ " #C_GRAY "%d", pInfo[params[0]][pName],params[1]);
	psend:( playerid, -1 );

	pInfo[params[0]][pAdmin]=params[1];

   	mysql_format:str_small( "UPDATE `" #DB_ACCOUNTS "` SET `Admin` = %d WHERE `ID` = '%d'",
   		pInfo[params[0]][pAdmin],
   		pInfo[params[0]][pID]
   	);

   	mysql_function_query( mysql_connect_ID, str_small, false, "", "");

	return 1;
}

CMD:warn(playerid, params[])
{
    if(IsAdmin(playerid, 2)) return 1;
    if(sscanf(params, "us[60]", params[0],params[1])) return SCM(playerid, COLOR_WHITE, "�����������: /warn [��] [�������]");
    if( !IsPlayerLogged( params[0] ) ) return SCM( playerid, COLOR_DARK_GRAY, !INCORRECT_PLAYER_ID );
    
    pInfo[params[0]][pWarn]+=1;
	
	format:str_cmd( "������������� %s ����� �������������� ������ %s (%d/3). �������: %s",pInfo[playerid][pName],pInfo[params[0]][pName], pInfo[params[0]][pWarn],params[1]);
	SendClientMessageToAll( COLOR_LIGHT_RED, str_cmd);

   	mysql_format:str_small( "UPDATE `" #DB_ACCOUNTS "` SET `Warn` = %d WHERE `Name` = '%s'",
   		pInfo[params[0]][pWarn],
   		pInfo[params[0]][pName]
   	);
   	mysql_function_query( mysql_connect_ID, str_small, false, "", "");
   	
   	if(pInfo[params[0]][pWarn]==3)
   	{
   	    format:str_cmd( "%s ������������ �� 7 ����",pInfo[params[0]][pName]);
		SendClientMessageToAll( COLOR_LIGHT_RED, str_cmd);
		mysql_format:str_small( "UPDATE `" #DB_ACCOUNTS "` SET `Ban` = '%d', `Warn` = '0'  WHERE `Name` = '%s'",
   		gettime() + 7 * 86400,
   		pInfo[params[0]][pName]
   		);
   		mysql_function_query( mysql_connect_ID, str_small, false, "", "");
   		Kick(params[0]);
   	}

	return 1;
}

CMD:checkinv(playerid, params[])
{
    if(IsAdmin(playerid, 2)) return 1;
    if(sscanf(params, "u", params[0])) return SCM(playerid, COLOR_WHITE, "�����������: /checkinv [��]");
    if( !IsPlayerLogged( params[0] ) ) return SCM( playerid, COLOR_DARK_GRAY, !INCORRECT_PLAYER_ID );

	ShowInva(params[0],playerid);
	pformat:( "�� ���������� ��������� ������ " #C_GRAY "%s[%d]", pInfo[params[0]][pName],params[0]);
	psend:( playerid, -1 );
	return 1;
}

CMD:ban(playerid, params[])
{
    if(IsAdmin(playerid, 3)) return 1;
    if(sscanf(params, "uds[60]", params[0],params[1],params[2])) return SCM(playerid, COLOR_WHITE, "�����������: /ban [��] [���] [�������]");
    if( !IsPlayerLogged( params[0] ) ) return SCM( playerid, COLOR_DARK_GRAY, !INCORRECT_PLAYER_ID );
	if( params[1] < 0 || params[1] > 360 )	return SCM( playerid, COLOR_DARK_GRAY, !"�� ������� �������� ���������� ����. ����������� ����� ������������� ������ �� 360 ����." );

	format:str_cmd( "������������� %s ������������ ������ %s �� %d ����. �������: %s",pInfo[playerid][pName],pInfo[params[0]][pName], params[1], params[2]);
	SendClientMessageToAll( COLOR_LIGHT_RED, str_cmd);
   
   	mysql_format:str_small( "UPDATE `" #DB_ACCOUNTS "` SET `Ban` = %d WHERE `Name` = '%s'",
   		gettime() + params[1] * 86400, 
   		pInfo[params[0]][pName]
   	);

   	mysql_function_query( mysql_connect_ID, str_small, false, "", "");

    Kick(params[0]);
	return 1;
}

