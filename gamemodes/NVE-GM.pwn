CMD:pmoff(playerid, params[])
{
	if(IsAdmin(playerid, 1)) return 1;
	if(GetPVarInt(playerid,"pmoff")==1) DeletePVar(playerid,"pmoff"), SCM(playerid,-1,"�� �������� PM"); else SetPVarInt(playerid,"pmoff",1), SCM(playerid,-1,"�� ��������� PM");
