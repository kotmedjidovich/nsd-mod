}

SendMessageVip(playerid)
{
    ClearVar();

    if( pInfo[playerid][pVip] == 3 && pInfo[playerid][pVipday] > gettime() )
    {
		SCM(playerid,-1,"� ��� ���������� ����������� {FFD700}VIP-������ \"�������\""), SendMes(playerid,-1,"���� ��������� ��������: %s (%s ���)", timec(pInfo[playerid][pVipday]), timem(pInfo[playerid][pVipday]) );
	}

	if( pInfo[playerid][pVip] == 2 && pInfo[playerid][pVipday] > gettime() )
    {
		SCM(playerid,-1,"� ��� ���������� ����������� {C9C0BB}VIP-������ \"�������\""), SendMes(playerid,-1,"���� ��������� ��������: %s (%s ���)", timec(pInfo[playerid][pVipday]), timem(pInfo[playerid][pVipday]));
	}

	if( pInfo[playerid][pVip] == 1 && pInfo[playerid][pVipday] > gettime() )
    {
		SCM(playerid,-1,"� ��� ���������� ����������� {BA4A4B}VIP-������ \"������\""), SendMes(playerid,-1,"���� ��������� ��������: %s (%s ���)", timec(pInfo[playerid][pVipday]), timem(pInfo[playerid][pVipday]));
    }
    
    return 1;
}

Specoff(playerid)
{
    DeletePVar(playerid,"spec"), TogglePlayerSpectating(playerid, 0), SetPlayerPos(playerid, pInfo[playerid][pCor][0], pInfo[playerid][pCor][1], pInfo[playerid][pCor][2]), SetPlayerSkin(playerid,pInfo[playerid][pChart]), HideMenuForPlayer(spec,playerid),
	DeletePVar(playerid,"spectable");
	return 1;
}

Specon(playerid,spectable)
{
    SetPVarInt(playerid,"spec",1);

    if(IsPlayerInAnyVehicle(spectable))
    {
        SetPlayerInterior(playerid,GetPlayerInterior(spectable));
        SetPlayerVirtualWorld(playerid, GetPlayerVirtualWorld(spectable));
        TogglePlayerSpectating(playerid, 1);
        PlayerSpectateVehicle(playerid, GetPlayerVehicleID(spectable));
    }
    else
    {
        SetPlayerInterior(playerid,GetPlayerInterior(spectable));
        SetPlayerVirtualWorld(playerid, GetPlayerVirtualWorld(spectable));
        TogglePlayerSpectating(playerid, 1);
        PlayerSpectatePlayer(playerid, spectable);
    }

    pformat:( "�� ������� �� "C_GRAY"%s[%d]",pInfo[spectable][pName],spectable);
	psend:( playerid, COLOR_WHITE );

	SetPVarInt(playerid,"spectable",spectable);

	ShowMenuForPlayer(spec,playerid);
	
	return 1;
}

CheckLic(playerid)
{

    for(new i; i != 4; i++)
	{
		if( pInfo[playerid][pLic][i] > 2 || pInfo[playerid][pLic][i] < 0 )
		{
		    if( pInfo[playerid][pLic][i] < gettime() )
			{
			    pInfo[playerid][pLic][i] = 1;
			    SendMes( playerid, -1, "���� ������� ����� ���� ��������� "C_GRAY"%s "C_WHITE"����� ! ������������� � ����� ��� ��������������", kat[ pInfo[playerid][pLic][i] ] );
			    
			    mysql_format:str_small("UPDATE `" #DB_ACCOUNTS "` SET `Lic` = '%d|%d|%d|%d' WHERE `ID` = %d",pInfo[playerid][pLic][0],pInfo[playerid][pLic][1],pInfo[playerid][pLic][2],pInfo[playerid][pLic][3],pInfo[playerid][pID]);
				mysql_function_query(mysql_connect_ID, str_small, false, "", "");
		    }
		}
	}

	return 1;
}

