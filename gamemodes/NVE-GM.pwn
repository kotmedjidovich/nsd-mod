}

CheckNickname(playerid)
{
	new temp_name[21],
    bool: allow_connect = false;
    new d = strfind(temp_name, "_");
    if( d==-1 ) return 0; //
	GetPlayerName(playerid, temp_name, sizeof temp_name);
	if(strfind(temp_name, "_", false, d+1) != -1) // true ����
	    return 1;
	
	for(new idx; idx < sizeof allowed_nicknames; idx ++)
	{
		if(!strcmp(temp_name, allowed_nicknames[idx], true))
		{
		    allow_connect = true;
		    
		    break;
		}
	}
	
	if(!allow_connect)
	    SCM(playerid, 0xFF5533FF, "��� ������� ������ ���� � ������� ���_������� (�� ��������)"), SetPVarInt(playerid, "kick_for_name", 2);

	return 1;
}

UpdatePlayer( playerid, column[], _: value )
{
	mysql_format:str_big( "UPDATE `" DB_ACCOUNTS "` SET `%s` = %d WHERE `ID` = %d",
	    column,
	    value,
	    pInfo[playerid][pID]
	);
	
	return mysql_tquery( mysql_connect_ID, str_big, "", "" );
}

