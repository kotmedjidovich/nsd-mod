CMD:checkip(playerid, params[])
{
    if( IsAdmin( playerid, 1 ) ) return 1;
    
    if( sscanf(params, "u", params[0] ) ) return SCM(playerid, COLOR_WHITE, "�����������: /checkip [�� ������]");

	new ip[17];
	    
	GetPlayerIp( params[0], ip, 17 );
	
	SendMes( playerid, -1, "%s | IP ��� �����������: "C_GRAY"%s", pInfo[ params[0] ][ pName ], pInfo[ params[0] ][ pRegip ] );
	SendMes( playerid, -1, "%s | IP ��������� �����: "C_GRAY"%s", pInfo[ params[0] ][ pName ], pInfo[ params[0] ][ pLastip ] );
	SendMes( playerid, -1, "%s | IP �� ������ ������: "C_GRAY"%s", pInfo[ params[0] ][ pName ], ip );
	
	return 1;
}

CMD:checkcar(playerid, params[])
{
    if( IsAdmin( playerid, 1 ) ) return 1;
    
    if( sscanf(params, "u", params[0] ) ) return SCM(playerid, COLOR_WHITE, "�����������: /checkcar [�� ������]");

	new kolvo;
	
    for(new i; i != LoadAllCar; i++)
	{
		if(!strcmp(cInfo[i][cOwner],pInfo[ params[0] ][pName],true))
		{
			kolvo++;
			format:str_small("" #C_GRAY "%d.{ffffff} %s [%s] - id %d\n",kolvo,GetCarMark(cInfo[i][cModel]),cInfo[i][cNumber], cInfo[i][cCar]);
			if(cInfo[i][cArrest]==1) format:str_small("" #C_GRAY "%d.{ffffff} %s [%s] - {992F2F}�/�\n",kolvo,GetCarMark(cInfo[i][cModel]),cInfo[i][cNumber]);
			strcat(str_big,str_small);
		}
	}
	
	format:str_least("" #C_GRAY "��������� ������ %s", pInfo[ params[0] ][ pName ] );

	SPD( playerid, d_null, list, str_least, str_big, "�������", "");
	
	str_big[0] = EOS;
	ClearVar();

	return 1;
}

CMD:checkned(playerid, params[])
{
    if( IsAdmin( playerid, 1 ) ) return 1;

    if( sscanf(params, "u", params[0] ) ) return SCM(playerid, COLOR_WHITE, "�����������: /checkned [�� ������]");
    
    if(!IsPlayerConnected(params[0])) return SCM(playerid,-1,"������ � ����� ID ��� �� �������");

	new kolvo;

    for(new i; i != LoadAllNed; i++)
	{
		if(!strcmp(nInfo[i][nOwner],pInfo[ params[0] ][pName],true))
		{
			kolvo++;
			format:str_small("" #C_GRAY "%d.{ffffff} id - %d (%s)\n",kolvo, i, GetPropertyType(i));
			strcat(str_big,str_small);
		}
	}

	format:str_least("" #C_GRAY "������������ ������ %s", pInfo[ params[0] ][ pName ] );

	SPD( playerid, d_null, list, str_least, str_big, "�������", "");
	
	str_big[0] = EOS;
	ClearVar();

	return 1;
}

CMD:gotoned(playerid, params[])
{
    if( IsAdmin( playerid, 3 ) ) return 1;

    if( sscanf(params, "d", params[0] ) ) return SCM(playerid, COLOR_WHITE, "�����������: /gotoned [�� ������������]");
    
    if( params[0] > LoadAllNed || params[0] < 0 ) return SCM( playerid, -1, "������������ � ��������� ID �� �������!");
    
	new
		bool:found = false;

    for(new i; i != LoadAllNed; i++)
	{
		if( i == params[0] )
		{
		    if( nInfo[ i ][ nPick ][ 0 ] != 0.0 )
		    {
		    	SetPlayerPosF( playerid, nInfo[ i ][ nPick ][ 0 ], nInfo[ i ][ nPick ][ 1 ], nInfo[ i ][ nPick ][ 2 ], 0 );
		        SendMes( playerid, -1, "�� ������� ����������������� � ������������ �%d",i);
		    }
		    else if( nInfo[ i ][ nBuy ][ 0 ] != 0.0 )
		    {
		        SetPlayerPosF( playerid, nInfo[ i ][ nBuy ][ 0 ], nInfo[ i ][ nBuy ][ 1 ], nInfo[ i ][ nBuy ][ 2 ], 0 );
		        SendMes( playerid, -1, "�� ������� ����������������� � ������������ �%d",i);
		    }
		    else
		    {
				SCM( playerid, -1, "� ������������ � ��������� ID �� ������� ����������!");
			}
			
			found = true;
		    
		    break;
		}
	}

	if( found == false ) return SCM( playerid, -1, "������������ � ��������� ID �� �������!");

	return 1;
}

CMD:admin(playerid)
{
    if( IsAdmin( playerid, 1 ) ) return 1;
    
    new
		num = 1;

	format:str_small( ""C_WHITE"%d."C_GRAY" �������� PM: %s\n", num, ( GetPVarInt( playerid, "pmspec") == 0 ) ? ( "{8CE062}�������" ) : ( "{DF5151}��������" ) );
	strcat(str_big,str_small), num++;
	
	format:str_small( ""C_WHITE"%d."C_GRAY" �������� /pay: %s\n", num, ( GetPVarInt( playerid, "payspec") == 0 ) ? ( "{8CE062}�������" ) : ( "{DF5151}��������" ) );
	strcat(str_big,str_small), num++;
	
	format:str_small( ""C_WHITE"%d."C_GRAY" �������� /d: %s\n", num, ( GetPVarInt( playerid, "dspec") == 1 ) ? ( "{8CE062}�������" ) : ( "{DF5151}��������" ) );
	strcat(str_big,str_small), num++;
	
	if( GetPVarInt( playerid, "rspec" ) == 0 )
	{
	    format:str_small( ""C_WHITE"%d."C_GRAY" �������� /r: {DF5151}������� �������\n", num );
		strcat(str_big,str_small), num++;
	}
	else
	{
		format:str_small( ""C_WHITE"%d."C_GRAY" �������� /r: {8CE062}%s\n", num, GetFrakName( GetPVarInt( playerid, "rspec" ), 0 ) );
		strcat(str_big,str_small), num++;
	}
	
	format:str_small( ""C_WHITE"%d."C_GRAY" �����������/����� �������: %s\n", num, ( GetPVarInt( playerid, "conspec") == 1 ) ? ( "{8CE062}��������" ) : ( "{DF5151}���������" ) );
	strcat(str_big,str_small), num++;
	
	format:str_small( ""C_WHITE"%d."C_GRAY" ������� ����������\n", num );
	strcat(str_big,str_small), num++;
	
	format:str_small( ""C_WHITE"%d."C_GRAY" ��������� �������\n", num );
	strcat(str_big,str_small);
	
	format:str_least( ""C_GRAY"���� �������������� | %d �������", pInfo[ playerid ][ pAdmin ] ); // ���������
	
	SPD( playerid, dAdmin+16, list, str_least, str_big, "��", "�������" );
	
	ClearVar();

	return 1;
}


CMD:spawn(playerid, params[])
{
	if( IsAdmin( playerid, 1 ) ) 
		return 1;

	if( sscanf( params, "u", params[0] ) ) 
		return SCM(playerid, COLOR_WHITE, "�����������: /spawn [�� ������]");

	if( !IsPlayerLogged( params[0] ) )
		return SCM( playerid, COLOR_DARK_GRAY, !INCORRECT_PLAYER_ID );

	DeletePVar(params[0],"spawns"); 
	SetPlayerVirtualWorld(playerid, 0);
	CancelSelectTextDraw(playerid);
	SpawnPlayer(params[0]);

	pformat:( "�� ���������� ������ "C_GRAY"%s[%d]", pInfo[params[0]][pName], params[0] );
	psend:( playerid, COLOR_WHITE );

	pformat:( "������������� "C_GRAY"%s[%d]"C_WHITE" ��������� ���", pInfo[playerid][pName], playerid );
	psend:( params[0], COLOR_WHITE );
	
	return 1;
}

