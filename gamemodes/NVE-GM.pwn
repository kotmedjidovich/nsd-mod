public OnPlayerTakeDamage(playerid, issuerid, Float:amount, weaponid, bodypart)
{
	if(issuerid != INVALID_PLAYER_ID) // ���� ����� �� �������� ���
	{
		{
			switch(bodypart)
			{
				case BODY_PART_TORSO: // ��������
				{
					new Float:health;
					GetPlayerHealth(playerid, health);
	                if(weaponid == 24) SetPlayerHealth(playerid, health-50.0); // ������ 50.0 ������� ��� ��������
				}
				case BODY_PART_LEFT_ARM, BODY_PART_RIGHT_ARM, BODY_PART_LEFT_LEG, BODY_PART_RIGHT_LEG: // ����, ����
				{
					new Float:health;
					GetPlayerHealth(playerid, health);
					if(weaponid == 24) SetPlayerHealth(playerid, health-34.0); // ������ 20.0 ������� ��� ��������
				}
				case BODY_PART_HEAD: // ������
				{
					new Float:health;
					GetPlayerHealth(playerid, health);
					if(19 <= weaponid <= 34) SetPlayerHealth(playerid, health-200.0), SetPVarInt(playerid,"death",2); // ������ 90.0 ������� ��� ��������
				}
			}
		}
	}
	return 1;
}

public OnPlayerEditAttachedObject(playerid, response, index, modelid, boneid,Float:fOffsetX, Float:fOffsetY, Float:fOffsetZ,Float:fRotX, Float:fRotY, Float:fRotZ,Float:fScaleX, Float:fScaleY, Float:fScaleZ)
{
	if(response == EDIT_RESPONSE_FINAL)
	{
     	aObj[playerid][aSlot][index]=1;
	    aObj[playerid][aObject][index]=modelid;
	    aObj[playerid][aBone][index]=boneid;
	    aObj[playerid][aX][index]=fOffsetX;
	    aObj[playerid][aY][index]=fOffsetY;
	    aObj[playerid][aZ][index]=fOffsetZ;
	    aObj[playerid][aFX][index]=fRotX;
	    aObj[playerid][aFY][index]=fRotY;
	    aObj[playerid][aFZ][index]=fRotZ;
		SetPlayerAttachedObject(playerid,index, modelid, boneid,fOffsetX, fOffsetY, fOffsetZ, fRotX, fRotY, fRotZ,fScaleX, fScaleY, fScaleZ);
	    SCM(playerid,0xB2EC5DFF,"�� ������� ���������� ������� �� ������ ���������");
	}
	if(response == EDIT_RESPONSE_CANCEL)
    {
	    RemovePlayerAttachedObject(playerid, index);
	    aObj[playerid][aSlot][index]=0;
	    aObj[playerid][aObject][index]=0;
	    aObj[playerid][aBone][index]=0;
	    aObj[playerid][aX][index]=0;
	    aObj[playerid][aY][index]=0;
	    aObj[playerid][aZ][index]=0;
	    aObj[playerid][aFX][index]=0;
	    aObj[playerid][aFY][index]=0;
	    aObj[playerid][aFZ][index]=0;
	    SCM(playerid,0xCD4B47FF,"�� �������� ��������");
    }
    return 1;
}

