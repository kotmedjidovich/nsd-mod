CMD:settime(playerid, params[])
{
    if(timeability == 0)
    {
        if(IsAdmin(playerid, 5)) return 1;
        if(sscanf(params, "dd", params[0],params[1])) return SCM(playerid, COLOR_WHITE, "�����������: /settime [����] [������]");
        foreach(Player, i)
        {
            SetPlayerTime(i,params[0],params[1]), timeability = 1;
        }
        format:str_small( "[A] %s ������� ������� ����� ��: %d:%d",pInfo[playerid][pName],params[0],params[1]);
        SAM( COLOR_LIGHT_GREEN, str_small );
	}
	else
	{
        timeability = 0;
	}
    return 1;
}

CMD:givelic(playerid, params[])
{
	if(IsAdmin(playerid, 5)) return 1;
	if(sscanf(params, "udd", params[0],params[1],params[2])) return SCM(playerid, COLOR_WHITE, "�����������: /givelic [�� ������] [��������� (0-A,1-B � �.�)] [1-������� ��������� | 2-���� �����]");
	if(!IsPlayerLogged( params[0] ) ) return SCM( playerid, COLOR_DARK_GRAY, !INCORRECT_PLAYER_ID );
	pInfo[params[0]][pLic][params[1]]=params[2];
