   								strcat( str_big, str_small );
   							}
   						}

   						if( num == 0 )
   						{
   							SCM( playerid, -1, "�� ������� ��� ������� � ������ �� ������ ��");

   							return 1;
   						}

   						format:str_least("" #C_GRAY "����� �� %s", GetCarMark( cInfo[ i ][ cModel ] ) );

   						SPD( playerid, dCar+23, list, str_least, str_big, "�������", "�������" );

   						str_big[0] = EOS;
   						str_small[0] = EOS;

