ShowCarInv(playerid,id)
{
    ClearVar();

	new num;

	format:str_small("{ffffff}������������:                            {ffffff}| ���-��:\n"), strcat(str_big, str_small);

	for(new i; i != 15; i ++)
	{
		if(cInv[id][cinvSlot][i]!=0 && cInv[id][cinvSlotKol][i]!=0)
		{
			switch(strlen(_itemsInfo[cInv[id][cinvSlot][i]][invName]))
			{
				case 0..6: format:str_least("%s\t\t\t\t",_itemsInfo[cInv[id][cinvSlot][i]][invName]);
				case 7..12: format:str_least("%s\t\t\t",_itemsInfo[cInv[id][cinvSlot][i]][invName]);
				case 13..18: format:str_least("%s\t\t",_itemsInfo[cInv[id][cinvSlot][i]][invName]);
				case 19..24: format:str_least("%s\t",_itemsInfo[cInv[id][cinvSlot][i]][invName]);
			}
			format:str_small("" #C_GRAY "%s{ffffff} |     " #C_GRAY "%d\n", str_least,cInv[id][cinvSlotKol][i]), strcat(str_big, str_small), num++;
		}
	}

	format:str_least("{ffffff}�������� " #C_GRAY "| %d/15",num);

	return SPD(playerid,dcInv,list,str_least,str_big,"��","�����"), str_big[0] = EOS, str_small[0] = EOS;
}

