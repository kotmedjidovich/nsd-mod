nmenu(playerid,i)
{
	SetPVarInt(playerid,"nmenuid",i);

	format:str_small("" #C_GRAY "�{FFFFFF} ����������\n" #C_GRAY "�{FFFFFF} ����������\n" #C_GRAY "�{FFFFFF} ������\n" #C_GRAY "�{FFFFFF} ������������\n"), strcat(str_cmd,str_small);
	if(nInfo[GetPVarInt(playerid,"nmenuid")][nType]==0 || nInfo[GetPVarInt(playerid,"nmenuid")][nType]==1 || nInfo[GetPVarInt(playerid,"nmenuid")][nType]==3) format:str_small("" #C_GRAY "�{FFFFFF} ���������� ����� � ���� ����\n"), strcat(str_cmd,str_small);
	if(nInfo[GetPVarInt(playerid,"nmenuid")][nType]==5 || nInfo[GetPVarInt(playerid,"nmenuid")][nType]==6 || nInfo[GetPVarInt(playerid,"nmenuid")][nType]==9 || nInfo[GetPVarInt(playerid,"nmenuid")][nType]==8 || nInfo[GetPVarInt(playerid,"nmenuid")][nType]==7 || nInfo[GetPVarInt(playerid,"nmenuid")][nType]==5 || nInfo[GetPVarInt(playerid,"nmenuid")][nType]==2) format:str_small("" #C_GRAY "�{FFFFFF} ���������� ���� �� ������\n"), strcat(str_cmd,str_small);
	if(nInfo[GetPVarInt(playerid,"nmenuid")][nType]==4) format:str_small("" #C_GRAY "�{FFFFFF} ���������� ���� �� 1 ���� �������\n"), strcat(str_cmd,str_small);
	if(nInfo[GetPVarInt(playerid,"nmenuid")][nType]==0 || nInfo[GetPVarInt(playerid,"nmenuid")][nType]==1 || nInfo[GetPVarInt(playerid,"nmenuid")][nType]==3 && nInfo[GetPVarInt(playerid,"nmenuid")][nBuy][0] != 0.0 ) format:str_small("" #C_GRAY "�{FFFFFF} ����������� ����\n"), strcat(str_cmd,str_small);
	if(nInfo[GetPVarInt(playerid,"nmenuid")][nType]==0 || nInfo[GetPVarInt(playerid,"nmenuid")][nType]==1 || nInfo[GetPVarInt(playerid,"nmenuid")][nType]==3 && nInfo[GetPVarInt(playerid,"nmenuid")][nSpawn][0] != 0.0 ) format:str_small("" #C_GRAY "�{FFFFFF} ����������� ����� ������\n"), strcat(str_cmd,str_small);
	if( nInfo[GetPVarInt(playerid,"nmenuid")][nType] == 2 || nInfo[GetPVarInt(playerid,"nmenuid")][nType] > 3  && nInfo[GetPVarInt(playerid,"nmenuid")][nBuy][0] != 0.0 ) format:str_small("" #C_GRAY "�{FFFFFF} ����������� ����� �������\n"), strcat(str_cmd,str_small);
	SPD(playerid,dNed+3, list,"" #C_GRAY "���������� �������������",str_cmd,"��","�������");
	str_cmd[0] = EOS;
	return 1;
}

GetPropertyType(id)
{
	new name[50];
	switch(nInfo[id][nType])
	{
		case 0: name = "������� ���";
	    case 1: name = "������� ���";
	    case 2: name = "������� 24/7";
	    case 3: name = "������� ���������";
	    case 4: name = "���";
	    case 5: name = "����� ������� �����";
	    case 6: name = "������� ������";
	    case 7: name = "����������� �����";
	    case 8: name = "������ �������";
	    case 9: name = "��� ��� ��������� ������";
 		default: name = "������������";
	}
	return name;
}

GetObjName(id)
{
	for(new i; i != 1000; i ++)
	{
	    if(_itemsInfo[i][invObject] == id)
		{
		    strmid(str_least, _itemsInfo[i][invName], 0, strlen(_itemsInfo[i][invName]),50);
		    break;
		}
	}
	return str_least;
}

