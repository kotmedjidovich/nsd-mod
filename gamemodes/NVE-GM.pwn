	if(cars >= 2) return SCM(playerid,-1,"� ������� ������ ������� ����� �����������!");
	if(pInfo[playerid][pVip] > 0 && cInfo[i][cModel] == 560 || pInfo[playerid][pVip] > 0 && cInfo[i][cModel] == 580 || pInfo[playerid][pVip] > 0 && cInfo[i][cModel] == 579|| pInfo[playerid][pVip] > 0 && cInfo[i][cModel] == 400 || pInfo[playerid][pVip] > 0 && cInfo[i][cModel] == 466 || pInfo[playerid][pVip] > 0 && cInfo[i][cModel] == 604)
	{
	    SCM(playerid,-1,"VIP ��������� ����� ��������� ������ � ���������!");
		return 1;
	}//tamasita*
	
	SendMes(playerid,-1,"" #C_GRAY "�� ��������� %s ����������� ������ ��� ����������",pInfo[params[0]][pName]);
	
	str_small[0] = EOS;
	
	format:str_small("" #C_GRAY "����������� �� ������ {ffffff}%s\n" #C_GRAY "������: {ffffff}%s\n" #C_GRAY "����: {ffffff}%s �.\n" #C_GRAY "������: {ffffff}%s%s%s%s%s%s",pInfo[playerid][pName],GetCarMark(cInfo[i][cModel]),params[1],cInfo[i][cNumber],cInfo[i][cNumber2],cInfo[i][cNumber3],cInfo[i][cNumber4],cInfo[i][cNumber5],cInfo[i][cNumber6]),
 	SPD(params[0],dCar+8,info,"" #C_GRAY "����������� � ������� ����������",str_small,"������","��������"), SetPVarInt(params[0],"sellcarid",i), SetPVarInt(params[0],"sellname",playerid), SetPVarInt(params[0],"sellprice",params[1]);
	return 1;
}

CMD:addsellcar(playerid, params[])
