public OnPlayerGiveDamage(playerid, damagedid, Float:amount, weaponid)
{
    if(GetPVarInt(playerid,"gLogged")!=1) return 1;
    if(GetPVarInt(damagedid,"gLogged")!=1) return 1;
    if(GetPVarInt(damagedid,"death")>0) return 1;
    if(damagetime[damagedid]!=0) return 1;
    
	if(playerid != INVALID_PLAYER_ID)
	{
		if(weaponid>54) return 1;
	    new tdeath1,tdeath2,tdeath3;
		new dtime[7];
		gettime(tdeath1,tdeath2,tdeath3);
		damagetime[damagedid]=2;
	    for(new i; i !=10; i++)
		{
			if(dInfo[damagedid][dGun][i] == 0)
			{
				dInfo[damagedid][dGun][i] = weaponid;
				dInfo[damagedid][dType][i] = 1;
				f(dtime),"%d:%d|",tdeath1,tdeath2);
				strins(dInfo[damagedid][dTime],dtime,strlen(dInfo[damagedid][dTime]),128);
				break;
			}
		}
	}
    return 1;
}

public OnPlayerDeath(playerid, killerid, reason)
{
	if(GetPVarInt(playerid,"gLogged")!=1) return 1;
	if(GetPVarInt(playerid,"spawn")!=1) return 1;
	if(GetPVarInt(playerid,"bcheck")!=0) SetPVarInt(playerid,"bway",0), busdel[playerid]=0, SetVehicleToRespawn(GetPVarInt(playerid,"jobcar")), SetPVarInt(playerid,"jobcar",0), SetPVarInt(playerid,"nomerb",0), RemovePlayerFromVehicle(playerid), DisablePlayerCheckpoint(playerid), DeletePVar(playerid,"bjob");
	if(GetPVarInt(playerid,"spawns")!=0) DeletePVar(playerid,"spawns");
	
	if(GetPVarInt(playerid,"taxi")==1 && GetPVarInt(playerid,"taxitype")!=0)
	{
		if(GetPVarInt(playerid,"perevoz")==1) { new dr = GetPVarInt(playerid,"taxip"); DeletePVar(dr,"taxipp"),DeletePVar(dr,"pperevoz"), RemovePlayerFromVehicle(dr); }
		textdrawtaxi(playerid,0,0,1,0,0,1), textdrawtaxi(playerid,0,0,0,1,0,0), DeletePVar(playerid,"taxip"), DeletePVar(playerid,"perevoz"), DeletePVar(playerid,"taxi"), DeletePVar(playerid,"taxitype"), DeletePVar(playerid,"plata"), DeletePVar(playerid,"zarplata");
		SetVehicleToRespawn(GetPVarInt(playerid,"idtaxi")), tdriver--, textupdate(), DeletePVar(playerid,"idtaxi");
	}
	
 	/*if(GetPVarInt(playerid,"duty")!=1) SetPlayerSkin(playerid,pInfo[playerid][pChart][1]);
    if(pInfo[playerid][pFrakskin] != 0) //
    {
        if(pInfo[playerid][pFrak] != 0)
        {
	        SetPlayerSkin(playerid,pInfo[playerid][pFrakskin]);
	        SetPVarInt(playerid,"duty",1);
		}
		else
		{
			SetPlayerSkin(playerid,pInfo[playerid][pChart]);
		}
    }*/
	PreloadAnimLib(playerid,"CRACK");
	
	if(killerid != INVALID_PLAYER_ID)
	{
	
		if(reason>54) return 1;

		if(GetPVarInt(playerid,"death")==1)
		{
			SetPVarInt(playerid,"death",2);
			DestroyDynamic3DPlayer( dtext[playerid], playerid );
		}
	    if(GetPVarInt(playerid,"death")!=2) SetPVarInt(playerid,"death",1);
	    for(new id; id < MAX_VIZ; id ++) { if(viInfo[id][viPlayerid]==playerid && viInfo[id][viEnter]==1) viInfo[id][viEnter]=0,viInfo[id][viPos][0]=0,viInfo[id][viPos][1]=0,viInfo[id][viPos][2]=0,viInfo[id][viPlayerid]=0, strmid(viInfo[id][viText], "0", 0, strlen("0"), 70), vizov--; if(vizov<0) vizov=0; }
		GetPlayerPos(playerid,pInfo[playerid][pCor][0],pInfo[playerid][pCor][1],pInfo[playerid][pCor][2]);
		GetPlayerFacingAngle(playerid,pInfo[playerid][pCor][3]);
		new tdeath1,tdeath2,tdeath3;
		new dtime[7];
		gettime(tdeath1,tdeath2,tdeath3);
	    for(new i; i !=10; i++)
		{
			if(dInfo[playerid][dGun][i] == 0)
			{
				dInfo[playerid][dGun][i] = reason;
				if(GetPVarInt(playerid,"death")==2) dInfo[playerid][dType][i] = 2;
				f(dtime),"%d:%d|",tdeath1,tdeath2);
				strins(dInfo[playerid][dTime],dtime,strlen(dInfo[playerid][dTime]),128);
				break;
			}
		}

	}
	return 1;
}

public OnVehicleSpawn( vehicleid )
{
	if(siren[vehicleid] != 0)
 	{
 		if(IsValidDynamicObject(sirenobj[vehicleid]))
		{
		 	DestroyDynamicObjected(sirenobj[vehicleid]),
	 		siren[vehicleid] = 0,
	 		sirenobj[vehicleid] = 0;
	 	}
  	}
    if(VehInfos[vehicleid][vRightBlink])
	{
 		DestroyObject(Blink[vehicleid][0]);
      	DestroyObject(Blink[vehicleid][1]);
     	VehInfos[vehicleid][vRightBlink] = 0;
	}
	if(VehInfos[vehicleid][vLeftBlink])
	{
 		DestroyObject(Blink[vehicleid][2]);
      	DestroyObject(Blink[vehicleid][3]);
     	VehInfos[vehicleid][vLeftBlink] = 0;
	}
	if(VehInfos[vehicleid][vAvary] == 1)
	{
		DestroyObject(Blink[vehicleid][0]);
		DestroyObject(Blink[vehicleid][1]);
		DestroyObject(Blink[vehicleid][2]);
		DestroyObject(Blink[vehicleid][3]);
        VehInfos[vehicleid][vAvary] = 0;
	}
