public OnPlayerKeyStateChange(playerid, newkeys, oldkeys)
{
	if(GetPVarInt(playerid, "gLogged") != 1) return 1;

	/*if(newkeys & KEY_FIRE && !IsPlayerInAnyVehicle(playerid))
	{

	}*/
    //
    if( newkeys == 2048 && IsPlayerInAnyVehicle(playerid))
	{
		new v = GetPlayerVehicleID(playerid);
		new model = (GetVehicleModel(v)-400);
		if(GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
		{
			if(LightsPos[model][0] == 0.0 && LightsPos[model][1] == 0.0 && LightsPos[model][2] == 0.0) return true;
			if(VehInfos[v][vRightBlink] == 1)
			{
				DestroyObject(Blink[v][0]);
				DestroyObject(Blink[v][1]);
				VehInfos[v][vRightBlink] = 0;
			}
			if(VehInfos[v][vLeftBlink] == 1)
			{
				DestroyObject(Blink[v][2]);
				DestroyObject(Blink[v][3]);
				VehInfos[v][vLeftBlink] = 0;
			}
			if(VehInfos[v][vAvary] == 1)
			{
				DestroyObject(Blink[v][0]);
				DestroyObject(Blink[v][1]);
				DestroyObject(Blink[v][2]);
				DestroyObject(Blink[v][3]);
                VehInfos[v][vAvary] = 0;
			}
			else
			{
				Blink[v][0] = CreateObject(14267, 0, 0, 0, 0, 0, 0);
				Blink[v][1] = CreateObject(14267, 0, 0, 0, 0, 0, 0);
				AttachObjectToVehicle(Blink[v][0], v, LightsPos[model][0], LightsPos[model][1], LightsPos[model][2], 0, 0, 0);
				AttachObjectToVehicle(Blink[v][1], v, LightsPos[model][3], LightsPos[model][4], LightsPos[model][5], 0, 0, 0);
				Blink[v][2] = CreateObject(14267, 0, 0, 0, 0, 0, 0);
				Blink[v][3] = CreateObject(14267, 0, 0, 0, 0, 0, 0);
				AttachObjectToVehicle(Blink[v][2], v, -LightsPos[model][0], LightsPos[model][1], LightsPos[model][2], 0, 0, 0);//������  ��������
				AttachObjectToVehicle(Blink[v][3], v, -LightsPos[model][3], LightsPos[model][4], LightsPos[model][5], 0, 0, 0);//������  ������
    			VehInfos[v][vAvary] = 1;
			}
		}
	}
	if( newkeys & KEY_LOOK_LEFT && IsPlayerInAnyVehicle(playerid))
	{
		new v = GetPlayerVehicleID(playerid);
		new model = (GetVehicleModel(v)-400);
		if(GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
		{
			if(LightsPos[model][0] == 0.0 && LightsPos[model][1] == 0.0 && LightsPos[model][2] == 0.0) return true;
			if(VehInfos[v][vAvary] == 1)
			{
				DestroyObject(Blink[v][0]);
				DestroyObject(Blink[v][1]);
				DestroyObject(Blink[v][2]);
				DestroyObject(Blink[v][3]);
                VehInfos[v][vAvary] = 0;
			}
			if(VehInfos[v][vLeftBlink] == 1)
			{
				DestroyObject(Blink[v][2]);
				DestroyObject(Blink[v][3]);
				VehInfos[v][vLeftBlink] = 0;
			}
			if(VehInfos[v][vRightBlink] == 1)
			{
				DestroyObject(Blink[v][0]);
				DestroyObject(Blink[v][1]);
				VehInfos[v][vRightBlink] = 0;
			}
			else
			{
				Blink[v][0] = CreateObject(14267, 0, 0, 0, 0, 0, 0);
				Blink[v][1] = CreateObject(14267, 0, 0, 0, 0, 0, 0);
				AttachObjectToVehicle(Blink[v][0], v, LightsPos[model][0], LightsPos[model][1], LightsPos[model][2], 0, 0, 0);
				AttachObjectToVehicle(Blink[v][1], v, LightsPos[model][3], LightsPos[model][4], LightsPos[model][5], 0, 0, 0);
				VehInfos[v][vRightBlink] = 1;
			}
		}
	}
	if(newkeys& KEY_LOOK_RIGHT)
	{
		new v = GetPlayerVehicleID(playerid);
		new model = (GetVehicleModel(v)-400);
		if(GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
		{
			if(LightsPos[model][0] == 0.0 && LightsPos[model][1] == 0.0 && LightsPos[model][2] == 0.0) return true;
			if(VehInfos[v][vAvary] == 1) return true;
			if(VehInfos[v][vRightBlink] == 1)
			{
				DestroyObject(Blink[v][0]);
				DestroyObject(Blink[v][1]);
				VehInfos[v][vRightBlink] = 0;
			}
			if(VehInfos[v][vLeftBlink] == 0)
			{
				Blink[v][2] = CreateObject(14267, 0, 0, 0, 0, 0, 0);
				Blink[v][3] = CreateObject(14267, 0, 0, 0, 0, 0, 0);
				AttachObjectToVehicle(Blink[v][2], v, -LightsPos[model][0], LightsPos[model][1], LightsPos[model][2], 0, 0, 0);//������  ��������
				AttachObjectToVehicle(Blink[v][3], v, -LightsPos[model][3], LightsPos[model][4], LightsPos[model][5], 0, 0, 0);//������  ������
				VehInfos[v][vLeftBlink] = 1;
			}
			else if(VehInfos[v][vLeftBlink] == 1)
			{
				DestroyObject(Blink[v][2]);
				DestroyObject(Blink[v][3]);
				VehInfos[v][vLeftBlink] = 0;
			}
		}
	}
	
    if(newkeys & KEY_YES)
    {
