	{
		f(frak),"���"); // �������
		f(dolj),"���"); // ���������
		f(dolg),"���"); // ���������
	}
	else
	{
		f(frak),"%s",GetFrakName(pInfo[playerid][pFrak],0)); // �������
		f(dolj),"%s[%d]",pInfo[playerid][pDol],pInfo[playerid][pRang]); // ���������[����]
		f(dolg),"%s[%d]",pInfo[playerid][pDols],pInfo[playerid][pRang]); // ���������[����]
	}

	if(pInfo[playerid][pJob][0]==0) f(jobz),"���");
	if(pInfo[playerid][pJob][0]==1) f(jobz),"�������� ��������");
	if(pInfo[playerid][pJob][0]==2) f(jobz),"�������� �����");
	if(pInfo[playerid][pJob][0]==3) f(jobz),"�������� ����");

	switch( pInfo[playerid][pFight] )
	{
		case 0: format:str_least("�����������");
 		case 4: format:str_least("�����������");
   		case 5: format:str_least("����");
	    case 6: format:str_least("����-��");
	    case 7: format:str_least("������");
	}

    new
		textip[17],
		textip2[17];
		
	if( !strlen(pInfo[ playerid ][ pRegip ]) ) f(textip),"��� ����������");
	else f(textip),"%s",pInfo[ playerid ][ pRegip ] );
	
	if( !strlen(pInfo[ playerid ][ pLastip ]) ) f(textip2),"��� ����������");
	else f(textip2),"%s",pInfo[ playerid ][ pLastip ] );

	format:str_big("\
	" #C_GRAY "��� �������:\t\t\t {ffffff}%s\n\
	" #C_GRAY "����� �� �������:\t\t {ffffff}%d\n\
	" #C_GRAY "����� �� �����:\t\t {ffffff}%d\n\
	" #C_GRAY "����� � �����:\t\t {ffffff}%d\n\
	" #C_GRAY "������:\t\t\t {ffffff}%s\n\
	" #C_GRAY "�����������:\t\t\t {ffffff}%s\n\
	" #C_GRAY "����:\t\t\t\t {ffffff}%s\n\
	" #C_GRAY "�������:\t\t\t {ffffff}%s\n\
	" #C_GRAY "������:\t\t\t {ffffff}%s\n\
	" #C_GRAY "���������:\t\t\t {ffffff}%s\n\
	" #C_GRAY "����� ��������:\t\t {ffffff}%s\n\
	" #C_GRAY "��������������:\t\t {ffffff}%d/3\n\n\
	" #C_GRAY "��������������� IP:\t\t {ffffff}%s\n\
	" #C_GRAY "��������� IP:\t\t\t {ffffff}%s\n\
	" #C_GRAY "�������� IP:\t\t\t {ffffff}%s\n\
	" #C_GRAY "���� �����������:\t\t {ffffff}%s(%s)\n\
	" #C_GRAY "���� ���������� ������:\t {ffffff}%s(%s)",pInfo[playerid][pName],pInfo[playerid][pGame],pInfo[playerid][pMoney],pInfo[playerid][pBank],jobz,org,rang,frak,dolj,dolg,nomer,pInfo[playerid][pWarn],
	textip,
	textip2,
	pInfo[ playerid ][ pIP ],
	timec( pInfo[ playerid ][ pRegdate ] ),
	timem( pInfo[ playerid ][ pRegdate ] ),
	timec( pInfo[ playerid ][ pLastdate ] ),
	timem( pInfo[ playerid ][ pLastdate ] ) );
	
	SPD(idshow,d_null,info,"" #C_ABILITY "" #C_ABILITY "����������",str_big,"�������","");
	str_big[0] = EOS;
	
	return 1;
}

