		return 1;
	}

	if( count == 26 ) return SPD(playerid, dSearchPlayers+1, info, ""C_GRAY"���� ������������� �������", str_big, "�����", "�����");
	return SPD(playerid, dSearchPlayers+1, info, ""C_GRAY"���� ������������� �������", str_big, "�����", "");
}





