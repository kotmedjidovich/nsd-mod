			        format:str_small( "" #C_WHITE "������� ID ������, �������� �� ������ ������ ����� �� " #C_GRAY "%s", GetCarMark( cInfo[ i ][ cModel ] ) );

   					SPD( playerid, dCar+21, input, "" #C_GRAY "������ �����", str_small, "��", "�������" );

			        return 1;
			   	}

			   	SetPVarInt( id, "givekey", playerid );

			    format:str_small("" #C_GRAY "%s " #C_WHITE "����� �������� ��� ����� �� ������ �� " #C_GRAY "%s\n\n       " #C_WHITE "�� �������� ����� ����� ?", pInfo[ playerid ][ pName ], GetCarMark( cInfo[ i ][ cModel ] ) );

			    SPD( id, dCar+22, info, " ", str_small, "��", "���" );

   				return 1;
   			}

			case dCar+22:
			{
				new 
					id = GetPVarInt( playerid, "givekey" ),
					i = GetPVarInt( id, "cmenuid" );

				if(!response) 
				{
					SendMes( id, -1, "" #C_GRAY "%s ��������� ����� ����� �� ������ ��", pInfo[ playerid ][ pName ] );
					SCM( playerid, -1, "�� ���������� ����� �����");

					return 1;
