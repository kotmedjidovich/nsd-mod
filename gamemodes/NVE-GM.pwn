CMD:atest(playerid,params[])//tamasita*
{
	if(sscanf(params, "d", params[0])) return SCM(playerid, COLOR_WHITE, "�����������: /atest [�� ������]");
    if(!IsPlayerConnected(params[0])) return SCM(playerid,-1,"������ � ����� ID ��� �� �������");
    if(pInfo[playerid][pFrak] == 3)
	{
	    if(GetPVarInt(playerid,"duty")!=1) return SCM(playerid,-1,"�� �� ����� ��������� �� ���." #C_ABILITY " (�� �� �� ���������)");
	    new Float:p1,Float:p2,Float:p3;
	    GetPlayerPos(playerid,p1,p2,p3);
	    if(IsPlayerInRangeOfPoint(params[0], 5.0,p1,p2,p3))
	    {
	        if(GetPVarInt(params[0],"Alkohol") >= 1) return format:str_small( "���������� �������, ��� %s ��������� � ��������� ������������ ���������", pInfo[params[0]][pName]), cmd::do(playerid,str_small);
