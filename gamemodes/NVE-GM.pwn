public OnPlayerEnterDynamicArea(playerid, areaid)
{
	/*for( new i; i != LoadAllCar; i++ )
	{
	    IsValidDynamicArea(cInfo[i][cMusic][2]);
	    {
	        StopAudioStreamForPlayer(playerid);
	        if(cInfo[i][cMusic][1] != 1) StopAudioStreamForPlayer(playerid);
			if( cInfo[i][cMusic][2] == areaid )
			{
	 			PlayAudioStreamForPlayer(playerid,carmusic[cInfo[i][cCar]]);
			}
		}
	}*/
	
	for( new i; i != LoadAllNed; i++ )
	{
	    if( areaid == nInfo[ i ][ nMusicID ] )
	    {
	        if( IsValidDynamicArea( nInfo[ i ][ nMusicID ] ) && GetPlayerVirtualWorld( playerid ) == nInfo[ i ][ nInt ] )
	        {
	            new
	                Float:radius;
	        
	            switch( nInfo[i][nMusicVolume] )
				{
		  			case 0: radius = 10.0;
			    	case 1: radius = 20.0;
			    	case 2: radius = 30.0;
			    	default: radius = 10.0;
				}
	        
				StopAudioStreamForPlayer( playerid );
				StopAudioStreamForPlayer( playerid );
				StopAudioStreamForPlayer( playerid );
	            PlayAudioStreamForPlayer( playerid, nInfo[ i ][ nMusicUrl ], nInfo[ i ][ nExite ][ 0 ], nInfo[ i ][ nExite ][ 1 ], nInfo[ i ][ nExite ][ 2 ], radius, 1 );
	        }
	    }
	    if( areaid == nInfo[ i ][ nMusicstID ] )
	    {
	    	if( IsValidDynamicArea( nInfo[ i ][ nMusicstID ] ) && nInfo[ i ][ nMusicVolume ] == 2 )
	        {
	    		StopAudioStreamForPlayer( playerid );
	    		StopAudioStreamForPlayer( playerid );
	    		StopAudioStreamForPlayer( playerid );
      			PlayAudioStreamForPlayer( playerid, nInfo[ i ][ nMusicUrl ], nInfo[ i ][ nPick ][ 0 ], nInfo[ i ][ nPick ][ 1 ], nInfo[ i ][ nPick ][ 2 ], 5.0, 1 );
                break;
			}
		}
	}
	
   	return 1;
}

public OnPlayerLeaveDynamicArea(playerid, areaid)
{
   	/*for( new i; i != LoadAllCar; i++ )
	{
	    IsValidDynamicArea(cInfo[i][cMusic][2]);
	    {
	        if(cInfo[i][cMusic][1] != 1) StopAudioStreamForPlayer(playerid);
			if( cInfo[i][cMusic][2] == areaid )
			{
				StopAudioStreamForPlayer(playerid);
			}
		}
	}*/
	for( new i; i != LoadAllNed; i++ )
	{
		if( areaid == nInfo[ i ][ nMusicID ] )
  		{
    		if( IsValidDynamicArea( nInfo[ i ][ nMusicID ] ) )
			{
				StopAudioStreamForPlayer( playerid );
				StopAudioStreamForPlayer( playerid );
				StopAudioStreamForPlayer( playerid );
			}
		}
		if( areaid == nInfo[ i ][ nMusicstID ] )
  		{
    		if( IsValidDynamicArea( nInfo[ i ][ nMusicstID ] ) )
			{
				StopAudioStreamForPlayer( playerid );
				StopAudioStreamForPlayer( playerid );
				StopAudioStreamForPlayer( playerid );
				break;
			}
		}
	}
	
   	return 1;
}


public OnPlayerClickTextDraw(playerid, Text:clickedid)
{
    if(_:clickedid != INVALID_TEXT_DRAW) {
    
    //////////////////////////// ����� � �������� ������ ///////////////////////
	if(clickedid == ftextdraw[5] && GetPVarInt(playerid,"fshop") == 1) // ������
	{
		new
		    id = FurnitureList[ fnum[ playerid ] ][ fID ],
		    price = FurnitureList[ fnum[ playerid ] ][ fPrice ];
		    
		format:str_small(""C_GRAY"�� ������������� ������� "C_WHITE"%s ?"C_GRAY"\n\n����: "C_WHITE"%d�", _itemsInfo[ id ][ invName ], price );
		
        CancelSelectTextDraw( playerid );
		SPD( playerid, dOther+12, info, " ",str_small,"��","�����");
		    
		return 1;
	}
	
	if(clickedid == ftextdraw[6] && GetPVarInt(playerid,"fshop") == 1) // �������
	{
	    CancelSelectTextDraw( playerid );
        CancelSelectTextDraw( playerid );
        CancelSelectTextDraw( playerid );
	
		SetPlayerVirtualWorld(playerid,0);
	    SetPlayerPosF( playerid, 2792.7671,-2713.6814,1102.0000, 90.9922 );
	
		TextdrawFurniture( playerid, false );
	    
	    if( furnitureid[ playerid ] != 0 ) DestroyPlayerObject( playerid, furnitureid[ playerid ] );
	    
	    fnum[ playerid ] =
	    furnitureid[ playerid ] = 0;
	    
	    CancelSelectTextDraw( playerid );
	    
	    SPD(playerid,dOther+11,list,""C_GRAY"�������� ���������","\
		"C_GRAY"1. "C_WHITE"������������ ���������\n\
		"C_GRAY"2. "C_WHITE"�������\n\
		"C_GRAY"3. "C_WHITE"���������\n\
		"C_GRAY"4. "C_WHITE"��������������\n\
		"C_GRAY"5. "C_WHITE"����� � �����\n\
		"C_GRAY"6. "C_WHITE"�����������\n\
		"C_GRAY"7. "C_WHITE"�������� ��������������\n\
		"C_GRAY"8. "C_WHITE"��������\n\
		"C_GRAY"9. "C_WHITE"����������\n\
		"C_GRAY"10. "C_WHITE"����� � ��������\n\
		"C_GRAY"11. "C_WHITE"������ ��� �������","��","�������");
		
		return 1;
	}
	
	if(clickedid == ftextdraw[10] && GetPVarInt(playerid,"fshop") == 1) // >
	{
	
	    new
			bool: full = false,
			id;
	
	    for(new i = fnum[ playerid ] + 1; i != sizeof FurnitureList; i ++)
		{
		    if( GetPVarInt( playerid, "fcategory" ) == FurnitureList[ i ][ fCategory ] )
		    {
				fnum[ playerid ] = i;
				full = true;
				break;
			}
		}
		
		if( full == false )
		{
			for(new i; i != sizeof FurnitureList; i ++)
			{
			    if( GetPVarInt( playerid, "fcategory" ) == FurnitureList[ i ][ fCategory ] )
			    {
					fnum[ playerid ] = i;
					break;
				}
			}
		}
	
 		if( furnitureid[ playerid ] != 0 ) DestroyPlayerObject( playerid, furnitureid[ playerid ] );

	    id = FurnitureList[ fnum[ playerid ] ][ fID ];

	    furnitureid[playerid] = CreatePlayerObject( playerid, _itemsInfo[ id ][ invObject ], 1779.84, -1994.25, 999.31 + FurnitureList[ fnum[ playerid ] ][ fPosZ ],   0.00, 0.00, 143.46 + FurnitureList[ fnum[ playerid ] ][ fAngle ], 200.0 );

		format:str_small("%s", _itemsInfo[ id ][ invName ]);
		FixText( str_small );

		TextDrawSetString( ftextdrawp[0][playerid], str_small );
		
		str_small[0] = EOS;
	    
	    format:str_least( "%dP", FurnitureList[ fnum[ playerid ] ][ fPrice ] );
	    
	    TextDrawSetString( ftextdrawp[1][playerid], str_least );
	    
	    str_least[0] = EOS;
	    
	    PlayerPlaySound(playerid,1150,0.0,0.0,0.0);

		return 1;
	}
	
	if(clickedid == ftextdraw[9] && GetPVarInt(playerid,"fshop") == 1) // <
	{

	    new
			bool: full = false,
			id;

	    for(new i = fnum[ playerid ] - 1; i > -1; i --)
		{
		    if( GetPVarInt( playerid, "fcategory" ) == FurnitureList[ i ][ fCategory ] )
		    {
				fnum[ playerid ] = i;
				full = true;
				break;
			}
		}

		if( full == false )
		{
		    for(new i = fnum[ playerid ]; i != sizeof FurnitureList; i ++)
			{
			    if( GetPVarInt( playerid, "fcategory" ) == FurnitureList[ i ][ fCategory ] )
			    {
					fnum[ playerid ] = i;
				}
			}
		}

	    if( furnitureid[ playerid ] != 0 ) DestroyPlayerObject( playerid, furnitureid[ playerid ] );
	    
	    id = FurnitureList[ fnum[ playerid ] ][ fID ];

	    furnitureid[playerid] = CreatePlayerObject( playerid, _itemsInfo[ id ][ invObject ], 1779.84, -1994.25, 999.31 + FurnitureList[ fnum[ playerid ] ][ fPosZ ],   0.00, 0.00, 143.46 + FurnitureList[ fnum[ playerid ] ][ fAngle ], 200.0 );

	    format:str_small("%s", _itemsInfo[ id ][ invName ]);
		FixText( str_small );

		TextDrawSetString( ftextdrawp[0][playerid], str_small );

		str_small[0] = EOS;
		
	    format:str_least( "%dP", FurnitureList[ fnum[ playerid ] ][ fPrice ] );

	    TextDrawSetString( ftextdrawp[1][playerid], str_least );

	    str_least[0] = EOS;

	    PlayerPlaySound(playerid,1150,0.0,0.0,0.0);

		return 1;
	}
	
	
    ////////////////////////////// ����� ����� ����� UCP ///////////////////////

