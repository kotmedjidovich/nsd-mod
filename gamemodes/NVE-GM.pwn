public:ShowSearchCars( playerid )
{
	ClearVar();

	new
		rows = cache_get_row_count(),
		count,
		name[24],
		nomer[24],
		color[30];

	for ( new i = GetPVarInt( playerid, "search_list" ); i < rows; i++ )
	{
		count++;
		if( count == 26 ) break;

		cache_get_field_content ( i, "search_name", name, mysql_connect_ID, MAX_PLAYER_NAME );
		cache_get_field_content ( i, "search_color", color, mysql_connect_ID, 30 );
		cache_get_field_content ( i, "search_number", nomer, mysql_connect_ID, 30 );

		format:str_small(""C_WHITE"�%d [%s]: "C_GRAY"%s - %s - %s...\n",
		cache_get_field_content_int ( i, "search_id", mysql_connect_ID ),
		timec( cache_get_field_content_int ( i, "search_date", mysql_connect_ID ) ),
		name,
		nomer,
		color );

		strcat( str_big, str_small );
	}

	if( count == 0 )
	{
		SCM(playerid, -1,"���� ������ - �����!");
		SPD( playerid, dFrak+15, list, ""C_GRAY"���� ������ ���", search_text, "��", "�������" );
		return 1;
	}

	if( count == 26 ) return SPD(playerid, dSearchCars+1, info, ""C_GRAY"���� ������������� �����������", str_big, "�����", "�����");
	return SPD(playerid, dSearchCars+1, info, ""C_GRAY"���� ������������� ����������", str_big, "�����", "");
}

