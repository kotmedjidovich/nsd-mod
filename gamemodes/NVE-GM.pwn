CMD:repair(playerid)
{
	if( pInfo[playerid][pOrg][0] <= 0 ) return SCM(playerid,-1,"� ��� ��� ������� � ���� �������!");
    if( oInfo[pInfo[playerid][pOrg][0]][oType] != 1) return SCM(playerid,-1,"� ��� ��� ������� � ���� �������!");
    
    new n = oInfo[pInfo[playerid][pOrg][0]][oNed];
    if( IsPlayerInRangeOfPoint(playerid, 20.0,nInfo[n][nPick][0],nInfo[n][nPick][1],nInfo[n][nPick][2]) || IsPlayerInRangeOfPoint(playerid, 20.0,nInfo[n][nExite][0],nInfo[n][nExite][1],nInfo[n][nExite][2]))
	{
	    new Float:posx, Float:posy, Float:posz;
		new Float:oldposx, Float:oldposy, Float:oldposz, bool:found = false;
	
	    for(new cars; cars != MAX_VEHICLES; cars++)
		{
			if(INVALID_VEHICLE_ID != cars)
			{
				GetVehiclePos(cars, oldposx, oldposy, oldposz);
				GetPlayerPos(playerid,posx, Float:posy, Float:posz);
				new Float: tempposx = (oldposx -posx);
				new Float: tempposy = (oldposy -posy);
				new Float: tempposz = (oldposz -posz);
				if (((tempposx < 3.0) && (tempposx > -3.0)) && ((tempposy < 3.0) && (tempposy > -3.0)) && ((tempposz < 3.0) && (tempposz > -3.0)))
				{
					for( new i; i != LoadAllCar; i++ )
					{
						if( cars == cInfo[i][cCar] )
						{
							found = true;

							format:str_cmd("\
							" #C_GRAY "�����/������:\t{ffffff}%s\n\
							" #C_GRAY "��������:\t\t{ffffff}%s\n\
							" #C_GRAY "�������� ����:\t{ffffff}%s\n\n\
							�� ������ ������� ��������� ���� ��� ����� ���������� ?",
							GetCarMark(cInfo[i][cModel]), cInfo[i][cOwner], cInfo[i][cNumber]);
							
							foreach(Player,z) { if(!strcmp(cInfo[i][cOwner],pInfo[z][pName],true)) { SetPVarInt(playerid,"repairpID",z); } }
							SetPVarInt(playerid,"repaircar",i);

							SPD(playerid,dRepair,info," ",str_cmd,"�����","���");
							return 1;
						}
					}

					if(found==false) return SCM(playerid,-1,"�� ������ ������������� ������ ������ ��������� �������");
					continue;
				}
				else
				{
					continue;
				}
			}
		}
	}
	else return SCM(playerid,-1,"�� ������ ���������� � ������ ��� ��� ����� ������ � ����");
	SCM(playerid,-1, "���������� ��������� �� ������!");
	return 1;
}

CMD:buyfuel(playerid, params[])
{
    if( pInfo[playerid][pOrg][0] > 0 )
    {
        if(strcmp(oInfo[ pInfo[playerid][pOrg][0] ][oLeader],pInfo[playerid][pName],true)) return SCM(playerid,-1,"�� �� ��������� �������!");
        if( oInfo[ pInfo[playerid][pOrg][0] ][ oType ] != 1 ) return SCM(playerid, -1, "�� �� ��������� ������� ����������� ����: ���");
    
        new
			bool:found = false,
			count;
			
    	for(new i; i != LoadAllNed; i++)
	    {
		    if(IsPlayerInRangeOfPoint(playerid,6.0,nInfo[i][nPick][0],nInfo[i][nPick][1],nInfo[i][nPick][2]))
		    {
		        if(sscanf(params, "dd", params[0], params[1])) return SCM(playerid, COLOR_WHITE, "�����������: /buyfuel [���������� �������] [1 - �������� �� 10 ������ | 2 - �������� �� 20 ������]"), SCM(playerid, COLOR_WHITE, "���� �������� �� 10 ������ - 150� | ���� �������� �� 20 ������ - 250�");
		        
				if( params[0] > 50 ) return SCM( playerid, -1, "�� �� ������ ������ ������ 50 �������!");
				
				if( params[1] > 2 || params[1] < 1 ) return SCM( playerid, -1, "����������� ����� 1 - (10 ������) ��� ����� 2 - (20 ������)");
				
				for( new z; z != 10; z++ )
				{
					if(_invPlayer[playerid][invSlot][z] == 375 || _invPlayer[playerid][invSlot][z] == 376) count++;
				}
				
				if( count >= 20 ) return SCM(playerid, -1, "�� �� ������ ���������� � ����� ������, ��� 20 �������!");
				
				if( params[1] == 1 )
				{
				    if( params[0] * 150 > pInfo[playerid][pMoney] ) return SCM( playerid, -1, "��� �� ������� ����� �� ������� �������!");
				    
				    if(IsSpace(playerid,375)) return SCM(playerid, -1,"� ��� �� ������� ����� � ���������!");
				    
				    GivePlayerItem(playerid,375,params[0]);
				    
					GiveMoney(playerid,-params[0] * 150);
					
					SendMes(playerid, -1,"�� ������� �������� %d ������� 10L �� %d�", params[0], params[0]*150);
				    
				    return 1;
				}
		        
		        if( params[1] == 2 )
				{
				    if( params[0] * 250 > pInfo[playerid][pMoney] ) return SCM( playerid, -1, "��� �� ������� ����� �� ������� �������!");
				    
				    if(IsSpace(playerid,376)) return SCM(playerid, -1,"� ��� �� ������� ����� � ���������!");
				    
				    GivePlayerItem(playerid,376,params[0]);
				    
				    GiveMoney(playerid,-params[0] * 250);
				    
					SendMes(playerid, -1,"�� ������� �������� %d ������� 20L �� %d�", params[0], params[0]*250);
				    
				    return 1;
				}
		        
		        found = true;
		        break;
		    }
		}
		
		if( found == false ) return SCM( playerid, -1, "�� ������ ���������� �� ��������!");
	}
	else return SCM( playerid, -1, "�� �� �������� � ����������� ��� �� ��������� �� �������!");
	
	return 1;
}
CMD:tow(playerid)
{
	if(!IsPlayerInAnyVehicle(playerid)) return SCM(playerid,-1,"�� ������ ���������� � ����������");
	
    if(pInfo[playerid][pFrak] != 0 || pInfo[playerid][pOrg][0] > 0)
    {
    new car = GetPlayerVehicleID(playerid);
    
    if(pInfo[playerid][pFrak] == 3 && car >= gibdd[0] && car <= gibdd[25] && GetPlayerVehicleSeat(playerid)==0)
	{
		//if(pInfo[playerid][pFrak]!=3) return RemovePlayerFromVehicle(playerid), SCM(playerid,-1,"� ��� ��� ����� �� ����� ����������!");
		if(GetVehicleModel(car)!=525) return SCM(playerid,-1,"����� ��������� ���������, �� ������ ���������� � ����������!");
	}
	
	if( pInfo[playerid][pOrg][0] > 0 )
	{
 		if( oInfo[ pInfo[playerid][pOrg][0] ][oType] != 1 || GetVehicleModel(car) != 525 ) return SCM(playerid,-1,"�� ������ �������� � ��� � ���������� � ����������");
 	}
 	
 	if(GetVehicleModel(car)!=525) return 1;
	
    if(pInfo[playerid][pFrak] == 2 ||pInfo[playerid][pFrak] == 3 || oInfo[ pInfo[playerid][pOrg][0] ][oType] == 1)
	{
	    //new Float:x, Float:y, Float:z;
		//GetBootVehiclePos(car,x,y,z);
		
		if(IsTrailerAttachedToVehicle(car))
		{
		    DetachTrailerFromVehicle(car);
		    SCM(playerid,-1,"�� �������� ��������� �� ����������!");
		    return 1;
		}
		
		new Float:posx, Float:posy, Float:posz, bool:found = false;
  		new Float:oldposx, Float:oldposy, Float:oldposz;
  		new Float:tempposx, Float:tempposy, Float:tempposz;
  		new Float:Radi=6.0;        //���������� �� �����
  		new Float:AngRange=90.0;    //������������ ������
  		
  		new Float:plAngle;    GetVehicleZAngle(car, plAngle);
    	new Float:crAngle,Float:Angle,Float:Angle2;
		
		for(new i = 0; i < MAX_VEHICLES; i++)   
  		{
		    if(i == car) continue;

			GetVehiclePos(car, posx, posy, posz);
			GetVehiclePos(i, oldposx, oldposy, oldposz);
			tempposx = (oldposx -posx);
			tempposy = (oldposy -posy);
			tempposz = (oldposz -posz);
			if (((tempposx < Radi) && (tempposx > -Radi)) && ((tempposy < Radi) && (tempposy > -Radi)) && ((tempposz < Radi) && (tempposz > -Radi)))
			{
				GetVehicleZAngle(i, crAngle);  
				Angle = (plAngle -crAngle);    
				Angle2= (Angle-180.0);     
				if (( ((Angle < AngRange) && (Angle > -AngRange)) || ((Angle2 < AngRange) && (Angle2 > -AngRange)) ))
				{
					AttachTrailerToVehicle(i, car);
					SCM(playerid,-1,"�� ��������� ��������� � ����������");
					if( pInfo[playerid][pOrg][0] <= 0 ) SCM(playerid,-1,"������������� �� " #C_GRAY "�/� {ffffff}��� ������ ���� " #C_GRAY "(/gps > ������ > 9)");
					SCM(playerid,-1,"����� �������� ��������� �� ����������, ������� " #C_GRAY "/tow {ffffff}��� ���!");
					found = true;
					break;
				}
			}
		}
		if(found == false) SCM(playerid, -1, "���������� ��������� - �� ������ !");
	}
	else return SCM(playerid,-1,"�� �� �������� �� � ����� �� ���666����!");
	}
	else return SCM(playerid,-1,"�� �� �������� �� � ����� �� �������!");
	return 1;
}

CMD:arrestcar(playerid)
{
    if(!IsPlayerInRangeOfPoint(playerid, 10.0,	-402.9427,1042.8436,12.0779)) return SCM(playerid,-1,"�� ������ ���������� ����� �/�! " #C_GRAY "(/gps > ������ > 9)");
	if(!IsPlayerInAnyVehicle(playerid)) return SCM(playerid,-1,"�� ������ ���������� � ����������");
    if(pInfo[playerid][pFrak]==0) return SCM(playerid,-1,"�� �� �������� �� � ����� �� �������!");
    new car = GetPlayerVehicleID(playerid);
    if(car >= gibdd[0] && car <= gibdd[25] && GetPlayerVehicleSeat(playerid)==0)
	{
		if(pInfo[playerid][pFrak]!=3) return RemovePlayerFromVehicle(playerid), SCM(playerid,-1,"� ��� ��� ����� �� ����� ����������!");
		if(GetVehicleModel(car)!=525) return SCM(playerid,-1,"����� ��������� ���������, �� ������ ���������� � ����������!");
	}
	else
	{
	    SCM(playerid,-1,"�� ������ ���������� �� ����� ���������� �����!");
	    return 1;
	}
    if(pInfo[playerid][pFrak]==3)
	{
		if(IsTrailerAttachedToVehicle(car))
		{
		    new id = GetVehicleTrailer(car),
		        bool:found = false;

		    for( new i; i != LoadAllCar; i++ )
			{
				if( id == cInfo[i][cCar] )
				{
					found = true;

					format:str_cmd("\
					" #C_GRAY "�����/������:\t{ffffff}%s\n\
					" #C_GRAY "��������:\t\t{ffffff}%s\n\
					" #C_GRAY "�������� ����:\t{ffffff}%s\n\
					" #C_GRAY "�������� ����:\t{ffffff}%d\n\n\n\
					������� ������� ������ ���������� ������������� ��������:\n  - ���������� �� ����� 128 ��������(����)",
					GetCarMark(cInfo[i][cModel]), cInfo[i][cOwner], cInfo[i][cNumber], UnixDay( cInfo[i][cDate] ) );

					SetPVarInt(playerid,"arrestcar",i);

					SPD(playerid,dFrak+13,input,"" #C_GRAY "����� ����������",str_cmd,"�����","�������");

					break;
				}
			}

			if(found==false) return SCM(playerid,-1,"�� �� ������ ���������� ������ ���������, ��� ��� �� �� �������� ������!");

		    return 1;
		}
		else
		{
		    SCM(playerid,-1,"� ������ ���������� ��� ������������� ����������!");
			return 1;
		}
	}
	return 1;
}

