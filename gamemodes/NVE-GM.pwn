CMD:rem(playerid)//tamasita*
{
    if(!IsPlayerInAnyVehicle(playerid)||!PlayerInCAR(playerid)||GetPlayerVehicleSeat(playerid) >= 2) return 1;
	if(GetPVarInt(playerid,"remen") == 0) SetPVarInt(playerid,"remen",1), cmd::ame(playerid,"���������� ������ ������������"), PlayerPlaySound(playerid, 2021, 0.0, 0.0, 0.0);
	else SetPVarInt(playerid,"remen",0), cmd::ame(playerid,"��������� ������ ������������"), PlayerPlaySound(playerid, 2020, 0.0, 0.0, 0.0);
	return 1;
}

CMD:checkrem(playerid)//Tamasita*
{
	if(pInfo[playerid][pFrak] == 3)
	{
	    if(GetPVarInt(playerid,"duty")!=1) return SCM(playerid,-1,"�� �� ����� ��������� �� ���." #C_ABILITY " (�� �� �� ���������)");
	    new Float:p1,Float:p2,Float:p3;
	    cmd::ame(playerid,"������������ � ���������� ���������� � ��������� ������ �� ����� ������������");
	    foreach(Player, i)
	    {
	    	GetPlayerPos(playerid,p1,p2,p3);
	        if(IsPlayerInAnyVehicle(i) && GetPlayerVehicleSeat(i) < 2 && IsPlayerInRangeOfPoint(i, 15.0,p1,p2,p3) && PlayerInCAR(i))
	        {
	    		new model = GetVehicleModel(GetPlayerVehicleID(i));
	            if(GetPVarInt(i,"remen") == 0)
	            {
                    if(GetPlayerVehicleSeat(i) == 0) format:str_small( "�������� %s %s - �� ���������",GetCarMark(model), pInfo[i][pName]);
                    else if(GetPlayerVehicleSeat(i) == 1) format:str_small( "�������� %s %s - �� ���������", GetCarMark(model),pInfo[i][pName]);
                    SCM(playerid,-1,str_small);
	            }
	            else
				{
                    if(GetPlayerVehicleSeat(i) == 0) format:str_small( "�������� %s %s - ���������", GetCarMark(model),pInfo[i][pName]);
                    else if(GetPlayerVehicleSeat(i) == 1) format:str_small( "�������� %s %s - ���������", GetCarMark(model),pInfo[i][pName]);
                    SCM(playerid,-1,str_small);
	            }
			}
	    }
	}
	else return SCM(playerid,-1,"�� �� �������� � ������");
	return 1;
}

CMD:pullout(playerid, params[])
{
	if(pInfo[playerid][pFrak]==0) return SCM(playerid,-1,"�� �� �������� �� � ����� �� �������");
    if(pInfo[playerid][pFrak]==1 || pInfo[playerid][pFrak]==2 || pInfo[playerid][pFrak]==3)
	if(GetPVarInt(playerid,"duty")!=1) return SCM(playerid,-1,""#C_GRAY "(�� �� �� ���������)");
    if(sscanf(params, "d", params[0])) return SCM(playerid, COLOR_WHITE, "�����������: /pullout [�� ������, �������� �� ������ ������� ����]");
    if(!IsPlayerConnected(params[0])) return SCM(playerid,-1,"������ � ����� ID ��� �� �������");
    if(params[0]==playerid) return SCM(playerid,-1,"�� �� ������ ������� ��� �������� ���� � �����");
    new Float: p1, Float: p2, Float: p3;
	GetPlayerPos(playerid,p1,p2,p3);
	if(!IsPlayerInRangeOfPoint(params[0], 3.0, p1, p2, p3))
  	{
		new animlib[32], animname[32];
  		GetAnimationName(1138,animlib,32,animname,32);
  		ApplyAnimation(playerid,animlib,animname,8.1,0,0,0,0,0);
		if(GetPVarInt(playerid,"mask") != 0) format:str_small("%s ����� ������ ����������, ������ �����, ������� �������� (����� [%d]) � ������� ���� �� �����.",pInfo[playerid][pName],GetPVarInt(playerid,"mask"));
		else format:str_small("%s ����� ������ ����������, ����� ������ �����, ������� %s � ������� ���� �� ����� .",pInfo[playerid][pName], pInfo[params[0]][pName]);
		ProxDetector(20.0,playerid,str_small,0xAF5DD2FF,0xAF5DD2FF,0xAF5DD2FF,0xAF5DD2FF,0xAF5DD2FF);
		RemovePlayerFromVehicle(params[0]);
		GetAnimationName(1151,animlib,32,animname,32);
		ApplyAnimation(params[0],animlib,animname,8.1,0,0,0,1,0);
		SetPVarInt(params[0],"timek",21);
    }
	return true;
}

