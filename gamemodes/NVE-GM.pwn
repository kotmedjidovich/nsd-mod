    strmid(cInfo[i][cNumber], "Q", 0, strlen("Q"), 24);
    strmid(cInfo[i][cNumber2], "Q", 0, strlen("Q"), 24);
    strmid(cInfo[i][cNumber3], "Q", 0, strlen("Q"), 24);
    strmid(cInfo[i][cNumber4], "Q", 0, strlen("Q"), 24);
