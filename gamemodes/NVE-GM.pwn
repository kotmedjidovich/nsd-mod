CMD:gps(playerid)
{
    if(GetPVarInt(playerid,"bjob") == 1) return SCM(playerid,-1,"� ������ ������ �� �� ������ ������������ GPS");
    if(GetPVarInt(playerid,"truck") == 1) return SCM(playerid,-1,"� ������ ������ �� �� ������ ������������ GPS");
	if(GetPVarInt(playerid,"gps") == 1) DeletePVar(playerid,"gps"), DisablePlayerCheckpoint(playerid), SCM(playerid,-1,"GPS ��������");
	SPD(playerid,dGps, list,"{658c6a}GPS ���������","{658c6a}1. {ffffff}������ �����\n{658c6a}2. {ffffff}������\n{658c6a}3. {ffffff}�����������\n{658c6a}4. {ffffff}�����\n{658c6a}5. {ffffff}������\n{658c6a}6. {ffffff}��������� �����","��","�������");
	return 1;
}

CMD:firegps(playerid)
{
    if(GetPVarInt(playerid,"bjob")==1) return SCM(playerid,-1,"� ������ ������ �� �� ������ ������������ GPS");
    if(GetPVarInt(playerid,"truck")==1) return SCM(playerid,-1,"� ������ ������ �� �� ������ ������������ GPS");
    if(pInfo[playerid][pFrak] == 1 || pInfo[playerid][pFrak] == 2 || pInfo[playerid][pFrak] == 3 || pInfo[playerid][pFrak] == 4 || pInfo[playerid][pFrak] == 5 || pInfo[playerid][pFrak] == 6)
	{
		if(GetPVarInt(playerid,"gps")==1) return DeletePVar(playerid,"gps"), DisablePlayerCheckpoint(playerid), SCM(playerid,-1,"GPS ��������");
		if(fireas == 0) return SCM(playerid,-1,"� ������ ������ ������� ���������� - ���!");
		if(fireas == 1) SCM(playerid,-1,"{658c6a}� ��� �� ����� ���� ��������: ����� ����������"), SetPlayerCheckpoint(playerid,262.15, 1805.80, 11.00,5.0);
		if(fireas == 2) SCM(playerid,-1,"{658c6a}� ��� �� ����� ���� ��������: ����� ����������"), SetPlayerCheckpoint(playerid,-316.06, 423.36, 11.62,5.0);
		if(fireas == 3) SCM(playerid,-1,"{658c6a}� ��� �� ����� ���� ��������: ����� ����������"), SetPlayerCheckpoint(playerid,-158.10, 603.84, 11.12,5.0);
		if(fireas == 4) SCM(playerid,-1,"{658c6a}� ��� �� ����� ���� ��������: ����� ����������"), SetPlayerCheckpoint(playerid,-938.07, 1186.74, 9.87,5.0);
	 	return SCM(playerid,-1,"����� ��������� GPS-���������, ������� /gps ��� ���"), SetPVarInt(playerid,"gps",1);
	}
	else return SCM(playerid,-1,"� ��� ��� ������� � ���� �������!");
}

CMD:createned(playerid)
{
	if(IsAdmin(playerid, 5)) return 1;
	SPD(playerid,dNed, list,"�������� ������������","������� ���\n������� ������� ���������\n������� �����","��","�������");
	return 1;
}

CMD:nmenu(playerid)
{
    SetPVarInt(playerid,"nmenuid",-1);
	new sum;
	for(new i; i != LoadAllNed; i++)
	{
		if(!strcmp(nInfo[i][nOwner],pInfo[playerid][pName],true))
		{
			SetPVarInt(playerid,"nmenuid",i);
			format:str_small("%s | �����: " #C_GRAY "%d\n",GetPropertyType(i),i);
			strcat(str_big,str_small);
			sum++;
		}
	}
	if(GetPVarInt(playerid,"nmenuid")==-1) return SCM(playerid,-1,"�� �� ������� �������������");
	
	if(sum==1)
	{
		return nmenu(playerid,GetPVarInt(playerid,"nmenuid")), str_big[0] = EOS;
	}
	return SPD(playerid,dNed+4,list,"" #C_GRAY "���� ������������",str_big,"��","�������"), str_big[0] = EOS;
}

CMD:exit(playerid)
{
	if(GetPVarInt(playerid,"AntiFlood") > gettime()) return SCM(playerid, COLOR_WHITE, "��������������: " #C_GRAY "�� ������� !");
	
    for(new i; i != LoadAllNed; i++)
    {
    	if(IsPlayerInRangeOfPoint(playerid,7.0,nInfo[i][nPick][0],nInfo[i][nPick][1],nInfo[i][nPick][2]))
     	{
      		if(nInfo[i][nLock] != 0) return SCM(playerid, -1, "������ �������");
        	if(nInfo[i][nType]==4) return 1;
       		SetPlayerPosF(playerid, nInfo[i][nExite][0],nInfo[i][nExite][1],nInfo[i][nExite][2],0);
         	SetPlayerVirtualWorld(playerid, nInfo[i][nInt]);
         	break;
      	}
      	else if(IsPlayerInRangeOfPoint(playerid,7.0,nInfo[i][nExite][0],nInfo[i][nExite][1],nInfo[i][nExite][2]) && GetPlayerVirtualWorld(playerid) == nInfo[i][nInt])
		{
 			if(nInfo[i][nLock] != 0) return SCM(playerid, -1, "����� �������");
		    if(nInfo[i][nType]==4) return 1;
		    SetPlayerPosF(playerid, nInfo[i][nPick][0],nInfo[i][nPick][1],nInfo[i][nPick][2],0);
		    SetPlayerVirtualWorld(playerid, 0);
		    break;
      	}
 	}

 	return SetPVarInt(playerid,"AntiFlood",gettime() + 1);
}

CMD:suka(playerid)
{
	new string[128];
	format(string, sizeof(string), "��� - %d", pInfo[playerid][pOrg][0]);
	SendClientMessage(playerid, -1, string);
	return 1;
}

CMD:omenu(playerid)
{
	if(pInfo[playerid][pOrg][0] <= 0) return SCM(playerid,-1,"� ��� ��� ������� � ������ �������!");
    if(strcmp(oInfo[ pInfo[playerid][pOrg][0] ][oLeader],pInfo[playerid][pName],true)) return SCM(playerid,-1,"�� �� ��������� �������!");
    format:str_small("" #C_GRAY "���������� ������������ %s", oInfo[ pInfo[playerid][pOrg][0] ][oName]);
	SPD(playerid,dOrg+1, list, str_small ,"" #C_GRAY "1.{FFFFFF} ����������\n" #C_GRAY "2.{FFFFFF} ����������\n" #C_GRAY "3.{FFFFFF} ����������\n" #C_GRAY "4.{FFFFFF} �������\n" #C_GRAY "5.{FFFFFF} ���������\n" #C_GRAY "6.{FFFFFF} ������������ �����������\n" #C_GRAY "7.{FFFFFF} ������ �����������","��","�������");
	return 1;
}

CMD:fmenu(playerid)
{
	if(pInfo[playerid][pRang] == 5) SPD(playerid,dFrak+1,list,"" #C_GRAY "���������� ��������","" #C_GRAY "1.{FFFFFF} ����������\n" #C_GRAY "2.{FFFFFF} ����������\n" #C_GRAY "3.{FFFFFF} �������","��","�������");
	return 1;
}

