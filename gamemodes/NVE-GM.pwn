		{
			itemkol = true;
			nInv[id][ninvSlot][i] = item;
			nInv[id][ninvSlotKol][i] = kol;
			SaveNinventory(id);
			return 1;
		}
  		if(itemv==false)
		{
			for(new z; z != 20; z++)
			{
				if(nInv[id][ninvSlot][z] == item) return nInv[id][ninvSlotKol][z] += kol, itemkol = true, SaveNinventory(id);
