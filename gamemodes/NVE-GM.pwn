GetFrakName(i,t)
{
	if(t==0) { switch(i) { case 1: format:str_small("����"); case 2: format:str_small("�����"); case 3: format:str_small("������"); case 4: format:str_small("�������������"); case 5: format:str_small("��� �15"); case 6: format:str_small("���� �54"); case 7: format:str_small("���"); } }
	if(t==1)
	{
		switch(i)
		{
			case 1: format:str_small("���������� ��� �� �� ������������� �������"); case 2: format:str_small("����� ��������� ������� ����������"); case 3: format:str_small("���� ������ �� ������������� �������");
			case 4: format:str_small("������������� ������������� �������"); case 5: format:str_small("�������� ����� �15 �� ���. ��������"); case 6: format:str_small("����������� ����������� ����� �4"); case 7: format:str_small("����������������� \"�����������-24\"");
		}
	}
	return str_small;
}

UpdateBusText(playerid)
{
    new id;
	DestroyDynamic3DVehicle( bustext[GetPVarInt(playerid,"jobcar")], GetPVarInt(playerid,"jobcar") );
    if(GetPVarInt(playerid,"way")==12) format:str_least("���������� ����� � 10%d\n{FFCF0B}������� �12",id);
    if(GetPVarInt(playerid,"way")==27) format:str_least("���������� ����� � 10%d\n{FFCF0B}������� �27",id);
    if(GetPVarInt(playerid,"way")<5) format:str_least("���������� ����� � 10%d",id);
    bustext[GetPVarInt(playerid,"jobcar")] = CreateDynamic3DTextLabel(str_least, 0xFFFFFFFF, 0.0, 0.0, 2.25, 50.0, INVALID_PLAYER_ID, GetPVarInt(playerid,"jobcar"),1,-1,-1,-1,50.0);
	return 0;
}

