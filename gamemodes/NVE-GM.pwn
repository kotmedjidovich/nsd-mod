GiveNedItem(id,item,kol,price)
{
	new bool:itemkol = false, bool:itemv = false;
	//for(new i; i != 56; i++) kg += _itemsInfo[_invPlayer[playerid][invSlot][i]][invKg];
	//if(kg + _itemsInfo[item][invKg] > MAX_PLAYER_KG) return SCM(playerid,-1,"�� ��� � ��� ������ ����� ����� � �����!");
	for(new i; i != 20; i++)
	{
		if(nInv[id][ninvSlot][i] == 0)
		{
			itemkol = true;
			nInv[id][ninvSlot][i] = item;
			nInv[id][ninvSlotKol][i] = kol;
			nInv[id][ninvSlotPrice][i] = price;
			SaveNinventory(id), DeletePVar(id,"playerid");
			return 1;
		}
		if(itemv==false)
		{
			for(new z; z != 20; z++)
			{
				if(nInv[id][ninvSlot][z] == item)
				{
					return nInv[id][ninvSlotKol][z] += kol, itemkol = true, SaveNinventory(id), DeletePVar(id,"playerid");
				}
			}
			itemv=true;
		}
	}
	if(itemkol == false) return SCM(GetPVarInt(id,"playerid"),-1,"� ����� ������������ �� ������� �����!");
	return 1;
}

GiveCarItem(playerid,id,item,kol)
{
	new bool:itemkol = false, bool:itemv = false;
	//for(new i; i != 56; i++) kg += _itemsInfo[_invPlayer[playerid][invSlot][i]][invKg];
	//if(kg + _itemsInfo[item][invKg] > MAX_PLAYER_KG) return SCM(playerid,-1,"�� ��� � ��� ������ ����� ����� � �����!");
	for(new i; i != 15; i++)
	{
		if(cInv[id][cinvSlot][i] == 0)
		{
			itemkol = true;
			cInv[id][cinvSlot][i] = item;
			cInv[id][cinvSlotKol][i] = kol;
			SaveCinventory(id);
			return 1;
		}
  		if(itemv==false)
		{
			for(new z; z != 15; z++)
			{
				if(cInv[id][cinvSlot][z] == item) return cInv[id][cinvSlotKol][z] += kol, itemkol = true, SaveCinventory(id);
			}
			itemv=true;
		}
	}
	if(itemkol == false) return SCM(playerid,-1,"� ��������� ������������ ����� ��� ����� ��������!");
	return 1;
}

GivePropertyItem(playerid,id,item,kol)
{
	new bool:itemkol = false, bool:itemv = false;
	//for(new i; i != 56; i++) kg += _itemsInfo[_invPlayer[playerid][invSlot][i]][invKg];
	//if(kg + _itemsInfo[item][invKg] > MAX_PLAYER_KG) return SCM(playerid,-1,"�� ��� � ��� ������ ����� ����� � �����!");
	for(new i; i != 20; i++)
	{
