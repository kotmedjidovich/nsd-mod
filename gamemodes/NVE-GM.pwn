public OnPlayerCommandReceived(playerid, cmdtext[])
{
	if(GetPVarInt(playerid,"gLogged") == 0) return 0;
	
	ClearVar();
	printf("[%s] %s",pInfo[playerid][pName],cmdtext);
	
	if(GetPVarInt(playerid,"editfrakobject") == 1) { SCM(playerid,-1,"��������� �������������� �������!"); return 0; }
	if(GetPVarInt(playerid,"editobject") == 1)
	 { SCM(playerid,-1,"��������� �������������� �������!"); return 0; }
	if(GetPVarInt(playerid,"editcarattach") != 0) { SCM(playerid,-1,"��������� �������������� �������!"); return 0; }
	return 1;
}
public OnPlayerCommandPerformed(playerid, cmdtext[], success)
{
	return 1;
}

public OnPlayerEnterVehicle(playerid, vehicleid, ispassenger)
{
	if(GetPVarInt(playerid,"death") == 1 || GetPVarInt(playerid,"death") == 2) return RemovePlayerFromVehicle(playerid), SetPlayerPos(playerid, pInfo[playerid][pCor][0], pInfo[playerid][pCor][1], pInfo[playerid][pCor][2]), ApplyAnimation(playerid, "CRACK", "crckdeth2", 4.1, 0, 0, 0, 1, 0);
	return 1;
}

public OnPlayerExitVehicle(playerid, vehicleid)
{
    if(vehicleid >= acar_b[0] && vehicleid <= acar_b[3]) { if(GetPVarInt(playerid,"go")==2 && GetPVarInt(playerid,"ekzamen")==1) return RemovePlayerFromVehicle(playerid), SCM(playerid,-1,"�� ��������� ��� �������"), SetVehicleToRespawn(vehicleid), DeletePVar(playerid,"go"), DeletePVar(playerid,"LESSON"), DeletePVar(playerid,"practicexam"), DeletePVar(playerid,"oshibka"), DeletePVar(playerid,"testnum"), DeletePVar(playerid,"ekzamen"),DisablePlayerRaceCheckpoint(playerid); }
    if(vehicleid >= acar_a[0] && vehicleid <= acar_a[1]) { if(GetPVarInt(playerid,"go")==1 && GetPVarInt(playerid,"ekzamen")==1) return RemovePlayerFromVehicle(playerid), SCM(playerid,-1,"�� ��������� ��� �������"), SetVehicleToRespawn(vehicleid), DeletePVar(playerid,"go"), DeletePVar(playerid,"LESSON"), DeletePVar(playerid,"practicexam"), DeletePVar(playerid,"oshibka"), DeletePVar(playerid,"testnum"), DeletePVar(playerid,"ekzamen"),DisablePlayerRaceCheckpoint(playerid); }
    if(vehicleid >= acar_c[0] && vehicleid <= acar_c[2]) { if(GetPVarInt(playerid,"go")==3 && GetPVarInt(playerid,"ekzamen")==1) return RemovePlayerFromVehicle(playerid), SCM(playerid,-1,"�� ��������� ��� �������"), SetVehicleToRespawn(vehicleid), DeletePVar(playerid,"go"), DeletePVar(playerid,"LESSON"), DeletePVar(playerid,"practicexam"), DeletePVar(playerid,"oshibka"), DeletePVar(playerid,"testnum"), DeletePVar(playerid,"ekzamen"),DisablePlayerRaceCheckpoint(playerid); }
    if(vehicleid >= acar_d[0] && vehicleid <= acar_d[2]) { if(GetPVarInt(playerid,"go")==4 && GetPVarInt(playerid,"ekzamen")==1) return RemovePlayerFromVehicle(playerid), SCM(playerid,-1,"�� ��������� ��� �������"), SetVehicleToRespawn(vehicleid), DeletePVar(playerid,"go"), DeletePVar(playerid,"LESSON"), DeletePVar(playerid,"practicexam"), DeletePVar(playerid,"oshibka"), DeletePVar(playerid,"testnum"), DeletePVar(playerid,"ekzamen"),DisablePlayerRaceCheckpoint(playerid); }

	if(vehicleid == GetPVarInt(playerid,"jobcar"))
	{
		SetPVarInt(playerid,"stopj",20), SCM(playerid,-1,"{F04223}� ��� ���� 20 ������, ����� ��������� �� ����, ����� ���� �������� ����������");
	}

	if(vehicleid >= truck[0] && vehicleid <= truck[1] && GetPlayerVehicleSeat(playerid)==0 && GetPVarInt(playerid,"truck")==1) SetPVarInt(playerid,"deltruck",61), SCM(playerid,-1,"���� �� ������ ������ �� ����, ���� �������� ����� ������������");
	if(vehicleid >= taxi[0] && vehicleid <= taxi[1] && GetPlayerVehicleSeat(playerid)==0 && GetPVarInt(playerid,"taxi")==1 && GetPVarInt(playerid,"taxitype")!=0) SetPVarInt(playerid,"deltaxi2",61), SCM(playerid,-1,"��������� � ����������, ����� ���� �������� ����� ������������");
	if(vehicleid >= taxi[0] && vehicleid <= taxi[1] && GetPlayerVehicleSeat(playerid)!=0)
	{
		new dr=GetPVarInt(playerid,"taxipp");
		if(GetPVarInt(GetPVarInt(playerid,"taxipp"),"plata")==0) return textdrawtaxi(dr,0,0,0,0,0,1), DeletePVar(dr,"perevoz"),DeletePVar(dr,"s"),DeletePVar(dr,"plata"),DeletePVar(dr,"taxip"),DeletePVar(playerid,"taxipp"),DeletePVar(playerid,"pperevoz");

        pformat:( "{FFD918}�� �������� ����� � �������� �������� %d ���",GetPVarInt(dr,"plata"));
		psend:( playerid, COLOR_WHITE );
		
		pformat:( "{FFD918}%s ������� ���� ����� � �������� ��� %d ���",pInfo[playerid][pName],GetPVarInt(dr,"plata"));
		psend:( dr, COLOR_WHITE );

		GiveMoney(playerid,-GetPVarInt(dr,"plata"));
		
	    SetPVarInt(dr,"zarplata",GetPVarInt(dr,"zarplata")+GetPVarInt(dr,"plata")),
		textdrawtaxi(dr,0,0,0,0,0,1),
		DeletePVar(dr,"perevoz"),
		DeletePVar(dr,"s"),
		DeletePVar(dr,"plata"),
		DeletePVar(dr,"taxip"),
		DeletePVar(playerid,"taxipp"),
		DeletePVar(playerid,"pperevoz");
    }
    if(GetPVarInt(playerid,"remen") == 1) SetPVarInt(playerid,"remen",0), cmd::ame(playerid,"��������� ������ ������������");
    if(vehicleid == GetPVarInt(playerid,"motoid")) SetPVarInt(playerid,"delmoto",120);
	return 1;
}

public OnPlayerStateChange(playerid, newstate, oldstate)
{
	if(GetPVarInt(playerid,"gLogged")!=1) return 1;
    new newcar = GetPlayerVehicleID(playerid);
    if(GetPVarInt(playerid,"death")!=0 && IsPlayerInAnyVehicle(playerid)) return RemovePlayerFromVehicle(playerid), SetPlayerPos(playerid, pInfo[playerid][pCor][0], pInfo[playerid][pCor][1], pInfo[playerid][pCor][2]), ApplyAnimation(playerid, "CRACK", "crckdeth2", 4.1, 0, 0, 0, 1, 0);
    if(pInfo[playerid][pArrest]!=0 && IsPlayerInAnyVehicle(playerid)) return RemovePlayerFromVehicle(playerid), SetPlayerPosF(playerid,415.5716,-350.4875,1096.1500,271.3558);

	if(GetVehicleModel(newcar)==462)
	{
	
		if(GetPVarInt(playerid,"motoid")==newcar)
		{
			DeletePVar(playerid,"delmoto");
		}
		else
		{
			foreach(Player, i)
		    {
		    	if(GetPVarInt(i,"motoid")==newcar && GetPlayerVehicleSeat(playerid)!=0) { RemovePlayerFromVehicle(playerid); SCM(playerid,-1,"� ��� ��� ����� �� ����� ������"); break; }
		    }
	    }
	    
	}

	if(newcar >= bustaxi[0] && newcar <= bustaxi[9])
    {
	    if(pInfo[playerid][pJob][0]!=1) return RemovePlayerFromVehicle(playerid), SCM(playerid,-1,"�� �� ��������� ����������� " #C_GRAY "\"������������\"");
	    if(GetPVarInt(playerid,"bjob")!=1) return RemovePlayerFromVehicle(playerid), SCM(playerid,-1,"�� �� ������ ���� ������� ����");
	    if(GetPVarInt(playerid,"bjob")==1 && GetPVarInt(playerid,"bcheck")>=1) { if(GetPlayerVehicleID(playerid)!=GetPVarInt(playerid,"jobcar")) return RemovePlayerFromVehicle(playerid), SCM(playerid,-1,"��� �� ��� ������� ���������"); }
	    if(GetPVarInt(playerid,"bjob")==1 && GetPVarInt(playerid,"bcheck")<1) SPD(playerid,dJob+4,list,"" #C_GRAY "�������� �������","" #C_GRAY "1.{ffffff} ������� �12\n" #C_GRAY "2.{ffffff} ������� �27","��","");
	    if(GetPlayerVehicleID(playerid)==GetPVarInt(playerid,"jobcar")) SetPVarInt(playerid,"stopj",0);
	}

	if(newcar >= taxi[0] && newcar <= taxi[1] && GetPlayerVehicleSeat(playerid)!=0)
	{
	    foreach(Player, i)
	    {
		    if(GetPVarInt(i,"idtaxi")!=GetPlayerVehicleID(playerid)) continue;
			if(GetPlayerVehicleSeat(i)==0 && GetPlayerVehicleID(i)==GetPlayerVehicleID(playerid))
			{
				for(new id; id < MAX_VIZ; id ++)
				{
					if(viInfo[id][viPlayerid]==playerid && viInfo[id][viEnter]==1) viInfo[id][viEnter]=0,viInfo[id][viPos][0]=0,viInfo[id][viPos][1]=0,viInfo[id][viPos][2]=0,viInfo[id][viPlayerid]=0, strmid(viInfo[id][viText], "0", 0, strlen("0"), 70), vizov--; if(vizov<0) vizov=0;
				}
				
				SetPVarInt(i,"taxip",playerid), SetPVarInt(playerid,"taxipp",i);
				SCM(i,-1,"{FFD918}� ���� ����� ��� �������� {ffffff}(( ����� ������� �������� �� ����������, ������� /eject [id] ))"), SCM(i,-1,"���������, ���� ����� ���������: �������� ��� ����� �� gps ��� ��������� �� ������");
				SPD(playerid,dTaxi,list,"" #C_GRAY "�������� �������","" #C_GRAY "1. {ffffff}������� ������� �� GPS\n" #C_GRAY "2. {ffffff}��������� �������� �� ������","��","�����");
				break;
			}
		}
	}

	if(newcar >= taxi[0] && newcar <= taxi[1] && GetPlayerVehicleSeat(playerid)==0 )
	{
		if(GetPVarInt(playerid,"taxi")!=1) return RemovePlayerFromVehicle(playerid), SCM(playerid,-1,"� ��� ��� ����� �� ����� ����������");
	    if(GetPVarInt(playerid,"idtaxi")!=0)
	    {
		    if(GetPVarInt(playerid,"idtaxi")!=GetPlayerVehicleID(playerid)) return RemovePlayerFromVehicle(playerid), SCM(playerid,-1,"� ��� ��� ����� �� ����� ����������");
			DeletePVar(playerid,"deltaxi2");
		}
	    if(GetPVarInt(playerid,"taxi")==1 && GetPVarInt(playerid,"idtaxi")==0) return SPD(playerid,dJob+9,list,"" #C_GRAY "�������� ��� ������ �� ���������","" #C_GRAY "1. {ffffff}����� �� �������\n" #C_GRAY "2. {ffffff}����� �� ����������\n" #C_GRAY "3. {ffffff}��������� �����","��","�������");
	}

	if(newcar >= truck[0] && newcar <= truck[1] && GetPlayerVehicleSeat(playerid)==0)
	{
		if(GetPVarInt(playerid,"truck")!=1) return RemovePlayerFromVehicle(playerid), SCM(playerid,-1,"� ��� ��� ����� �� ���� ����");
	    if(GetPVarInt(playerid,"idtruck")!=0)
	    {
	    	if(GetPVarInt(playerid,"idtruck")!=GetPlayerVehicleID(playerid)) return RemovePlayerFromVehicle(playerid), SCM(playerid,-1,"� ��� ��� ����� �� ���� ����");
			DeletePVar(playerid,"deltruck");
		}
	    if(GetPVarInt(playerid,"truck")==1 && GetPVarInt(playerid,"idtruck")==0) return SetPlayerCheckpoint(playerid,714.2816,2262.0625,12.3600,7.0), SetPVarInt(playerid,"idtruck",GetPlayerVehicleID(playerid)), SCM(playerid,-1,"������������� �� ��������");
	}

	if(newcar >= omon[0] && newcar <= omon[18] && GetPlayerVehicleSeat(playerid)==0 ) { if(pInfo[playerid][pFrak]!=2) return RemovePlayerFromVehicle(playerid), SCM(playerid,-1,"� ��� ��� ����� �� ����� ����������"); }
	if(newcar >= gibdd[0] && newcar <= gibdd[25] && GetPlayerVehicleSeat(playerid)==0)
	{
		if(pInfo[playerid][pFrak]!=3) return RemovePlayerFromVehicle(playerid), SCM(playerid,-1,"� ��� ��� ����� �� ����� ����������");
		if(GetVehicleModel(newcar==525)) SCM(playerid,-1,"����������� ������� " #C_GRAY "/tow, {ffffff}����� ��������� ���������");
	}

	if(newcar >= mcs[0] && newcar <= mcs[7] && GetPlayerVehicleSeat(playerid)==0) { if(pInfo[playerid][pFrak]!=5) return RemovePlayerFromVehicle(playerid), SCM(playerid,-1,"� ��� ��� ����� �� ����� ����������"); }
	if(newcar >= fkc[0] && newcar <= fkc[11] && GetPlayerVehicleSeat(playerid)==0) { if(pInfo[playerid][pFrak]!=6) return RemovePlayerFromVehicle(playerid), SCM(playerid,-1,"� ��� ��� ����� �� ����� ����������"); }
	if(newcar >= trk[0] && newcar <= trk[1] && GetPlayerVehicleSeat(playerid)==0) { if(pInfo[playerid][pFrak]!=7) return RemovePlayerFromVehicle(playerid), SCM(playerid,-1,"� ��� ��� ����� �� ����� ����������"); }
	if(newcar >= ymvd[0] && newcar <= ymvd[20] && GetPlayerVehicleSeat(playerid)==0) { if(pInfo[playerid][pFrak]!=1) return RemovePlayerFromVehicle(playerid), SCM(playerid,-1,"� ��� ��� ����� �� ����� ����������"); }

	if(GetPlayerVehicleID(playerid) >= acar_b[0] && GetPlayerVehicleID(playerid) <= acar_b[3]) // ����������
	{
		if(GetPVarInt(playerid,"go")==2 && GetPVarInt(playerid,"ekzamen")==1 ) SetPlayerRaceCheckpoint(playerid,0,B_CHECK1,B_CHECK2,7.0), SetPVarInt(playerid,"practicexam",1), SetPVarInt(playerid,"LESSON",1);
    	else return RemovePlayerFromVehicle(playerid), SCM(playerid,-1,"�� �� ������ �� ����� ��� ��� �� ���� ���������");
	}

	if(GetPlayerVehicleID(playerid) >= acar_a[0] && GetPlayerVehicleID(playerid) <= acar_a[1]) // ���������
	{
		if(GetPVarInt(playerid,"go")==1 && GetPVarInt(playerid,"ekzamen")==1 ) SetPlayerRaceCheckpoint(playerid,0,B_CHECK1,B_CHECK2,7.0), SetPVarInt(playerid,"practicexam",1), SetPVarInt(playerid,"LESSON",1);
    	else return RemovePlayerFromVehicle(playerid), SCM(playerid,-1,"�� �� ������ �� ����� ��� ��� �� ���� ���������");
	}

	if(GetPlayerVehicleID(playerid) >= acar_c[0] && GetPlayerVehicleID(playerid) <= acar_c[2]) // ������
	{
		if(GetPVarInt(playerid,"go")==3 && GetPVarInt(playerid,"ekzamen")==1 ) SetPlayerRaceCheckpoint(playerid,0,B_CHECK1,B_CHECK2,7.0), SetPVarInt(playerid,"practicexam",1), SetPVarInt(playerid,"LESSON",1);
    	else return RemovePlayerFromVehicle(playerid), SCM(playerid,-1,"�� �� ������ �� ����� ��� ��� �� ���� ���������");
	}

	if(GetPlayerVehicleID(playerid) >= acar_d[0] && GetPlayerVehicleID(playerid) <= acar_d[2]) // ��������
	{
		if(GetPVarInt(playerid,"go")==4 && GetPVarInt(playerid,"ekzamen")==1 ) SetPlayerRaceCheckpoint(playerid,0,B_CHECK1,B_CHECK2,7.0), SetPVarInt(playerid,"practicexam",1), SetPVarInt(playerid,"LESSON",1);
    	else return RemovePlayerFromVehicle(playerid), SCM(playerid,-1,"�� �� ������ �� ����� ��� ��� �� ���� ���������");
	}

	// ���������
	if(newstate == PLAYER_STATE_DRIVER)
    {
        /*for(new z; z != LoadAllCar; z++)
		{
			if(!strcmp(cInfo[z][cOwner],pInfo[playerid][pName],true))
			{
		    	if(cInfo[z][cCar] == newcar)
		    	{
		    	    if(pInfo[playerid][pVip] == 0 && (cInfo[z][cModel] == 560 ||cInfo[z][cModel] == 580 || cInfo[z][cModel] == 400 || cInfo[z][cModel] == 466 || cInfo[z][cModel] == 579 || cInfo[z][cModel] == 604)) return RemovePlayerFromVehicle(playerid), SCM(playerid,-1,"��� ����, ����� ����� � ������ ���������� ��������� ��� �������!");
		    	    else if(pInfo[playerid][pVip] == 1 && (cInfo[z][cModel] == 580 || cInfo[z][cModel] == 400 || cInfo[z][cModel] == 466 || cInfo[z][cModel] == 579 || cInfo[z][cModel] == 604)) return RemovePlayerFromVehicle(playerid), SCM(playerid,-1,"����� ����� � ������ ��������� ��������� ����� ������� ������� ��� ��������!");
		    	    else if(pInfo[playerid][pVip] == 2 && (cInfo[z][cModel] == 400 || cInfo[z][cModel] == 466 || cInfo[z][cModel] == 579)) return RemovePlayerFromVehicle(playerid), SCM(playerid,-1,"����� ����� � ������ ��������� ��������� ����� ������� ������� ��� ��������!");
		    	}
			}
 		}*/
	    if(GetPVarInt(playerid,"helpengine")==1)
	    {
			SCM(playerid,0xAEAEAEFF,"����������� ������� {ffffff}\"2\" {AEAEAE}����� ������� ���������, {AEAEAE}� {ffffff}\"/rem\" {AEAEAE}����� ����������� ������"), SCM(playerid,0xAEAEAEFF,"����� ������� {ffffff}��������/�����, {AEAEAE}��������� � ���� � ������� ������� {ffffff}\"Y\""), DeletePVar(playerid,"helpengine");
			if( PlayerInCAR( playerid ) ) SCM(playerid,0xAEAEAEFF,"����� ���������� - {ffffff}\"Q\" {AEAEAE}������ ���������� - {ffffff}\"E\" {AEAEAE}��������� ������ - {ffffff}\"NUM8\""); SCM(playerid,0xAEAEAEFF,"��� ������������� ����������� �������� �������� ����������� �� NUMPAD - {ffffff}\"4\" � {ffffff}\"6\"");
			for(new i; i != sizeof sirenpos; i ++) // �������
			{
			    if(sirenpos[i][models] == GetVehicleModel(GetPlayerVehicleID(playerid)))
			    {
			    	if(GetVehicleModel(GetPlayerVehicleID(playerid)) == 585)
		    		{
			    	    if(GetPlayerVehicleID(playerid) >= ymvd[0] && GetPlayerVehicleID(playerid) <= ymvd[20]) return SCM(playerid,0xAEAEAEFF,"����� ��������/��������� ������������ ������, ������� ������� {ffffff}\"N\"");
						else return 1;
					}
			    	SCM(playerid,0xAEAEAEFF,"����� ��������/��������� ������������ ������, ������� ������� {ffffff}\"N\"");
			    }
			}
		}
		return 1;
    }
	return 1;
}

public OnPlayerEditDynamicObject(playerid, objectid, response, Float:x, Float:y, Float:z, Float:rx, Float:ry, Float:rz)
{
	new 
		Float:fX = x,
		Float:fY = y,
		Float:fZ = z,
		Float:fRotX = rx,
		Float:fRotY = ry,
		Float:fRotZ = rz
	;
    if( response == EDIT_RESPONSE_FINAL )
	{
	    if( GetPVarInt(playerid,"editobject") == 1 )
		{
			for(new i; i != MAX_OBJECTS_DROP; i ++)
			{
			    if(_objectInfo[i][objDrop][0] == 0 && _objectInfo[i][objDrop][1] == 0)
			    {
					_objectInfo[i][objDrop][0] = _invPlayer[playerid][invSlot][GetPVarInt(playerid,"selectSlot")];
					_objectInfo[i][objDrop][1] = 1; //_invPlayer[playerid][invSlotKol][GetPVarInt(playerid,"selectSlot")];
					_objectInfo[i][objPos][0] = fX;
					_objectInfo[i][objPos][1] = fY;
					_objectInfo[i][objPos][2] = fZ;
					_objectInfo[i][objObject] = objectid;
					_objectInfo[i][objWorld] = GetPlayerVirtualWorld( playerid );
					
					SetDynamicObjectPos(_objectInfo[i][objObject], fX, fY, fZ);
					SetDynamicObjectRot(_objectInfo[i][objObject], fRotX, fRotY, fRotZ);
					
					_objectInfo[i][objText] = CDT(_itemsInfo[_invPlayer[playerid][invSlot][GetPVarInt(playerid,"selectSlot")]][invName],0xFFFFFF50, _objectInfo[i][objPos][0],_objectInfo[i][objPos][1],_objectInfo[i][objPos][2],2.0,INVALID_PLAYER_ID,INVALID_VEHICLE_ID,0,GetPlayerVirtualWorld(playerid));
					
				    _invPlayer[playerid][invSlotKol][GetPVarInt(playerid,"selectSlot")]--;
				    if(_invPlayer[playerid][invSlotKol][GetPVarInt(playerid,"selectSlot")] <= 0) _invPlayer[playerid][invSlot][GetPVarInt(playerid,"selectSlot")]= 0;
				    SaveInventory(playerid);
				    SCM(playerid,0xB2EC5DFF,"�� ������� �������� �������");
				    DeletePVar(playerid,"editobject");
					DeletePVar(playerid,"selectSlot");
					SCM(playerid, -1, "����� ������� �������, ������� ������� "C_GRAY"- H");
					
					break;
				}
			}
		}
		
		if(GetPVarInt(playerid,"editfrakobject")==1)
		{
			for(new i; i != MAX_FRAK_OBJ; i ++)
			{
			    if(fObj[i][objID] == 0 && fObj[i][objFrak] == 0)
			    {
					fObj[i][objPos][0] = fX;
					fObj[i][objPos][1] = fY;
					fObj[i][objPos][2] = fZ;
					fObj[i][objPlayer] = playerid;
					fObj[i][objID] = objectid;
					fObj[i][objFrak] = pInfo[playerid][pFrak];
					SetDynamicObjectPos(objectid, fX, fY, fZ);
					SetDynamicObjectRot(objectid, fRotX, fRotY, fRotZ);

				    SCM(playerid,COLOR_WHITE,"�� ������� ���������� �������.");
				    SCM(playerid,COLOR_WHITE,"����� ������� ������� �������: /delobj ��� /fobj - ������������� �������");
				    DeletePVar(playerid,"editfrakobject");
				    
					break;
				}
			}
		}
	
		if( GetPVarInt(playerid,"fursel") == 1 || GetPVarInt(playerid,"fursel") == 2 ) // ���������� / ���������������
		{
		    new
				i = GetPVarInt(playerid,"nmenuid"),
		    	id = GetPVarInt(playerid,"furslot");
		    	
			if( GetPlayerVirtualWorld( playerid ) != nInfo[ i ][ nInt ] ) return SCM( playerid, -1, "�� ������ ���������� ������ ����� ������������!");
   			if( !IsPlayerInRangeOfPoint( playerid, 40.0, nInfo[ i ][ nExite ][ 0 ], nInfo[ i ][ nExite ][ 1 ], nInfo[ i ][ nExite ][ 2 ] ) )
   			{
   			    if( GetPVarInt(playerid,"fursel") == 1 )
				{
					DestroyDynamicObjected( fInfo[ GetPVarInt(playerid,"nmenuid") ][ fObjectid ][ GetPVarInt( playerid, "furslot" ) ]);
				    fInfo[ GetPVarInt(playerid,"nmenuid") ][ fObjectid ][ GetPVarInt( playerid, "furslot" ) ] = EOS;
				    fInfo[ GetPVarInt(playerid,"nmenuid") ][ fObject ][ GetPVarInt( playerid, "furslot" ) ] = EOS;
				    DeletePVar( playerid, "fursel" );
					SetPlayerPosF( playerid, nInfo[ i ][ nExite ][ 0 ], nInfo[ i ][ nExite ][ 1 ], nInfo[ i ][ nExite ][ 2 ], nInfo[ i ][ nExite ][ 3 ]);
				}

				if( GetPVarInt(playerid,"fursel") == 2 )
				{
					SPD( playerid, dFurniture, list, " ","" #C_GRAY "�{FFFFFF} ��������������� ������\n" #C_GRAY "�{FFFFFF} ���������� ������","��","�����");
				    DeletePVar( playerid, "fursel" );
				    SetPlayerPosF( playerid, nInfo[ i ][ nExite ][ 0 ], nInfo[ i ][ nExite ][ 1 ], nInfo[ i ][ nExite ][ 2 ], nInfo[ i ][ nExite ][ 3 ]);
				}
   				return SCM( playerid, -1, "�� ������ ���������� ������ ����� ������������!");
			}
		    
			SetDynamicObjectPos( fInfo[ i ][ fObjectid ][ id ], fX, fY, fZ );
			SetDynamicObjectRot( fInfo[ i ][ fObjectid ][ id ], fRotX, fRotY, fRotZ );
			
			_invPlayer[playerid][invSlotKol][GetPVarInt(playerid,"selectSlot")]--;
   			if(_invPlayer[playerid][invSlotKol][GetPVarInt(playerid,"selectSlot")] <= 0) _invPlayer[playerid][invSlot][GetPVarInt(playerid,"selectSlot")]= 0;
      		SaveInventory(playerid);
			
			SPD( playerid, dFurniture, list, " ","" #C_GRAY "�{FFFFFF} ��������������� ������\n" #C_GRAY "�{FFFFFF} ���������� ������","��","�����");
			
			if( GetPVarInt(playerid,"fursel") == 1 )
			{
			    mysql_format:str_big( "\
				INSERT INTO `" #DB_FURNITURE "` \
					(`IDned`, `Object`, `X`, `Y`,`Z`, `RX`, `RY`,`RZ`) \
				VALUES \
					('%d', '%d', '%f', '%f', '%f', '%f', '%f', '%f')",
				nInfo[ i ][ nID ],
				fInfo[ i ][ fObject ][ id ],
				fX, fY, fZ,
				fRotX, fRotY, fRotZ
				);

				mysql_tquery( mysql_connect_ID, str_big, "CreateFurniture", "ii", i, id );
			}
			else if( GetPVarInt(playerid,"fursel") == 2 )
			{
                mysql_format:str_small( "\
				UPDATE `" #DB_FURNITURE "` SET \
					`X` = '%f', `Y` = '%f', `Z` = '%f', `RX` = '%f', `RY` = '%f', `RZ` = '%f' \
				WHERE \
					`ID` = '%d'",
				fX, fY, fZ,
				fRotX, fRotY, fRotZ,
				fInfo[ i ][ fID ][ id ]
				);

				mysql_tquery( mysql_connect_ID, str_small, "", "" );
			}
			
			DeletePVar( playerid, "fursel" );
		    
		    return 1;
		}
		
	    if(GetPVarInt(playerid,"editcarattach")==1) // �������������� ������
		{
			new
				i = GetPVarInt( playerid, "editattachcar"),
				car = GetPVarInt( playerid, "attachcar"),
				Float:ofx, Float:ofy, Float:ofz, Float:ofaz,
   				Float:finalx, Float:finaly,
   				Float:px, Float:py, Float:pz, Float:roz;

			GetVehiclePos(cInfo[ car ][ cCar ], px, py, pz);
        	GetVehicleZAngle(cInfo[ car ][ cCar ], roz);

         	ofx = fX-px;
          	ofy = fY-py;
           	ofz = fZ-pz;
            ofaz = fRotZ-roz;

            finalx = ofx*floatcos(roz, degrees)+ofy*floatsin(roz, degrees);
            finaly = -ofx*floatsin(roz, degrees)+ofy*floatcos(roz, degrees);

            AttachDynamicObjectToVehicle(cInfo[ car ][ cAttachID ][ i ], cInfo[ car ][ cCar ], finalx, finaly, ofz, fRotX, fRotY, ofaz);

            cInfo[ car ][ cObjectX ][ i ] = finalx,
			cInfo[ car ][ cObjectY ][ i ] = finaly,
			cInfo[ car ][ cObjectZ ][ i ] = ofz,
			cInfo[ car ][ cObjectfX ][ i ] = fRotX,
			cInfo[ car ][ cObjectfY ][ i ] = fRotY,
			cInfo[ car ][ cObjectfZ ][ i ] = ofaz;

			SCM(playerid,0xB2EC5DFF,"�� ������� ��������������� ��������� ��������");
			DeletePVar(playerid,"editcarattach");
			
			SaveCarAttach( car );

			cmd::attachcar(playerid);

			return 1;
		}

		if(GetPVarInt(playerid,"editcarattach")==2) // ��������� ������
		{
			new
				i = GetPVarInt( playerid, "editattachcar"),
				car = GetPVarInt( playerid, "attachcar"),
				d,
				Float:ofx, Float:ofy, Float:ofz, Float:ofaz,
   				Float:finalx, Float:finaly,
   				Float:px, Float:py, Float:pz, Float:roz;

      		GetVehiclePos(cInfo[ car ][ cCar ], px, py, pz);
        	GetVehicleZAngle(cInfo[ car ][ cCar ], roz);

         	ofx = fX-px;
          	ofy = fY-py;
           	ofz = fZ-pz;
            ofaz = fRotZ-roz;

            finalx = ofx*floatcos(roz, degrees)+ofy*floatsin(roz, degrees);
            finaly = -ofx*floatsin(roz, degrees)+ofy*floatcos(roz, degrees);

            AttachDynamicObjectToVehicle(cInfo[ car ][ cAttachID ][ i ], cInfo[ car ][ cCar ], finalx, finaly, ofz, fRotX, fRotY, ofaz);

            cInfo[ car ][ cObjectX ][ i ] = finalx,
			cInfo[ car ][ cObjectY ][ i ] = finaly,
			cInfo[ car ][ cObjectZ ][ i ] = ofz,
			cInfo[ car ][ cObjectfX ][ i ] = fRotX,
			cInfo[ car ][ cObjectfY ][ i ] = fRotY,
			cInfo[ car ][ cObjectfZ ][ i ] = ofaz;

			for( new j; j != 10; j++ )
			{
				if(_invPlayer[playerid][invSlot][j] == cInfo[ car ][ cObjectInv ][ i ]) d = j;
			}

			SendMes(playerid,-1,"�� ������� ���������� " #C_GRAY "%s " #C_WHITE "�� ���� %d", GetObjName( cInfo[ car ][ cAttachObject ][ i ] ), i + 1 );

			_invPlayer[playerid][invSlotKol][d] -= 1;
			if( _invPlayer[playerid][invSlotKol][d] <= 0 ) _invPlayer[playerid][invSlot][d] = 0;

			SaveInventory(playerid);

			DeletePVar(playerid,"editcarattach");
			
			SaveCarAttach( car );

			cmd::attachcar(playerid);

			return 1;
		}
	}
	else if( response == EDIT_RESPONSE_CANCEL )
    {
    	if( GetPVarInt(playerid,"fursel") == 1 )
		{
			DestroyDynamicObjected( fInfo[ GetPVarInt(playerid,"nmenuid") ][ fObjectid ][ GetPVarInt( playerid, "furslot" ) ]);
		    fInfo[ GetPVarInt(playerid,"nmenuid") ][ fObjectid ][ GetPVarInt( playerid, "furslot" ) ] = EOS;
		    fInfo[ GetPVarInt(playerid,"nmenuid") ][ fObject ][ GetPVarInt( playerid, "furslot" ) ] = EOS;
		    DeletePVar( playerid, "fursel" );
		    return 1;
		}
		
		if( GetPVarInt(playerid,"fursel") == 2 )
		{
			SPD( playerid, dFurniture, list, " ","" #C_GRAY "�{FFFFFF} ��������������� ������\n" #C_GRAY "�{FFFFFF} ���������� ������","��","�����");
		    DeletePVar( playerid, "fursel" );
		    return 1;
		}
		
        if(GetPVarInt(playerid,"editcarattach") == 1)
		{
		    DeletePVar(playerid,"editcarattach");
		    SCM(playerid, -1, "�� �������� �������������� ��������!");
		    
		    new
				i = GetPVarInt( playerid, "editattachcar"),
				car = GetPVarInt( playerid, "attachcar"),
				Float:ofx, Float:ofy, Float:ofz, Float:ofaz,
   				Float:finalx, Float:finaly,
   				Float:px, Float:py, Float:pz, Float:roz;

			GetVehiclePos(cInfo[ car ][ cCar ], px, py, pz);
        	GetVehicleZAngle(cInfo[ car ][ cCar ], roz);

         	ofx = fX-px;
          	ofy = fY-py;
           	ofz = fZ-pz;
            ofaz = fRotZ-roz;

            finalx = ofx*floatcos(roz, degrees)+ofy*floatsin(roz, degrees);
            finaly = -ofx*floatsin(roz, degrees)+ofy*floatcos(roz, degrees);

            AttachDynamicObjectToVehicle(cInfo[ car ][ cAttachID ][ i ], cInfo[ car ][ cCar ], finalx, finaly, ofz, fRotX, fRotY, ofaz);

            cInfo[ car ][ cObjectX ][ i ] = finalx,
			cInfo[ car ][ cObjectY ][ i ] = finaly,
			cInfo[ car ][ cObjectZ ][ i ] = ofz,
			cInfo[ car ][ cObjectfX ][ i ] = fRotX,
			cInfo[ car ][ cObjectfY ][ i ] = fRotY,
			cInfo[ car ][ cObjectfZ ][ i ] = ofaz;
			
			SaveCarAttach( car );
			
		    return 1;
		}
		else if(GetPVarInt(playerid,"editcarattach") == 2)
		{
			new
				i = GetPVarInt( playerid, "editattachcar"),
				car = GetPVarInt( playerid, "attachcar");
				
			SCM(playerid, -1, "�� �������� ��������� ��������!");
			cInfo[ car ][ cAttachID ][ i ] = 0;
			cInfo[ car ][ cObjectInv ][ i ] = 0;
			cInfo[ car ][ cAttachObject ][ i ] = 0;
		}
		DeletePVar(playerid,"editcarattach");
		
		DeletePVar(playerid,"editobject");
		
		DeletePVar(playerid,"editfrakobject");
		DeletePVar(playerid,"selectSlot");
		
		DestroyDynamicObjected(objectid);
		SCM(playerid,0xCD4B47FF,"�� �������� ��������");

		Streamer_UpdateEx(playerid, fX, fY, fZ );
    }
    else if( response == EDIT_RESPONSE_UPDATE )
    {
    	CheckEditObject(playerid, fX, fY, fZ );
    }

	return 1;
}

