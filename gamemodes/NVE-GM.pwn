{
	for(new i; i != 1000; i ++)
	{
	    if(_itemsInfo[i][invID] == id)
		{
		    strmid(str_least, _itemsInfo[i][invName], 0, strlen(_itemsInfo[i][invName]),50);
		    break;
		}
	}
	return str_least;
}

PayDay(i)
{
	new c,
	    m,
	    s;
	gettime(c,m,s);
    //robmag[i] = 0;
	SetWorldTime(c);
	pInfo[i][pGame]++;

	pformat:( "" #C_ORANGE "������ ����� ���: " #C_GRAY "%d:00",c);
	psend:( i, COLOR_WHITE );
	pformat:( "�� �������� �� �������: " #C_GRAY "%d �����",pInfo[i][pGame]);
	psend:( i, COLOR_WHITE );

	if(pInfo[i][pFrak]==0 && pInfo[i][pJob]==0 && pInfo[i][pOrg][0] < 1)
	{
		SCM(i,-1,"" #C_GRAY "�� ��� ���������� ���� ��������� ������� �� ����������� � �������: 2.000 ���"),
		pInfo[i][pBank]+=2000,
		mysql_format:str_small("UPDATE `" #DB_ACCOUNTS "` SET `Bank` = '%d' WHERE `ID` = '%d'",pInfo[i][pBank],pInfo[i][pID]);
		mysql_function_query(mysql_connect_ID, str_small, false, "", "");
		//robmag[i] = 0;
	}
	
	if( pInfo[i][pOrg][0] > 0 && oInfo[ pInfo[i][pOrg][0] ][ oPay ] != 0 )
	{
	    if( oInfo[ pInfo[i][pOrg][0] ][ oMoney ] > oInfo[ pInfo[i][pOrg][0] ][ oPay ] )
	    {
	    	SendMes(i,-1,"" #C_GRAY "���� �������� �� ����������� %s ���������: %d ���", oInfo[ pInfo[i][pOrg][0] ][ oName ], oInfo[ pInfo[i][pOrg][0] ][ oPay ] );
	    	pInfo[i][pBank] += oInfo[ pInfo[i][pOrg][0] ][ oPay ];
	    	oInfo[ pInfo[i][pOrg][0] ][ oMoney ] -= oInfo[ pInfo[i][pOrg][0] ][ oPay ];
	    	mysql_format:str_small("UPDATE `" #DB_ACCOUNTS "` SET `Bank` = '%d' WHERE `ID` = '%d'",pInfo[i][pBank],pInfo[i][pID]);
			mysql_function_query(mysql_connect_ID, str_small, false, "", "");
			mysql_format:str_small("UPDATE `" #DB_ORGS "` SET `money` = '%d' WHERE `ID` = '%d'",oInfo[ pInfo[i][pOrg][0] ][ oMoney ], oInfo[ pInfo[i][pOrg][0] ][ oID ]);
			mysql_function_query(mysql_connect_ID, str_small, false, "", "");
	    }
	    else
	    {
	    	SendMes(i,-1,"" #C_GRAY "� ����������� %s �� ������� �����, ����� ��������� ��� ��������", oInfo[ pInfo[i][pOrg][0] ][ oName ] );
	    }
	}

    if(pInfo[i][pVip] > 0) viptime[i]++;
    if(viptime[i] >= 5 && pInfo[i][pVip] >= 2)
	{
	    new num = random(6);
		if(num == 0)//tamasita*
		{
			new money = random(40000)+10000;
			GiveMoney(i,floatround(money,floatround_round));
			pformat:( "�� �������� "C_GRAY"%d"C_WHITE" ������",money);
			psend:( i, COLOR_WHITE );
		}
		else if(num == 1)
		{
		    new gm = random(50)+50;
		    pInfo[i][pDonate]+=gm;
		    mysql_format:str_cmd("UPDATE `" #DB_ACCOUNTS "` SET `Donate` = '%d'  WHERE `Name` = '%s'",pInfo[i][pDonate],pInfo[i][pName]), mysql_function_query(mysql_connect_ID, str_cmd, false, "", "");
			pformat:( "�� �������� "C_GRAY"%d"C_WHITE" NCoin",gm);
			psend:( i, COLOR_WHITE );
		}
		else if(num == 2)
		{
		   	new idwear = 14+random(4);//��������
			GivePlayerItem(i,idwear,1);
			pformat:( "�� �������� "C_GRAY"%s"C_WHITE"",_itemsInfo[idwear][invName]);
			psend:( i, COLOR_WHITE );
		}
		else if(num == 3)
		{
		    new idwear = 365+random(3);//�����
			GivePlayerItem(i,idwear,1);
			pformat:( "�� �������� "C_GRAY"%s"C_WHITE"",_itemsInfo[idwear][invName]);
			psend:( i, COLOR_WHITE );
		}
		else if(num == 4)
		{
			new idwear, numbr = random(4);//�����
		   	if(numbr == 0) idwear = 25;
		    else if(numbr == 1) idwear = 26;
			else if(numbr == 2) idwear = 28;
		    else if(numbr == 3) idwear = 409;
			GivePlayerItem(i,idwear,1);
			pformat:( "�� �������� "C_GRAY"%s"C_WHITE"",_itemsInfo[idwear][invName]);
			psend:( i, COLOR_WHITE );
		}
		else if(num == 5)
		{
		    new idwear, numbr = random(2);//����
		    if(numbr == 0) idwear = 29;
		    else if(numbr == 1) idwear = 364;
			GivePlayerItem(i,idwear,1);
			pformat:( "�� �������� "C_GRAY"%s"C_WHITE"",_itemsInfo[idwear][invName]);
			psend:( i, COLOR_WHITE );
		}
		viptime[i] = 0;
	}
	if(pInfo[i][pVip] == 1)
	{
		new money;

		if( pInfo[i][pBank] > 6545129 )
		{
		    money=floatround(pInfo[i][pBank]/400,floatround_round);
		    SendMes(i,-1,"" #C_GRAY "VIP: {ffffff}��� ������������� ���� � ����� �������� �� 0.001% = " #C_GRAY "+%d",money);
		}
		else
		{
		    money=floatround(pInfo[i][pBank]/400,floatround_round);
