public OnDialogResponse(playerid, dialogid, response, listitem, inputtext[])
{
    ClearVar();
    
    printf("[%s] %d",pInfo[playerid][pName],dialogid);

    switch(dialogid)
	{
	    case dLogin:
	    {
	        if(!response) return SPD(playerid, dLogin, info, "����������", "{FFFFFF}�� ���� ������� � �������.\n{FF0000}�������: ����� �� �����������.\n{FFFFFF}��� ������ � ������� ������� \"/q\" � ���", "����", "�����"), Kick(playerid);
	        if(!strlen(inputtext)) return SPD(playerid, dLogin, DIALOG_STYLE_PASSWORD, "�����������", "������. �� ������ �� �����\n{FFFFFF}������� ������ �� �������� ��� ����, ���� ���������� ����:", "����", "�����");
            for(new i = strlen(inputtext)-1; i != -1; i--)
	        {
	            switch(inputtext[i])
	            {
	                case '0'..'9', '�'..'�', 'a'..'z', '�'..'�', 'A'..'Z': continue;
	                default: return SPD(playerid, dLogin, DIALOG_STYLE_PASSWORD, "�����������", "������. ������������ �������� ������ ��������� ����� � �����\n{FFFFFF}������� ������ �� �������� ��� ����, ���� ���������� ����:", "����", "�����");
	            }
	        }
	        if( !strcmp(pInfo[playerid][pPass], inputtext) )
	        {
	            mysql_format:str_small( "SELECT * FROM `" #DB_ACCOUNTS "` WHERE `ID` = %d", pInfo[playerid][pID] );
				mysql_tquery( mysql_connect_ID, str_small, "UploadPlayerAccount","i", playerid );
	        }
	        else
			{
				SPD(playerid, dLogin, DIALOG_STYLE_PASSWORD, "�����������", "������. �� ����� �������� ������\n{FFFFFF}������� ������ �� �������� ��� ����, ���� ���������� ����:", "����", "�����");
			}
			return 1;
	    }

	    case dLogin+1:
	    {
		    if(!response) return 1;
		    switch(listitem)
		    {
			    //��������
			    case 0:
				{
				    if( pInfo[playerid][pPos][0] == 0.0 ) return SPD(playerid,dLogin+1,list,"" #C_GRAY "�������� ����� ������ ���������","" #C_GRAY "1.{FFFFFF}  ����� ������\n" #C_GRAY "2.{FFFFFF} ���\n" #C_GRAY "3.{FFFFFF} ������\n" #C_GRAY "4.{FFFFFF} ������","��","�������"), SCM(playerid,-1,"����� ������ ������ - �� ������!");
					SetPVarInt(playerid,"spawns",2);
					SetPVarInt(playerid, "gLogged", 1);
					SpawnPlayer(playerid);
					mysql_format:str_small( "SELECT * FROM `" #DB_ACCOUNTS "` WHERE `ID` = %d", pInfo[playerid][pID] );
					mysql_tquery( mysql_connect_ID, str_small, "LoadWeapon","i", playerid );
					return SendMessageVip(playerid), CheckDelay(playerid);
				}
				//���
				case 1:
				{
					if(pInfo[playerid][pHspawn]==0) return SCM(playerid,-1,"� ��� ��� ���� ��� �� �� ������� ��� ��� ������"), SetPVarInt(playerid,"spawns",1), SPD(playerid,dLogin+1,list,"" #C_GRAY "�������� ����� ������ ���������","" #C_GRAY "1.{FFFFFF} ����� ������\n" #C_GRAY "2.{FFFFFF} ���\n" #C_GRAY "3.{FFFFFF} ������\n" #C_GRAY "4.{FFFFFF} ������","��","�������");
					if(strcmp(nInfo[pInfo[playerid][pHspawn]-1][nOwner],pInfo[playerid][pName],true))
					{
						SCM(playerid,-1,"��������� ���� ��� ��� ��������� �� �������� �����"), SetPVarInt(playerid,"spawns",1), SPD(playerid,dLogin+1,list,"" #C_GRAY "�������� ����� ������ ���������","" #C_GRAY "1.{FFFFFF} ����� ������\n" #C_GRAY "2.{FFFFFF} ���\n" #C_GRAY "3.{FFFFFF} ������\n" #C_GRAY "4.{FFFFFF} ������","��","�������");
						return mysql_format:str_small("UPDATE `" #DB_ACCOUNTS "` SET `Hspawn` = '0' WHERE `Name` = '%s'",pInfo[playerid][pName]), mysql_function_query(mysql_connect_ID, str_small, false, "", "");
					}
					SetPVarInt(playerid,"spawns",4), SetPVarInt(playerid, "gLogged", 1); SpawnPlayer(playerid);
					mysql_format:str_small( "SELECT * FROM `" #DB_ACCOUNTS "` WHERE `ID` = %d", pInfo[playerid][pID] );
					mysql_tquery( mysql_connect_ID, str_small, "LoadWeapon","i", playerid );
					return SendMessageVip(playerid), CheckDelay(playerid);
				}
				//������
			    case 2:
			    {
					if(pInfo[playerid][pFrak]!=0)
					{
						SetPVarInt(playerid,"spawns",5), SetPVarInt(playerid, "gLogged", 1); SpawnPlayer(playerid);
						mysql_format:str_small( "SELECT * FROM `" #DB_ACCOUNTS "` WHERE `ID` = %d", pInfo[playerid][pID] );
						mysql_tquery( mysql_connect_ID, str_small, "LoadWeapon","i", playerid );
						return SendMessageVip(playerid), CheckDelay(playerid);
					}
					else
					{
					    if(pInfo[playerid][pOrg][0] > 0)
					    {
					        SetPVarInt(playerid,"spawns",5), SetPVarInt(playerid, "gLogged", 1); SpawnPlayer(playerid);
        					mysql_format:str_small( "SELECT * FROM `" #DB_ACCOUNTS "` WHERE `ID` = %d", pInfo[playerid][pID] );
							mysql_tquery( mysql_connect_ID, str_small, "LoadWeapon","i", playerid );
							return SendMessageVip(playerid), CheckDelay(playerid);
					    }
					}
					return SCM(playerid,-1,"�� �� �������� � �������"), SetPVarInt(playerid,"spawns",1), SPD(playerid,dLogin+1,list,"" #C_GRAY "�������� ����� ������ ���������","" #C_GRAY "1.{FFFFFF} ����� ������\n" #C_GRAY "2.{FFFFFF} ���\n" #C_GRAY "3.{FFFFFF} ������\n" #C_GRAY "4.{FFFFFF} ������","��","�������");
				}
				//������
				case 3:
				{
					SetPVarInt(playerid,"spawns",3);
					SetPVarInt(playerid, "gLogged", 1);
					SpawnPlayer(playerid);
					mysql_format:str_small( "SELECT * FROM `" #DB_ACCOUNTS "` WHERE `ID` = %d", pInfo[playerid][pID] );
					mysql_tquery( mysql_connect_ID, str_small, "LoadWeapon","i", playerid );
					return SendMessageVip(playerid), CheckDelay(playerid);
				}
			}
			
			return 1;
	    }
	    
		case dCreateAccount:
		{
		    if(!response)
		    {
		        SCM(playerid, -1, "����������� ��������. ��� ������ � ������� ����������� /q(uit)");

		        Kick(playerid);

		        return 1;
		    }

      		for(new i = strlen(inputtext)-1; i != -1; i--)
	        {
	            switch(inputtext[i])
	            {
	                case '0'..'9', '�'..'�', 'a'..'z', '�'..'�', 'A'..'Z': continue;
	                default: return SPD(playerid, dCreateAccount, DIALOG_STYLE_INPUT, "�����������", "������. ������������ �������� ������ ��������� ����� � �����\n{FFFFFF}������� ������ �� �������� ��� ����, ���� ���������� ����:", "����", "�����");
	            }
	        }

		    new password_length = strlen(inputtext);

		    if(!password_length)
			    return SPD(playerid, dCreateAccount, DIALOG_STYLE_INPUT, "�����������", erorreg1, "�����", "������");

		    else if(password_length < 4)
			    return SPD(playerid, dCreateAccount, DIALOG_STYLE_INPUT, "�����������", erorreg2, "�����", "������");

			else if(password_length > 20)
			    return SPD(playerid, dCreateAccount, DIALOG_STYLE_INPUT, "�����������", erorreg3, "�����", "������");

			else
			{
			    format(pInfo[playerid][pPass], 30, "%s", inputtext);

			    SPD(playerid, dCreateAccount + 1, DIALOG_STYLE_INPUT, "����������� �����", mailtext, "�����", "������");
			}
		}

		case dCreateAccount + 1:
		{
			if(!response)
			{
			    SCM(playerid, -1, "����������� ��������. ��� ������ � ������� ����������� /q(uit)");

		        Kick(playerid);

		        return 1;
			}

			new length = strlen(inputtext);

			if(!length)
			    return SPD(playerid, dCreateAccount + 1, DIALOG_STYLE_INPUT, "����������� �����", mailtext, "�����", "������");

			if(length < 4)
			    return SPD(playerid, dCreateAccount + 1, DIALOG_STYLE_INPUT, "����������� �����", mailtext, "�����", "������");

			for(new idx; idx < length; idx ++)
			{
			    switch(inputtext[idx])
			    {
			        case '0'..'9', 'a'..'z', 'A'..'Z', '@', '.', '_', '-': continue;
			        default: return SPD(playerid, dCreateAccount + 1, DIALOG_STYLE_INPUT, "����������� �����", #C_GRAY "������: {FFFFFF}EMail-����� �� ������������� �������\n\n" mailtext, "�����", "������");
			    }
			}

			if(strfind(inputtext, "@") == -1)
			{
			    return SPD(playerid, dCreateAccount + 1, DIALOG_STYLE_INPUT, "����������� �����", #C_GRAY "������: {FFFFFF}EMail-����� �� ������������� �������\n\n" mailtext, "�����", "������");
			}

			format(pInfo[playerid][pMail], 25, "%s", inputtext);

			SetPVarInt(playerid, "ucp_question_id", 0);

			format:str_big( #C_GRAY "UCP ����������� / ������ �%d\n\n{ffffff}%s", GetPVarInt(playerid, "ucp_question_id") + 1, ucp_questions[GetPVarInt(playerid, "ucp_question_id")]);
			SPD(playerid, dCreateAccount + 2, DIALOG_STYLE_INPUT, "UCP �����������", str_big, "�����", "������");
		}

		case dCreateAccount + 2:
		{
			new question_id = GetPVarInt(playerid, "ucp_question_id"),
