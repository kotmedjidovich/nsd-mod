CMD:pm(playerid, params[])
{
    if(GetPVarInt(playerid,"mute")!=0) return SendMes(playerid,-1,"" #C_GRAY "[MUTE] � ��� �������� OOC ��� ��: " #C_ORANGE "%d ������",GetPVarInt(playerid,"mute"));
	if(sscanf(params, "ds[150]", params[0],params[1])) return SCM(playerid, COLOR_WHITE, "�����������: /pm [id] [�����]");
	if(params[0]==playerid) return SCM(playerid,-1,"�� �� ������ ������ ������ ����!");
	if(!IsPlayerConnected(params[0])) return SCM(playerid,-1,"������ � ����� id ��� ������");
	if(GetPVarInt(params[0],"pmoff")==1) return SCM(playerid,-1,"����� �������� ���� PM");
	
	pformat:( "{E7F56D}(( PM | %s[%d]: %s ))",pInfo[playerid][pName],playerid,params[1]);
	psend:( params[0], COLOR_WHITE );
	
	pformat:( "{E7F56D}(( PM | ��� %s[%d]: %s ))",pInfo[params[0]][pName],params[0],params[1]);
	psend:( playerid, COLOR_WHITE );
	
	format:str_small("" #C_LIGHTBLUE "[PM] �� %s[%d] ��� %s[%d]: %s",pInfo[playerid][pName],playerid,pInfo[params[0]][pName],params[0],params[1]);
    SAMT(COLOR_WHITE,str_small,0);
    str_small[0] = EOS;
    
    return 1;
}

