public: LoadWeapon(playerid)
{
    new wlod[70];
	new ammo[10];
	cache_get_field_content(0, "pAmmo", wlod, mysql_connect_ID,70);
	sscanf(wlod, "p<|>dddddddddd",
	ammo[0],
	ammo[1],
	ammo[2],
	ammo[3],
	ammo[4],
	ammo[5],
	ammo[6],
	ammo[7],
	ammo[8],
	ammo[9]);

	new wlod2[70];
	new id[10];
	cache_get_field_content(0, "pWeapon", wlod2, mysql_connect_ID,70);
	sscanf(wlod2, "p<|>dddddddddd",
	id[0],
	id[1],
	id[2],
	id[3],
	id[4],
	id[5],
	id[6],
	id[7],
	id[8],
	id[9]);

	for(new h = 0; h < 10; h++)
	{
		if(ammo[h] == 0 || id[h] == 0) continue;
		ac_GivePlayerWeapon(playerid, id[h], ammo[h]);
	}
	return 1;
}


IsAdmin(playerid, lvl)
{
    if(pInfo[playerid][pAdmin] == 0) return SCM(playerid, COLOR_DARK_GRAY, !NOT_PERMITTED );
    if(pInfo[playerid][pAdmin] < lvl) return SCM(playerid, COLOR_DARK_GRAY, !NOT_PERMITTED );
    if(GetPVarInt(playerid, "alogin") == 0) return SCM(playerid, COLOR_DARK_GRAY, !"��� ����, ����� ��������� ������ ��������, ������������� ��� �������������" );
	return false;
}

public: IsPlayerMysql_check(playerid)
{
	new
		i = cache_get_row_count();

	if( !i ) return SCM(playerid, COLOR_DARK_GRAY, "����� � ����� ����� - �� ������!");

	SetPVarInt( playerid, "admoff", cache_get_field_content_int(0, "ID", mysql_connect_ID) );

	SPD( playerid, dAdmin+19, list, nameadmoff[playerid],"\
	" #C_GRAY "1. " #C_WHITE "������ ������� warn\n\
	" #C_GRAY "2. " #C_WHITE "������ ������� ban\n\
	" #C_GRAY "3. " #C_WHITE "������ ������� mute\n\
	" #C_GRAY "4. " #C_WHITE "������ ������� ����������", "�����","�����");
	
	return false;
}

SetPlayerPosF(playerid,Float:x,Float:y,Float:z,Float:f) { freeze[playerid]=5, SetPlayerPos(playerid,x,y,z), TogglePlayerControllable(playerid,false), SetCameraBehindPlayer(playerid); if(f!=0) SetPlayerFacingAngle(playerid,f); return 1; }

SendAdminMessage(clr, string[])
{
	foreach(Player, i)
	{
		if(IsPlayerConnected(i) && GetPVarInt(i,"gLogged") != 0)
		{
			if(pInfo[i][pAdmin] >= 1) SCM(i, clr, string);
		}
	}
    return 1;
}

SendAdminMessageType(clr, string[], type)
{
	foreach(Player, i)
	{
		if(IsPlayerConnected(i) && GetPVarInt(i,"gLogged") != 0)
		{
			if(pInfo[i][pAdmin] >= 1)
			{
			    if( type == 0 && GetPVarInt( i, "pmspec" ) == 1 ) continue;
			    if( type == 1 && GetPVarInt( i, "payspec" ) == 1 ) continue;
			    if( type == 2 && GetPVarInt( i, "dspec" ) == 0 ) continue;
			    if( type == 3 && GetPVarInt( i, "conspec" ) == 0 ) continue;
			    
				SCM(i, clr, string);
			}
		}
	}
    return 1;
}

public: ClearAnimText(playerid) return ApplyAnimation(playerid,"CARRY","crry_prtial",4.1,0,0,0,0,0);

stats(playerid,idshow)
{
	ClearVar();

	new org[40], rang[40], frak[40], dolj[35], dolg[35], nomer[14], jobz[45];
	if(pInfo[playerid][pNumber]==0)
	{
		f(nomer),"���"); // ����� �������� ���
	}
	else
	{
		f(nomer),"%d",pInfo[playerid][pNumber]); // ����� �������� ����
	}

	if(pInfo[playerid][pOrg][0] <= 0 || (pInfo[playerid][pOrg][0] != 0 && oInfo[pInfo[playerid][pOrg][0]][oType] == 0)) // ����������� ���
	{
		f(org),"���"), f(rang),"���");
	}
	else // ����������� ����
	{
		f(org),"%s",oInfo[pInfo[playerid][pOrg][0]][oName]);
		f(rang),"%s[%d]",pInfo[playerid][pDol],pInfo[playerid][pOrg][1]);
	}

	if(pInfo[playerid][pFrak]==0)
	{
		f(frak),"���"); // �������
		f(dolj),"���"); // ���������
		f(dolg),"���"); // ���������
	}
	else
	{
		f(frak),"%s",GetFrakName(pInfo[playerid][pFrak],0)); // �������
		f(dolj),"%s[%d]",pInfo[playerid][pDol],pInfo[playerid][pRang]); // ���������[����]
		f(dolg),"%s[%d]",pInfo[playerid][pDols],pInfo[playerid][pRang]); // ���������[����]
	}

	if(pInfo[playerid][pJob][0]==0) f(jobz),"���");
	if(pInfo[playerid][pJob][0]==1) f(jobz),"�������� ��������");
	if(pInfo[playerid][pJob][0]==2) f(jobz),"�������� �����");
	if(pInfo[playerid][pJob][0]==3) f(jobz),"�������� ����");

	switch( pInfo[playerid][pFight] )
	{
		case 0: format:str_least("�����������");
 		case 4: format:str_least("�����������");
   		case 5: format:str_least("����");
	    case 6: format:str_least("����-��");
	    case 7: format:str_least("������");
	}


	format:str_cmd("\
	" #C_GRAY "��� �������:\t\t\t {ffffff}%s\n\
	" #C_GRAY "����� �� �������:\t\t {ffffff}%d\n\
	" #C_GRAY "����� �� �����:\t\t {ffffff}%d\n\
	" #C_GRAY "����� � �����:\t\t {ffffff}%d\n\
	" #C_GRAY "������:\t\t\t {ffffff}%s\n\
	" #C_GRAY "�����������:\t\t\t {ffffff}%s\n\
	" #C_GRAY "����:\t\t\t\t {ffffff}%s\n\
	" #C_GRAY "�������:\t\t\t {ffffff}%s\n\
	" #C_GRAY "������:\t\t\t {ffffff}%s\n\
	" #C_GRAY "���������:\t\t\t {ffffff}%s\n\
	" #C_GRAY "����� ��������:\t\t {ffffff}%s\n\
	" #C_GRAY "��������������:\t\t {ffffff}%d/3\n\
	" #C_GRAY "����� ���:\t\t\t {ffffff}%s",pInfo[playerid][pName],pInfo[playerid][pGame],pInfo[playerid][pMoney],pInfo[playerid][pBank],jobz,org,rang,frak,dolj,dolg,nomer,pInfo[playerid][pWarn],str_least);
	SPD(idshow,d_null,info,"" #C_ABILITY "" #C_ABILITY "����������",str_cmd,"�������","");
	return 1;
}

statsa(playerid,idshow)
{
	ClearVar();

	new org[40], rang[40], frak[40], dolj[35],dolg[35], nomer[14], jobz[45];
	if(pInfo[playerid][pNumber]==0)
	{
		f(nomer),"���"); // ����� �������� ���
	}
